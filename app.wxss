/* ========================================================
   现代化设计系统 v6 —— 全局 Token
   ======================================================== */
page {
  --ink:    #14152A;
  --ink-2:  #5A5C70;
  --ink-3:  #9A9CB0;
  --line:   #EEF0F6;
  --bg:     #F4F5FA;
  --card:   #FFFFFF;
  --field:  #F3F5FB;
  --r-l: 30rpx; --r-m: 22rpx; --r-s: 14rpx; --pill: 999rpx;
  --sh-s: 0 4rpx 18rpx rgba(20,21,42,.05);
  --sh-m: 0 10rpx 30rpx rgba(20,21,42,.07);
  --bg-card: #FFFFFF;
  --text-disabled: #9A9CB0;
  --radius-lg: 30rpx; --radius-sm: 14rpx;
  --shadow-sm: 0 4rpx 18rpx rgba(20,21,42,.05);
  --font-md: 26rpx; --font-lg: 32rpx;
  background: var(--bg);
  color: var(--ink);
}

/* 通用：渐变 Hero 头 */
.x-hero {
  position: relative; overflow: hidden;
  padding: 36rpx 32rpx 56rpx;
  border-radius: 0 0 40rpx 40rpx;
  color: #fff;
}
.x-hero-orb { position: absolute; border-radius: 50%; background: rgba(255,255,255,.16); pointer-events: none; }
.x-hero-orb.a { width: 240rpx; height: 240rpx; top: -90rpx; right: -60rpx; }
.x-hero-orb.b { width: 160rpx; height: 160rpx; bottom: -70rpx; left: 30rpx; background: rgba(255,255,255,.10); }
.x-hero-back  { position: relative; z-index: 1; font-size: 28rpx; opacity: .92; }
.x-hero-title { position: relative; z-index: 1; display: block; font-size: 44rpx; font-weight: 800; letter-spacing: -.5px; margin-top: 6rpx; }
.x-hero-sub   { position: relative; z-index: 1; display: block; font-size: 24rpx; opacity: .85; margin-top: 8rpx; }

/* 通用：玻璃底栏 */
.x-glass-bar {
  position: fixed; left: 0; right: 0; bottom: 0; z-index: 100;
  display: flex; gap: 18rpx;
  padding: 18rpx 28rpx calc(28rpx + env(safe-area-inset-bottom));
  background: linear-gradient(180deg, rgba(244,245,250,0) 0%, rgba(244,245,250,.92) 38%, #fff 100%);
}

/* 通用：按下反馈 */
.x-tap:active { transform: scale(.97); opacity: .92; transition: transform .12s ease, opacity .12s ease; }

/* ========================================
   设计 Token — 统一配色体系
   Primary:   #4F6EF7  主色（靛蓝）
   Primary Dark: #3D56D4  深色变体
   Gradient:  #4F6EF7 → #6C5CE7  主渐变
   Success:   #52C41A  成功绿
   Danger:    #FF4D4F  危险红
   Warning:   #FA8C16  警告橙
   Text:      #1A1A1A  主文字
   Text Sec:  #8C8C8C  次级文字
   Bg:        #F5F6FA  页面背景
   Card:      #FFFFFF  卡片白
   ======================================== */

page {
  background-color: #F5F6FA;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
  color: #1A1A1A;
}

/* ========================================
   动画系统
   ======================================== */

/* 页面入场：淡入 + 上浮 */
@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(36rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* 卡片入场：淡入 + 缩放 */
@keyframes fadeInScale {
  from {
    opacity: 0;
    transform: scale(0.94);
  }
  to {
    opacity: 1;
    transform: scale(1);
  }
}

/* 从左滑入 */
@keyframes slideInLeft {
  from {
    opacity: 0;
    transform: translateX(-48rpx);
  }
  to {
    opacity: 1;
    transform: translateX(0);
  }
}

/* 从右滑入（导航推入） */
@keyframes slideInRight {
  from {
    opacity: 0;
    transform: translateX(60rpx);
  }
  to {
    opacity: 1;
    transform: translateX(0);
  }
}

/* 弹入 */
@keyframes bounceIn {
  0% {
    opacity: 0;
    transform: scale(0.3);
  }
  50% {
    transform: scale(1.04);
  }
  70% {
    transform: scale(0.96);
  }
  100% {
    opacity: 1;
    transform: scale(1);
  }
}

/* ========== Design Tokens ========== */
/*
  圆角体系
  --radius-hero: 64rpx   头部大圆角、FAB
  --radius-lg:   32rpx   大卡片（stats-card、action-card）
  --radius-md:   20rpx   普通卡片（goods-item、search-bar）
  --radius-sm:   12rpx   小标签、分页按钮
*/

/* 通用动画工具类 */
.animate-fade-in {
  animation: fadeInUp 0.45s cubic-bezier(0.25, 0.46, 0.45, 0.94) both;
}

.animate-card {
  animation: fadeInUp 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94) both;
}

.animate-bounce {
  animation: bounceIn 0.5s cubic-bezier(0.68, -0.55, 0.27, 1.55) both;
}

.animate-slide-in {
  animation: slideInRight 0.35s cubic-bezier(0.25, 0.46, 0.45, 0.94) both;
}

/* ========== 通用按压反馈 ========== */
.goods-item:active,
.receivable-card:active,
.action-card:active,
.mini-action:active,
.grid-item:active,
.menu-item:active {
  transform: scale(0.97);
  opacity: 0.88;
  transition: transform 0.12s ease, opacity 0.12s ease;
}

/* ========== Loading Spinner ========== */
@keyframes spin {
  to { transform: rotate(360deg); }
}
.loading-spinner {
  width: 56rpx; height: 56rpx;
  border: 4rpx solid #e8e8e8;
  border-top-color: #4F6EF7;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin: 0 auto;
}

/* ========== FAB 呼吸脉冲 ========== */
@keyframes fabPulse {
  0%, 100% { box-shadow: 0 8rpx 28rpx rgba(79, 110, 247, 0.25); }
  50%      { box-shadow: 0 8rpx 40rpx rgba(79, 110, 247, 0.45), 0 0 0 12rpx rgba(79, 110, 247, 0.08); }
}
.add-btn {
  animation: fabPulse 2.5s ease-in-out infinite;
  transition: transform 0.2s ease;
}
.add-btn:active {
  transform: scale(0.92);
}

/* ========== 搜索框 ========== */
.search-bar {
  transition: box-shadow 0.3s ease, border-color 0.3s ease;
}
.search-bar.focused {
  box-shadow: 0 0 0 3rpx rgba(79, 110, 247, 0.15), 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}
.search-input {
  transition: color 0.3s ease;
}

/* ========== 空状态脉冲 ========== */
@keyframes emptyPulse {
  0%, 100% { transform: scale(1); opacity: 0.6; }
  50%      { transform: scale(1.08); opacity: 0.85; }
}
.empty-icon {
  font-size: 96rpx;
  margin-bottom: 24rpx;
  animation: emptyPulse 2.4s ease-in-out infinite;
}

/* 容器 */
.container {
  padding: 28rpx;
  min-height: 100vh;
}

/* ========== 二级/三级页面通用样式 ========== */
.page-header {
  padding: 20rpx 8rpx 16rpx;
}
.page-title {
  font-size: 38rpx;
  font-weight: 700;
  color: #1a1a2e;
}
.page-subtitle {
  font-size: 24rpx;
  color: #8c8c8c;
  margin-top: 4rpx;
}
.section-card {
  background: #fff;
  border-radius: 24rpx;
  box-shadow: 0 2rpx 16rpx rgba(0,0,0,0.04);
  padding: 28rpx 24rpx;
  margin-bottom: 20rpx;
  border-left: 5rpx solid #4F6EF7;
  transition: box-shadow 0.2s ease;
}
.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1a1a2e;
  margin-bottom: 16rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

/* 输入框统一美化 */
input, textarea {
  background: #f8f9fc;
  border: 1rpx solid #e8ecf2;
  border-radius: 14rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  transition: border-color 0.2s ease, background 0.2s ease;
}
input:focus, textarea:focus {
  border-color: #4F6EF7;
  background: #fff;
}

/* 主要操作按钮 */
.btn-primary-full {
  width: 100%;
  background: linear-gradient(135deg, #4F6EF7, #3D56D4);
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 44rpx;
  padding: 24rpx 0;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(79,110,247,0.3);
  transition: transform 0.15s ease, box-shadow 0.15s ease;
}
.btn-primary-full:active {
  transform: scale(0.97);
  box-shadow: 0 4rpx 12rpx rgba(79,110,247,0.2);
}

/* 按钮 */
.btn-group {
  display: flex;
  gap: 20rpx;
  margin-top: 40rpx;
  padding: 0 20rpx;
}

.submit-btn {
  flex: 1;
  background: linear-gradient(135deg, #4F6EF7, #6C5CE7);
  color: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  font-size: 28rpx;
  font-weight: 600;
  text-align: center;
  box-shadow: 0 8rpx 24rpx rgba(79,110,247,0.25);
}

.cancel-btn {
  flex: 1;
  background-color: #F5F5F5;
  color: #595959;
  border-radius: 16rpx;
  padding: 24rpx;
  font-size: 28rpx;
  text-align: center;
}

/* 输入框 */
.input {
  width: 100%;
  padding: 20rpx;
  border: 2rpx solid #E8E8E8;
  border-radius: 12rpx;
  font-size: 24rpx;
  background: #fff;
}

/* 表单卡片 */
.form {
  background-color: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
}

/* 错误提示 */
.error-message {
  color: #FF4D4F;
  font-size: 20rpx;
  margin-top: 10rpx;
}

/* 成功提示 */
.success-message {
  color: #52C41A;
  font-size: 20rpx;
  margin-top: 10rpx;
}

/* 加载状态 */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.loading-text {
  margin-top: 20rpx;
  font-size: 24rpx;
  color: #8C8C8C;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
  color: #BFBFBF;
}

.empty-icon {
  font-size: 96rpx;
  margin-bottom: 24rpx;
  opacity: 0.6;
}

.empty-text {
  font-size: 26rpx;
  color: #8C8C8C;
}

/* 通用分页栏 */
.pagination {
  display: flex; align-items: center; justify-content: center; gap: 12rpx;
  padding: 12rpx 16rpx; margin: 16rpx 0;
  background: var(--bg-card,#fff); border-radius: 40rpx;
}
.page-btn {
  background: var(--field,#F3F5FB); border: none; border-radius: 30rpx;
  color: var(--ink-2,#5A5C70); font-size: 24rpx; padding: 14rpx 28rpx;
  line-height: 1.2; transition: all .15s ease;
}
.page-btn:active { background: var(--ink-3,#9A9CB0); color: #fff; }
.page-btn[disabled] { opacity: .35; }

.page-info {
  color: #999;
  font-size: 22rpx;
  margin: 0 12rpx;
}

/* 通用浮动添加按钮 */
.fab-btn {
  position: fixed;
  bottom: 40rpx;
  left: 10%;
  width: 80%;
  height: 96rpx;
  background: linear-gradient(135deg, #4F6EF7, #6C5CE7);
  border-radius: 48rpx;
  box-shadow: 0 12rpx 36rpx rgba(79,110,247,0.35);
  color: #fff;
  font-size: 32rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
}

.fab-btn:active {
  transform: scale(0.97);
  box-shadow: 0 8rpx 24rpx rgba(79,110,247,0.45);
}

/* 通用搜索栏 */
.search-bar {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 20rpx;
  padding: 16rpx 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04);
}

.search-box {
  display: flex;
  align-items: center;
  flex: 1;
  background: #F5F6FA;
  border-radius: 16rpx;
  min-height: 68rpx;
  padding: 0 20rpx;
}

.search-icon {
  color: #BFBFBF;
  font-size: 24rpx;
  margin-right: 10rpx;
}

.search-input {
  flex: 1;
  color: #1A1A1A;
  font-size: 26rpx;
}

/* ============================================================
   NEXUS-3D 动画增强系统
   非线性弹簧曲线 + 3D 透视 + 交互动效
   ============================================================ */

/* 弹性上浮 */
@keyframes nexus-spring-up {
  0%   { opacity: 0; transform: translateY(50rpx) scale(0.85); }
  60%  { opacity: 1; transform: translateY(-8rpx) scale(1.03); }
  80%  { transform: translateY(4rpx) scale(0.99); }
  100% { transform: translateY(0) scale(1); }
}

/* 弹性弹出 */
@keyframes nexus-pop {
  0%   { opacity: 0; transform: scale(0.3) rotate(-8deg); }
  50%  { opacity: 1; transform: scale(1.08) rotate(3deg); }
  70%  { transform: scale(0.96) rotate(-1deg); }
  100% { transform: scale(1) rotate(0); }
}

/* 3D 翻转入场（兼容版 — 使用 scaleX 模拟翻转，无需 perspective） */
@keyframes nexus-enter-3d {
  0%   { opacity: 0; transform: scaleX(0.5) translateY(40rpx); }
  55%  { opacity: 1; transform: scaleX(1.04) translateY(-6rpx); }
  80%  { transform: scaleX(0.97) translateY(3rpx); }
  100% { transform: scaleX(1) translateY(0); }
}

/* 左侧滑入（兼容版 — scaleX+translateX 模拟3D旋转） */
@keyframes nexus-slide-3d-left {
  0%   { opacity: 0; transform: scaleX(0.6) translateX(-60rpx); }
  100% { opacity: 1; transform: scaleX(1) translateX(0); }
}

/* 右侧滑入 */
@keyframes nexus-slide-3d-right {
  0%   { opacity: 0; transform: scaleX(0.6) translateX(60rpx); }
  100% { opacity: 1; transform: scaleX(1) translateX(0); }
}

/* 深度浮现（兼容版 — scale+translateY） */
@keyframes nexus-depth-in {
  0%   { opacity: 0; transform: scale(0.8) translateY(30rpx); }
  100% { opacity: 1; transform: scale(1) translateY(0); }
}

/* 浮动光晕 */
@keyframes nexus-float {
  0%,100% { transform: translateY(0) scale(1) rotate(0deg); }
  33%     { transform: translateY(-30rpx) scale(1.06) rotate(8deg); }
  66%     { transform: translateY(-15rpx) scale(0.96) rotate(-5deg); }
}

/* 旋转光环 */
@keyframes nexus-spin {
  to { transform: rotate(360deg); }
}

/* 脉冲辉光 */
@keyframes nexus-pulse-glow {
  0%,100% { box-shadow: 0 0 20rpx rgba(79,110,247,0.3), 0 0 40rpx rgba(79,110,247,0.1); }
  50%     { box-shadow: 0 0 30rpx rgba(79,110,247,0.5), 0 0 80rpx rgba(79,110,247,0.2); }
}

/* 光泽扫过 */
@keyframes nexus-shine {
  0%   { transform: translateX(-150%) skewX(-25deg); }
  100% { transform: translateX(250%) skewX(-25deg); }
}

/* 呼吸缩放 */
@keyframes nexus-breathe {
  0%,100% { transform: scale(1); opacity: 0.6; }
  50%     { transform: scale(1.12); opacity: 0.9; }
}

/* ===== 动画工具类 ===== */
.anim-spring      { animation: nexus-spring-up 0.65s cubic-bezier(0.34,1.56,0.64,1) both; }
.anim-pop         { animation: nexus-pop 0.6s cubic-bezier(0.34,1.56,0.64,1) both; }
.anim-enter-3d    { animation: nexus-enter-3d 0.7s cubic-bezier(0.16,1,0.3,1) both; }
.anim-slide-left  { animation: nexus-slide-3d-left 0.6s cubic-bezier(0.16,1,0.3,1) both; }
.anim-slide-right { animation: nexus-slide-3d-right 0.6s cubic-bezier(0.16,1,0.3,1) both; }
.anim-depth       { animation: nexus-depth-in 0.7s cubic-bezier(0.16,1,0.3,1) both; }
.anim-float       { animation: nexus-float 8s ease-in-out infinite; }

/* ===== 卡片悬浮效果 ===== */
.card-3d {
  transition: transform 0.4s cubic-bezier(0.34,1.56,0.64,1),
              box-shadow 0.4s cubic-bezier(0.34,1.56,0.64,1);
}
.card-3d:active {
  transform: scale(0.97);
  transition: transform 0.12s ease;
}

/* ===== 通用按压反馈 ===== */
.tap-3d:active {
  transform: scale(0.94);
  transition: transform 0.1s cubic-bezier(0.22,1,0.36,1);
}
