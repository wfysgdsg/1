/* 基础样式 */

/* 页面背景 */
page {
  background-color: #f5f5f5;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
}

/* 容器样式 */
.container {
  padding: 20rpx;
  min-height: 100vh;
}

/* 按钮样式 */
.btn-group {
  display: flex;
  gap: 20rpx;
  margin-top: 40rpx;
  padding: 0 20rpx;
}

.submit-btn {
  flex: 1;
  background-color: #1890ff;
  color: #fff;
  border-radius: 8rpx;
  padding: 24rpx;
  font-size: 28rpx;
  font-weight: bold;
  text-align: center;
}

.cancel-btn {
  flex: 1;
  background-color: #f0f0f0;
  color: #333;
  border-radius: 8rpx;
  padding: 24rpx;
  font-size: 28rpx;
  text-align: center;
}

/* 输入框样式 */
.input {
  width: 100%;
  padding: 20rpx;
  border: 2rpx solid #e8e8e8;
  border-radius: 8rpx;
  font-size: 24rpx;
}

/* 表单样式 */
.form {
  background-color: #fff;
  border-radius: 12rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

/* 错误提示 */
.error-message {
  color: #ff4d4f;
  font-size: 20rpx;
  margin-top: 10rpx;
}

/* 成功提示 */
.success-message {
  color: #52c41a;
  font-size: 20rpx;
  margin-top: 10rpx;
}

/* 加载状态 */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.loading-text {
  margin-top: 20rpx;
  font-size: 24rpx;
  color: #666;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
  color: #999;
}

.empty-text {
  font-size: 24rpx;
}