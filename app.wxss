/* ========================================================
   现代化设计系统 v7 —— 3D + 非线性动画增强版
   在 v6 基础上新增：3D 透视体系 / Spring 物理动画 / 深度阴影
   ======================================================== */
page {
  --ink:    #14152A;
  --ink-2:  #5A5C70;
  --ink-3:  #9A9CB0;
  --line:   #EEF0F6;
  --bg:     #F4F5FA;
  --card:   #FFFFFF;
  --field:  #F3F5FB;
  --r-l: 30rpx; --r-m: 22rpx; --r-s: 14rpx; --pill: 999rpx;
  --sh-s: 0 4rpx 18rpx rgba(20,21,42,.05);
  --sh-m: 0 10rpx 30rpx rgba(20,21,42,.07);
  --bg-card: #FFFFFF;
  --text-disabled: #9A9CB0;
  --radius-lg: 30rpx; --radius-sm: 14rpx;
  --shadow-sm: 0 4rpx 18rpx rgba(20,21,42,.05);
  --font-md: 26rpx; --font-lg: 32rpx;

  /* ===== 新增：3D 透视变量 ===== */
  --perspective-near: 600rpx;
  --perspective-mid: 1000rpx;
  --perspective-far: 1600rpx;

  /* ===== 新增：Spring 物理曲线 ===== */
  --spring: cubic-bezier(0.34, 1.56, 0.64, 1);
  --spring-soft: cubic-bezier(0.25, 0.46, 0.45, 0.94);
  --spring-bounce: cubic-bezier(0.68, -0.55, 0.27, 1.55);
  --ease-out-back: cubic-bezier(0.175, 0.885, 0.32, 1.275);
  --ease-in-out-quart: cubic-bezier(0.77, 0, 0.175, 1);

  /* ===== 新增：深度阴影体系 ===== */
  --sh-3d-1: 0 2rpx 8rpx rgba(20,21,42,.06), 0 1rpx 3rpx rgba(20,21,42,.04);
  --sh-3d-2: 0 8rpx 24rpx rgba(20,21,42,.08), 0 4rpx 12rpx rgba(20,21,42,.05);
  --sh-3d-3: 0 20rpx 50rpx rgba(20,21,42,.10), 0 8rpx 20rpx rgba(20,21,42,.06);
  --sh-3d-float: 0 30rpx 70rpx rgba(20,21,42,.12), 0 12rpx 30rpx rgba(20,21,42,.08);
  --sh-glow-primary: 0 8rpx 30rpx rgba(79,110,247,.25), 0 0 60rpx rgba(79,110,247,.08);

  background: var(--bg);
  color: var(--ink);
}

/* ========================================
   3D 透视容器 — 页面级 3D 空间
   ======================================== */
.scene-3d {
  perspective: var(--perspective-mid);
  perspective-origin: center center;
}

.scene-3d-near {
  perspective: var(--perspective-near);
  perspective-origin: center top;
}

.preserve-3d {
  transform-style: preserve-3d;
}

/* ========================================
   非线性动画关键帧系统
   ======================================== */

/* Spring 入场：弹跳上浮 */
@keyframes springInUp {
  0% {
    opacity: 0;
    transform: translateY(48rpx) scale(0.92);
  }
  60% {
    opacity: 1;
    transform: translateY(-8rpx) scale(1.02);
  }
  80% {
    transform: translateY(4rpx) scale(0.99);
  }
  100% {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
}

/* Spring 入场：弹跳缩放 */
@keyframes springInScale {
  0% {
    opacity: 0;
    transform: scale(0.3) rotateZ(-8deg);
  }
  50% {
    opacity: 1;
    transform: scale(1.08) rotateZ(2deg);
  }
  70% {
    transform: scale(0.95) rotateZ(-1deg);
  }
  100% {
    opacity: 1;
    transform: scale(1) rotateZ(0);
  }
}

/* 3D 翻转入场：从背面翻入 */
@keyframes flipIn3D {
  0% {
    opacity: 0;
    transform: perspective(1000rpx) rotateX(-80deg) translateZ(60rpx);
  }
  60% {
    opacity: 1;
    transform: perspective(1000rpx) rotateX(8deg) translateZ(0);
  }
  100% {
    opacity: 1;
    transform: perspective(1000rpx) rotateX(0) translateZ(0);
  }
}

/* 3D 侧翻入场：从侧面翻入 */
@keyframes flipInY3D {
  0% {
    opacity: 0;
    transform: perspective(1000rpx) rotateY(-70deg) translateZ(60rpx);
  }
  60% {
    opacity: 1;
    transform: perspective(1000rpx) rotateY(8deg) translateZ(0);
  }
  100% {
    opacity: 1;
    transform: perspective(1000rpx) rotateY(0) translateZ(0);
  }
}

/* 深度滑入：带 Z 轴位移 */
@keyframes slideInDepth {
  0% {
    opacity: 0;
    transform: translateX(-60rpx) translateZ(-80rpx) rotateY(15deg);
  }
  100% {
    opacity: 1;
    transform: translateX(0) translateZ(0) rotateY(0);
  }
}

/* 从右深度滑入 */
@keyframes slideInDepthRight {
  0% {
    opacity: 0;
    transform: translateX(60rpx) translateZ(-80rpx) rotateY(-15deg);
  }
  100% {
    opacity: 1;
    transform: translateX(0) translateZ(0) rotateY(0);
  }
}

/* 弹跳入场 */
@keyframes bounceIn {
  0% {
    opacity: 0;
    transform: scale(0.3);
  }
  50% {
    transform: scale(1.06);
  }
  70% {
    transform: scale(0.96);
  }
  100% {
    opacity: 1;
    transform: scale(1);
  }
}

/* 3D 浮动循环 */
@keyframes float3D {
  0%, 100% {
    transform: translateY(0) translateZ(0) rotateX(0) rotateY(0);
  }
  25% {
    transform: translateY(-12rpx) translateZ(20rpx) rotateX(3deg) rotateY(2deg);
  }
  50% {
    transform: translateY(-6rpx) translateZ(10rpx) rotateX(-2deg) rotateY(-1deg);
  }
  75% {
    transform: translateY(-16rpx) translateZ(15rpx) rotateX(1deg) rotateY(3deg);
  }
}

/* 倾斜摇摆 */
@keyframes tiltSway {
  0%, 100% { transform: rotateZ(-1deg) rotateX(2deg); }
  50% { transform: rotateZ(1deg) rotateX(-2deg); }
}

/* 脉冲发光 */
@keyframes pulseGlow {
  0%, 100% {
    box-shadow: 0 8rpx 28rpx rgba(79, 110, 247, 0.25);
  }
  50% {
    box-shadow: 0 8rpx 50rpx rgba(79, 110, 247, 0.50), 0 0 0 12rpx rgba(79, 110, 247, 0.06);
  }
}

/* 渐变流动 */
@keyframes gradientShift {
  0% { background-position: 0% 50%; }
  50% { background-position: 100% 50%; }
  100% { background-position: 0% 50%; }
}

/* 旋转 */
@keyframes spin360 {
  to { transform: rotate(360deg); }
}

/* 页面入场 */
@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(36rpx); }
  to { opacity: 1; transform: translateY(0); }
}

/* 卡片入场 */
@keyframes fadeInScale {
  from { opacity: 0; transform: scale(0.94); }
  to { opacity: 1; transform: scale(1); }
}

/* 从左滑入 */
@keyframes slideInLeft {
  from { opacity: 0; transform: translateX(-48rpx); }
  to { opacity: 1; transform: translateX(0); }
}

/* 从右滑入 */
@keyframes slideInRight {
  from { opacity: 0; transform: translateX(60rpx); }
  to { opacity: 1; transform: translateX(0); }
}

/* Spinner */
@keyframes spin {
  to { transform: rotate(360deg); }
}

/* 空状态脉冲 */
@keyframes emptyPulse {
  0%, 100% { transform: scale(1); opacity: 0.6; }
  50% { transform: scale(1.08); opacity: 0.85; }
}

/* ========================================
   动画工具类 — Spring 物理曲线
   ======================================== */
.animate-fade-in {
  animation: springInUp 0.6s var(--spring) both;
}

.animate-card {
  animation: springInUp 0.55s var(--spring) both;
}

.animate-bounce {
  animation: bounceIn 0.6s var(--spring-bounce) both;
}

.animate-slide-in {
  animation: slideInRight 0.45s var(--ease-out-back) both;
}

/* 新增 3D 动画工具类 */
.animate-3d-flip {
  animation: flipIn3D 0.7s var(--spring) both;
}

.animate-3d-flip-y {
  animation: flipInY3D 0.7s var(--spring) both;
}

.animate-3d-scale {
  animation: springInScale 0.65s var(--spring) both;
}

.animate-depth-left {
  animation: slideInDepth 0.6s var(--ease-out-back) both;
}

.animate-depth-right {
  animation: slideInDepthRight 0.6s var(--ease-out-back) both;
}

.animate-float-3d {
  animation: float3D 6s ease-in-out infinite;
}

/* ========================================
   通用 Hero 头部 — 3D 增强
   ======================================== */
.x-hero {
  position: relative; overflow: hidden;
  padding: 36rpx 32rpx 56rpx;
  border-radius: 0 0 40rpx 40rpx;
  color: #fff;
  transform-style: preserve-3d;
}
.x-hero-orb {
  position: absolute; border-radius: 50%;
  background: rgba(255,255,255,.16);
  pointer-events: none;
}
.x-hero-orb.a { width: 240rpx; height: 240rpx; top: -90rpx; right: -60rpx; }
.x-hero-orb.b { width: 160rpx; height: 160rpx; bottom: -70rpx; left: 30rpx; background: rgba(255,255,255,.10); }
.x-hero-back  { position: relative; z-index: 1; font-size: 28rpx; opacity: .92; }
.x-hero-title { position: relative; z-index: 1; display: block; font-size: 44rpx; font-weight: 800; letter-spacing: -.5px; margin-top: 6rpx; }
.x-hero-sub   { position: relative; z-index: 1; display: block; font-size: 24rpx; opacity: .85; margin-top: 8rpx; }

/* 玻璃底栏 */
.x-glass-bar {
  position: fixed; left: 0; right: 0; bottom: 0; z-index: 100;
  display: flex; gap: 18rpx;
  padding: 18rpx 28rpx calc(28rpx + env(safe-area-inset-bottom));
  background: linear-gradient(180deg, rgba(244,245,250,0) 0%, rgba(244,245,250,.92) 38%, #fff 100%);
  backdrop-filter: blur(20rpx);
}

/* 按下反馈 — Spring 弹性 */
.x-tap:active {
  transform: scale(.95) translateZ(20rpx);
  opacity: .92;
  transition: transform 0.15s var(--spring), opacity 0.15s ease;
}

/* ========================================
   设计 Token — 统一配色体系
   ======================================== */
page {
  background-color: #F5F6FA;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
  color: #1A1A1A;
}

/* ========================================
   3D 卡片触摸反馈 — 通用
   ======================================== */
.tilt-card {
  transition: transform 0.2s var(--spring), box-shadow 0.2s ease;
  transform-style: preserve-3d;
}
.tilt-card:active {
  transform: scale(0.96) translateZ(30rpx);
}

/* ========================================
   通用按压反馈 — Spring 弹性
   ======================================== */
.goods-item:active,
.receivable-card:active,
.action-card:active,
.mini-action:active,
.grid-item:active,
.menu-item:active {
  transform: scale(0.96);
  opacity: 0.88;
  transition: transform 0.15s var(--spring), opacity 0.15s ease;
}

/* ========================================
   Loading Spinner — 3D
   ======================================== */
.loading-spinner {
  width: 56rpx; height: 56rpx;
  border: 4rpx solid #e8e8e8;
  border-top-color: #4F6EF7;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin: 0 auto;
}

/* ========================================
   FAB 呼吸脉冲 — 增强发光
   ======================================== */
.add-btn {
  animation: pulseGlow 2.5s ease-in-out infinite;
  transition: transform 0.2s var(--spring);
}
.add-btn:active {
  transform: scale(0.92) translateZ(40rpx);
}

/* ========================================
   搜索框 — Spring 聚焦
   ======================================== */
.search-bar {
  transition: box-shadow 0.3s var(--spring), border-color 0.3s ease, transform 0.3s var(--spring);
}
.search-bar.focused {
  box-shadow: 0 0 0 3rpx rgba(79, 110, 247, 0.15), 0 8rpx 30rpx rgba(0, 0, 0, 0.08);
  transform: translateY(-2rpx);
}
.search-input {
  transition: color 0.3s ease;
}

/* 空状态脉冲 */
.empty-icon {
  font-size: 96rpx;
  margin-bottom: 24rpx;
  animation: emptyPulse 2.4s ease-in-out infinite;
}

/* 容器 */
.container {
  padding: 28rpx;
  min-height: 100vh;
}

/* ========================================
   二级/三级页面通用样式
   ======================================== */
.page-header {
  padding: 20rpx 8rpx 16rpx;
}
.page-title {
  font-size: 38rpx;
  font-weight: 700;
  color: #1a1a2e;
}
.page-subtitle {
  font-size: 24rpx;
  color: #8c8c8c;
  margin-top: 4rpx;
}
.section-card {
  background: #fff;
  border-radius: 24rpx;
  box-shadow: 0 2rpx 16rpx rgba(0,0,0,0.04);
  padding: 28rpx 24rpx;
  margin-bottom: 20rpx;
  border-left: 5rpx solid #4F6EF7;
  transition: box-shadow 0.2s ease, transform 0.2s var(--spring);
}
.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1a1a2e;
  margin-bottom: 16rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

/* 输入框统一美化 */
input, textarea {
  background: #f8f9fc;
  border: 1rpx solid #e8ecf2;
  border-radius: 14rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  transition: border-color 0.2s ease, background 0.2s ease;
}
input:focus, textarea:focus {
  border-color: #4F6EF7;
  background: #fff;
}

/* 主要操作按钮 — Spring + 3D */
.btn-primary-full {
  width: 100%;
  background: linear-gradient(135deg, #4F6EF7, #3D56D4);
  background-size: 200% 200%;
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 44rpx;
  padding: 24rpx 0;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(79,110,247,0.3);
  transition: transform 0.2s var(--spring), box-shadow 0.2s ease;
}
.btn-primary-full:active {
  transform: scale(0.96) translateZ(30rpx);
  box-shadow: 0 4rpx 12rpx rgba(79,110,247,0.2);
}

/* 按钮 */
.btn-group {
  display: flex;
  gap: 20rpx;
  margin-top: 40rpx;
  padding: 0 20rpx;
}

.submit-btn {
  flex: 1;
  background: linear-gradient(135deg, #4F6EF7, #6C5CE7);
  background-size: 200% 200%;
  color: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  font-size: 28rpx;
  font-weight: 600;
  text-align: center;
  box-shadow: 0 8rpx 24rpx rgba(79,110,247,0.25);
  transition: transform 0.2s var(--spring);
}

.cancel-btn {
  flex: 1;
  background-color: #F5F5F5;
  color: #595959;
  border-radius: 16rpx;
  padding: 24rpx;
  font-size: 28rpx;
  text-align: center;
}

/* 输入框 */
.input {
  width: 100%;
  padding: 20rpx;
  border: 2rpx solid #E8E8E8;
  border-radius: 12rpx;
  font-size: 24rpx;
  background: #fff;
}

/* 表单卡片 */
.form {
  background-color: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
}

/* 错误提示 */
.error-message {
  color: #FF4D4F;
  font-size: 20rpx;
  margin-top: 10rpx;
}

/* 成功提示 */
.success-message {
  color: #52C41A;
  font-size: 20rpx;
  margin-top: 10rpx;
}

/* 加载状态 */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.loading-text {
  margin-top: 20rpx;
  font-size: 24rpx;
  color: #8C8C8C;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
  color: #BFBFBF;
}

.empty-text {
  font-size: 26rpx;
  color: #8C8C8C;
}

/* 通用分页栏 */
.pagination {
  display: flex; align-items: center; justify-content: center; gap: 12rpx;
  padding: 12rpx 16rpx; margin: 16rpx 0;
  background: var(--bg-card,#fff); border-radius: 40rpx;
}
.page-btn {
  background: var(--field,#F3F5FB); border: none; border-radius: 30rpx;
  color: var(--ink-2,#5A5C70); font-size: 24rpx; padding: 14rpx 28rpx;
  line-height: 1.2; transition: all 0.2s var(--spring);
}
.page-btn:active { background: var(--ink-3,#9A9CB0); color: #fff; transform: scale(0.95); }
.page-btn[disabled] { opacity: .35; }

.page-info {
  color: #999;
  font-size: 22rpx;
  margin: 0 12rpx;
}

/* 通用浮动添加按钮 — 3D 浮动 */
.fab-btn {
  position: fixed;
  bottom: 40rpx;
  left: 10%;
  width: 80%;
  height: 96rpx;
  background: linear-gradient(135deg, #4F6EF7, #6C5CE7);
  background-size: 200% 200%;
  border-radius: 48rpx;
  box-shadow: 0 12rpx 40rpx rgba(79,110,247,0.35);
  color: #fff;
  font-size: 32rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: transform 0.2s var(--spring), box-shadow 0.2s ease;
}

.fab-btn:active {
  transform: scale(0.96) translateZ(30rpx);
  box-shadow: 0 8rpx 24rpx rgba(79,110,247,0.45);
}

/* 通用搜索栏 */
.search-bar {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 20rpx;
  padding: 16rpx 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04);
}

.search-box {
  display: flex;
  align-items: center;
  flex: 1;
  background: #F5F6FA;
  border-radius: 16rpx;
  min-height: 68rpx;
  padding: 0 20rpx;
}

.search-icon {
  color: #BFBFBF;
  font-size: 24rpx;
  margin-right: 10rpx;
}

.search-input {
  flex: 1;
  color: #1A1A1A;
  font-size: 26rpx;
}
