/* ============================================================
   NEXUS-3D Design System v1.0
   前卫 3D + 非线性动画 + 玻璃拟态
   ============================================================ */

page {
  /* ===== 深空色彩体系 ===== */
  --void:      #060818;
  --void-2:    #0B0E24;
  --surface:   #121530;
  --surface-2: #1A1E3F;
  --surface-3: #232854;

  /* ===== 玻璃材质 ===== */
  --glass:        rgba(255,255,255,0.045);
  --glass-2:      rgba(255,255,255,0.075);
  --glass-border: rgba(255,255,255,0.10);
  --glass-border-bright: rgba(255,255,255,0.18);

  /* ===== 霓虹色系 ===== */
  --neon-violet: #7B61FF;
  --neon-blue:   #00D4FF;
  --neon-coral:  #FF6B6B;
  --neon-mint:   #00F5A0;
  --neon-amber:  #FFB800;
  --neon-pink:   #FF4FA3;

  /* ===== 渐变 ===== */
  --grad-primary: linear-gradient(135deg, #7B61FF 0%, #00D4FF 100%);
  --grad-coral:   linear-gradient(135deg, #FF6B6B 0%, #FF4FA3 100%);
  --grad-mint:    linear-gradient(135deg, #00F5A0 0%, #00D4FF 100%);
  --grad-amber:   linear-gradient(135deg, #FFB800 0%, #FF6B6B 100%);
  --grad-dark:    linear-gradient(160deg, #121530 0%, #060818 100%);

  /* ===== 文字 ===== */
  --text-primary:   #F0F2FF;
  --text-secondary: rgba(240,242,255,0.62);
  --text-tertiary:  rgba(240,242,255,0.35);

  /* ===== 非线性动画曲线 ===== */
  --ease-spring:  cubic-bezier(0.34, 1.56, 0.64, 1);
  --ease-elastic: cubic-bezier(0.68, -0.55, 0.265, 1.55);
  --ease-expo:    cubic-bezier(0.16, 1, 0.3, 1);
  --ease-back:    cubic-bezier(0.68, -0.6, 0.32, 1.6);
  --ease-smooth:  cubic-bezier(0.25, 0.46, 0.45, 0.94);
  --ease-snappy:  cubic-bezier(0.22, 1, 0.36, 1);

  /* ===== 3D 透视 ===== */
  --perspective: 1200rpx;
  --perspective-near: 800rpx;

  /* ===== 圆角 ===== */
  --r-xl: 40rpx;
  --r-lg: 28rpx;
  --r-md: 20rpx;
  --r-sm: 12rpx;
  --pill: 999rpx;

  /* ===== 阴影 ===== */
  --sh-glow-violet: 0 0 40rpx rgba(123,97,255,0.25);
  --sh-glow-blue:   0 0 40rpx rgba(0,212,255,0.22);
  --sh-glow-coral:  0 0 40rpx rgba(255,107,107,0.22);
  --sh-deep:         0 20rpx 60rpx rgba(0,0,0,0.4);
  --sh-card:         0 8rpx 32rpx rgba(0,0,0,0.25);

  background: var(--void);
  color: var(--text-primary);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
}

/* ============================================================
   3D 透视容器
   ============================================================ */
.scene-3d {
  perspective: var(--perspective);
  perspective-origin: center top;
}
.scene-3d-near {
  perspective: var(--perspective-near);
}

/* ============================================================
   玻璃材质基础类
   ============================================================ */
.glass {
  background: var(--glass);
  backdrop-filter: blur(24rpx);
  -webkit-backdrop-filter: blur(24rpx);
  border: 1rpx solid var(--glass-border);
  border-radius: var(--r-lg);
}
.glass-bright {
  background: var(--glass-2);
  backdrop-filter: blur(32rpx);
  -webkit-backdrop-filter: blur(32rpx);
  border: 1rpx solid var(--glass-border-bright);
  border-radius: var(--r-lg);
}

/* ============================================================
   非线性动画关键帧
   ============================================================ */

/* 3D 翻转入场 */
@keyframes nexus-enter-3d {
  0% {
    opacity: 0;
    transform: perspective(1200rpx) rotateX(-25deg) translateY(60rpx) translateZ(-80rpx) scale(0.9);
  }
  100% {
    opacity: 1;
    transform: perspective(1200rpx) rotateX(0) translateY(0) translateZ(0) scale(1);
  }
}

/* 弹性上浮 */
@keyframes nexus-spring-up {
  0% {
    opacity: 0;
    transform: translateY(50rpx) scale(0.85);
  }
  60% {
    opacity: 1;
    transform: translateY(-8rpx) scale(1.03);
  }
  80% {
    transform: translateY(4rpx) scale(0.99);
  }
  100% {
    transform: translateY(0) scale(1);
  }
}

/* 3D 侧入 */
@keyframes nexus-slide-3d-left {
  0% {
    opacity: 0;
    transform: perspective(1000rpx) rotateY(35deg) translateX(-80rpx) translateZ(-40rpx);
  }
  100% {
    opacity: 1;
    transform: perspective(1000rpx) rotateY(0) translateX(0) translateZ(0);
  }
}

/* 3D 侧入右 */
@keyframes nexus-slide-3d-right {
  0% {
    opacity: 0;
    transform: perspective(1000rpx) rotateY(-35deg) translateX(80rpx) translateZ(-40rpx);
  }
  100% {
    opacity: 1;
    transform: perspective(1000rpx) rotateY(0) translateX(0) translateZ(0);
  }
}

/* 弹性缩放入场 */
@keyframes nexus-pop {
  0% {
    opacity: 0;
    transform: scale(0.3) rotate(-8deg);
  }
  50% {
    opacity: 1;
    transform: scale(1.08) rotate(3deg);
  }
  70% {
    transform: scale(0.96) rotate(-1deg);
  }
  100% {
    transform: scale(1) rotate(0);
  }
}

/* 深度浮现 */
@keyframes nexus-depth-in {
  0% {
    opacity: 0;
    transform: translateZ(-120rpx) scale(0.8);
  }
  100% {
    opacity: 1;
    transform: translateZ(0) scale(1);
  }
}

/* 浮动光晕 */
@keyframes nexus-float {
  0%, 100% {
    transform: translateY(0) scale(1) rotate(0deg);
  }
  33% {
    transform: translateY(-30rpx) scale(1.06) rotate(8deg);
  }
  66% {
    transform: translateY(-15rpx) scale(0.96) rotate(-5deg);
  }
}

/* 脉冲辉光 */
@keyframes nexus-pulse-glow {
  0%, 100% {
    box-shadow: 0 0 20rpx rgba(123,97,255,0.3), 0 0 40rpx rgba(123,97,255,0.1);
  }
  50% {
    box-shadow: 0 0 30rpx rgba(123,97,255,0.5), 0 0 80rpx rgba(123,97,255,0.2);
  }
}

/* 旋转边框 */
@keyframes nexus-spin {
  to { transform: rotate(360deg); }
}

/* 3D 翻转 */
@keyframes nexus-flip-y {
  0% { transform: rotateY(0); }
  100% { transform: rotateY(180deg); }
}

/* 非线性摇摆 */
@keyframes nexus-sway {
  0%, 100% { transform: rotateZ(-2deg); }
  50% { transform: rotateZ(2deg); }
}

/* 闪亮扫光 */
@keyframes nexus-shine {
  0% { transform: translateX(-150%) skewX(-25deg); }
  100% { transform: translateX(250%) skewX(-25deg); }
}

/* 呼吸缩放 */
@keyframes nexus-breathe {
  0%, 100% { transform: scale(1); opacity: 0.6; }
  50% { transform: scale(1.12); opacity: 0.9; }
}

/* 数据条增长 */
@keyframes nexus-bar-grow {
  0% { transform: scaleX(0); }
  100% { transform: scaleX(1); }
}

/* ============================================================
   动画工具类
   ============================================================ */
.anim-enter-3d {
  animation: nexus-enter-3d 0.7s var(--ease-expo) both;
}
.anim-spring {
  animation: nexus-spring-up 0.65s var(--ease-spring) both;
}
.anim-slide-left {
  animation: nexus-slide-3d-left 0.6s var(--ease-expo) both;
}
.anim-slide-right {
  animation: nexus-slide-3d-right 0.6s var(--ease-expo) both;
}
.anim-pop {
  animation: nexus-pop 0.6s var(--ease-spring) both;
}
.anim-depth {
  animation: nexus-depth-in 0.7s var(--ease-expo) both;
}
.anim-float {
  animation: nexus-float 8s ease-in-out infinite;
}

/* ============================================================
   3D 卡片悬浮效果
   ============================================================ */
.card-3d {
  transform-style: preserve-3d;
  transition: transform 0.4s var(--ease-spring), box-shadow 0.4s var(--ease-spring);
}
.card-3d:active {
  transform: perspective(800rpx) rotateX(2deg) scale(0.97);
  transition: transform 0.12s ease;
}

/* ============================================================
   通用按压反馈（非线性）
   ============================================================ */
.tap-3d:active {
  transform: scale(0.94) translateZ(20rpx);
  transition: transform 0.1s var(--ease-snappy);
}

/* ============================================================
   霓虹文字
   ============================================================ */
.neon-text-violet {
  color: var(--neon-violet);
  text-shadow: 0 0 12rpx rgba(123,97,255,0.5);
}
.neon-text-blue {
  color: var(--neon-blue);
  text-shadow: 0 0 12rpx rgba(0,212,255,0.5);
}
.neon-text-mint {
  color: var(--neon-mint);
  text-shadow: 0 0 12rpx rgba(0,245,160,0.5);
}
.neon-text-coral {
  color: var(--neon-coral);
  text-shadow: 0 0 12rpx rgba(255,107,107,0.5);
}

/* ============================================================
   霓虹按钮
   ============================================================ */
.btn-neon {
  position: relative;
  overflow: hidden;
  background: var(--grad-primary);
  color: #fff;
  border-radius: var(--pill);
  padding: 26rpx 0;
  font-size: 30rpx;
  font-weight: 600;
  text-align: center;
  border: none;
  box-shadow: 0 8rpx 32rpx rgba(123,97,255,0.35);
  transition: transform 0.2s var(--ease-spring), box-shadow 0.2s var(--ease-spring);
}
.btn-neon:active {
  transform: scale(0.96);
  box-shadow: 0 4rpx 16rpx rgba(123,97,255,0.3);
}
.btn-neon::after {
  content: '';
  position: absolute;
  top: 0; left: 0;
  width: 60%; height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.3), transparent);
  transform: translateX(-150%) skewX(-25deg);
  pointer-events: none;
}
.btn-neon:active::after {
  animation: nexus-shine 0.6s ease;
}

/* ============================================================
   背景光晕粒子
   ============================================================ */
.bg-orb {
  position: absolute;
  border-radius: 50%;
  filter: blur(80rpx);
  pointer-events: none;
  z-index: 0;
}

/* ============================================================
   通用容器
   ============================================================ */
.container {
  position: relative;
  min-height: 100vh;
  z-index: 1;
}

/* ============================================================
   加载动画
   ============================================================ */
.loading-spinner {
  width: 56rpx;
  height: 56rpx;
  border: 4rpx solid rgba(255,255,255,0.1);
  border-top-color: var(--neon-violet);
  border-right-color: var(--neon-blue);
  border-radius: 50%;
  animation: nexus-spin 0.8s linear infinite;
  margin: 0 auto;
}

/* ============================================================
   分页栏（3D 风格）
   ============================================================ */
.pagination {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 12rpx 16rpx;
  margin: 16rpx 0;
  background: var(--glass);
  backdrop-filter: blur(20rpx);
  border: 1rpx solid var(--glass-border);
  border-radius: var(--pill);
}
.page-btn {
  background: var(--glass-2);
  border: 1rpx solid var(--glass-border);
  border-radius: var(--pill);
  color: var(--text-primary);
  font-size: 24rpx;
  padding: 14rpx 28rpx;
  line-height: 1.2;
  transition: all 0.2s var(--ease-spring);
}
.page-btn:active {
  background: var(--grad-primary);
  color: #fff;
  transform: scale(0.95);
}
.page-btn[disabled] {
  opacity: 0.3;
}
.page-info {
  color: var(--text-tertiary);
  font-size: 22rpx;
  margin: 0 12rpx;
}

/* ============================================================
   搜索栏（玻璃拟态）
   ============================================================ */
.search-bar {
  display: flex;
  align-items: center;
  background: var(--glass);
  backdrop-filter: blur(20rpx);
  border: 1rpx solid var(--glass-border);
  border-radius: var(--pill);
  padding: 16rpx 24rpx;
  margin-bottom: 20rpx;
  transition: all 0.3s var(--ease-expo);
}
.search-bar.focused {
  border-color: var(--neon-violet);
  box-shadow: 0 0 0 3rpx rgba(123,97,255,0.15), var(--sh-glow-violet);
}
.search-input {
  transition: color 0.3s ease;
}

/* ============================================================
   空状态
   ============================================================ */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}
.empty-icon {
  font-size: 96rpx;
  margin-bottom: 24rpx;
  animation: nexus-breathe 3s ease-in-out infinite;
}
.empty-text {
  font-size: 26rpx;
  color: var(--text-tertiary);
}

/* ============================================================
   输入框统一美化
   ============================================================ */
input, textarea {
  background: var(--glass);
  border: 1rpx solid var(--glass-border);
  border-radius: var(--r-md);
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  color: var(--text-primary);
  transition: all 0.25s var(--ease-expo);
}
input:focus, textarea:focus {
  border-color: var(--neon-violet);
  background: var(--glass-2);
  box-shadow: 0 0 0 3rpx rgba(123,97,255,0.12);
}
