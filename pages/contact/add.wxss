.container {
  background-color: #f5f5f5;
  min-height: 100vh;
  padding: 20px;
}
.form-group {
  background-color: #fff;
  border-radius: 12px;
  margin-bottom: 30px;
  padding: 0 15px;
}
.form-item {
  align-items: center;
  border-bottom: 1px solid #f0f0f0;
  display: -webkit-flex;
  display: flex;
  padding: 15px 0;
}
.form-item:last-child {
  border-bottom: none;
}
.form-item.align-top {
  align-items: flex-start;
}
.label {
  color: #333;
  font-size: 14px;
  width: 80px;
}
.form-item input,
.form-item textarea {
  flex: 1;
  font-size: 14px;
}
.form-item textarea {
  height: 80px;
}
.radio-group,
.radio-label {
  display: -webkit-flex;
  display: flex;
}
.radio-label {
  align-items: center;
  font-size: 14px;
  margin-right: 20px;
}
.btn-group {
  display: -webkit-flex;
  display: flex;
  flex-direction: column;
}
.btn-submit {
  background-color: #1890ff;
  border-radius: 8px;
  color: #fff;
  margin-bottom: 15px;
  width: 100% !important;
}
.btn-cancel {
  background-color: #fff;
  border: 1px solid #d9d9d9;
  border-radius: 8px;
  color: #666;
  width: 100% !important;
}
