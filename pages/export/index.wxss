page { --grad: linear-gradient(135deg,#5B6CF7,#7C5CFF); --accent:#5B6CF7; background: var(--bg); }
.page { min-height: 100vh; padding-bottom: 60rpx; }

.hero { background: var(--grad); }

.body { padding: 28rpx; margin-top: -32rpx; position: relative; z-index: 2; }

.card {
  background: var(--card);
  border-radius: var(--r-l);
  padding: 28rpx;
  margin-bottom: 22rpx;
  box-shadow: var(--sh-s);
}
.card-h { display:flex; align-items:center; font-size:28rpx; font-weight:700; color:var(--ink); margin-bottom:24rpx; }
.dot { width:8rpx; height:30rpx; border-radius:4rpx; background:var(--grad); margin-right:14rpx; }

.field { margin-bottom: 26rpx; }
.field:last-child { margin-bottom: 0; }
.lab { display:block; font-size:26rpx; color:var(--ink-2); font-weight:600; margin-bottom:14rpx; }

.picker {
  display:flex;
  align-items:center;
  box-sizing:border-box;
  min-height:88rpx;
  padding:0 26rpx;
  background:var(--field);
  border:2rpx solid transparent;
  border-radius:var(--r-m);
}
.pick-val { flex:1; font-size:30rpx; color:var(--ink); }
.pick-val.ph { color: var(--ink-3); }
.pick-tag { font-size:26rpx; color:var(--ink-2); margin-right:10rpx; }
.pick-arrow { font-size:24rpx; color:var(--ink-3); margin-left:12rpx; }

.range { display:flex; align-items:center; gap:14rpx; }
.range-item { flex:1; }
.range-sep { color:var(--ink-3); font-size:28rpx; }

.btn-group { display:flex; gap:20rpx; margin-top:34rpx; }
.btn { border:none; border-radius:var(--pill); font-size:30rpx; font-weight:600; height:92rpx; line-height:92rpx; padding:0; }
.btn::after { border:none; }
.btn.ghost { flex:1; background:#EEF0F6; color:var(--ink-2); }
.btn.main  { flex:1.4; background:var(--grad); color:#fff; box-shadow:0 12rpx 30rpx rgba(91,108,247,.36); }
.btn.main[disabled] { background:#A9B4F7; color:rgba(255,255,255,.8); box-shadow:none; }

.preview-card { padding-bottom: 20rpx; }
.preview-table { width:100%; max-height:640rpx; }
.preview-inner { display:inline-block; min-width:100%; }
.preview-header {
  display:flex;
  background:var(--field);
  border-radius:var(--r-s);
  padding:16rpx 10rpx;
}
.header-cell { min-width:150rpx; flex:1; font-size:22rpx; font-weight:700; color:var(--ink); text-align:center; white-space:nowrap; }
.preview-row { display:flex; padding:18rpx 10rpx; border-bottom:1rpx solid var(--line); }
.preview-row:last-child { border-bottom:none; }
.row-cell { min-width:150rpx; flex:1; font-size:22rpx; color:var(--ink-2); text-align:center; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
