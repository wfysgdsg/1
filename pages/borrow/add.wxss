page { --grad: linear-gradient(135deg,#5B6CF7,#7C5CFF); --accent:#5B6CF7; }
.page { min-height: 100vh; padding-bottom: 220rpx; }
.hero { background: var(--grad); }
.body { padding: 28rpx; margin-top: -32rpx; position: relative; z-index: 2; }

/* 卡片 */
.card { background: var(--card); border-radius: var(--r-l); padding: 28rpx; margin-bottom: 22rpx; box-shadow: var(--sh-s); }
.card-h { display:flex; align-items:center; font-size:28rpx; font-weight:700; color:var(--ink); margin-bottom:22rpx; }
.dot { width:8rpx; height:30rpx; border-radius:4rpx; background:var(--grad); margin-right:14rpx; }
.req { color:#FF4D4F; margin-left:6rpx; }

/* 通用字段 */
.field { padding-bottom: 4rpx; }
.field + .field { padding-top: 24rpx; }
.lab { display:block; font-size:26rpx; color:var(--ink-2); font-weight:600; margin-bottom:14rpx; }
.inp { width:100%; box-sizing:border-box; height:88rpx; padding:0 26rpx; background:var(--field); border:2rpx solid transparent; border-radius:var(--r-m); font-size:30rpx; color:var(--ink); }
.inp:focus { border-color: var(--accent); background:#fff; }

/* 商品搜索 */
.goods-select { position: relative; }
.input-wrapper { position: relative; }
.clear-search { position:absolute; right:20rpx; top:50%; transform:translateY(-50%); width:40rpx; height:40rpx; display:flex; align-items:center; justify-content:center; background:var(--ink-3); color:#fff; border-radius:50%; font-size:28rpx; z-index:10; }

.search-result { position:absolute; left:0; right:0; top:100rpx; background:#fff; border-radius:var(--r-m); box-shadow:var(--sh-m); z-index:100; overflow:hidden; max-height:560rpx; overflow-y:auto; }
.empty-result { padding:40rpx; text-align:center; color:var(--ink-3); font-size:26rpx; }
.result-item { display:flex; align-items:center; gap:18rpx; padding:24rpx 26rpx; border-bottom:1rpx solid var(--line); }
.result-item:last-child { border-bottom:none; }
.check-box { flex-shrink:0; width:40rpx; height:40rpx; display:flex; align-items:center; justify-content:center; border:2rpx solid #D9DCE6; border-radius:10rpx; transition:.2s; }
.check-box.checked { background:var(--accent); border-color:var(--accent); }
.check-mark { color:#fff; font-size:24rpx; font-weight:700; }
.result-info { flex:1; display:flex; justify-content:space-between; align-items:center; }
.result-name { font-size:28rpx; color:var(--ink); }
.result-price { color:var(--accent); font-size:24rpx; font-weight:600; }

.batch-bar { display:flex; align-items:center; justify-content:space-between; padding:18rpx 26rpx; background:#EEF1FE; }
.batch-count { color:var(--accent); font-size:26rpx; font-weight:600; }
.batch-add-btn { background:var(--grad); border:none; border-radius:var(--pill); color:#fff; font-size:24rpx; padding:12rpx 30rpx; line-height:1.4; }
.batch-add-btn::after { border:none; }

.add-quick-link { display:inline-flex; align-items:center; color:var(--accent); font-size:26rpx; font-weight:600; margin-top:18rpx; padding:6rpx 0; }

/* 已选商品 */
.selected-goods { margin-top:22rpx; display:flex; flex-direction:column; gap:18rpx; }
.goods-item { background:var(--field); border-radius:var(--r-m); padding:24rpx; }
.goods-header { display:flex; align-items:center; justify-content:space-between; margin-bottom:18rpx; }
.goods-name { flex:1; font-size:28rpx; font-weight:700; color:var(--ink); }
.remove-btn { width:44rpx; height:44rpx; display:flex; align-items:center; justify-content:center; background:#FFF1F0; color:#FF4D4F; border-radius:50%; font-size:32rpx; }
.goods-body { display:flex; flex-wrap:wrap; gap:16rpx; margin-bottom:14rpx; }
.price-row { display:flex; align-items:center; gap:10rpx; }
.price-label { color:var(--ink-2); font-size:24rpx; }
.price-input, .quantity-input { width:150rpx; height:64rpx; box-sizing:border-box; padding:0 16rpx; background:#fff; border:2rpx solid var(--line); border-radius:var(--r-s); font-size:26rpx; color:var(--ink); }
.quantity-input { width:130rpx; background:#FFFBE6; border-color:#FFE58F; }
.price-input:focus, .quantity-input:focus { border-color:var(--accent); }
.goods-footer { padding-top:8rpx; }
.goods-unit { color:var(--ink-3); font-size:24rpx; }

/* 客户搜索 */
.location-search { position:relative; }
.contact-results { position:absolute; left:0; right:0; top:100rpx; background:#fff; border-radius:var(--r-m); box-shadow:var(--sh-m); max-height:500rpx; overflow-y:auto; z-index:100; }
.contact-item { display:flex; flex-direction:column; justify-content:center; padding:26rpx; border-bottom:1rpx solid var(--line); }
.contact-item:last-child { border-bottom:none; }
.contact-item:active { background:#EEF1FE; }
.contact-name { font-size:28rpx; color:var(--ink); }
.result-detail { color:var(--ink-3); font-size:22rpx; margin-top:8rpx; }

.selected-location { display:flex; align-items:center; justify-content:space-between; margin-top:18rpx; padding:22rpx 24rpx; background:#EEF1FE; border-radius:var(--r-m); }
.selected-text { color:var(--accent); font-size:28rpx; font-weight:600; }
.clear-btn { color:#FF4D4F; font-size:36rpx; padding:0 10rpx; }

/* 日期 picker */
.picker { display:flex; align-items:center; justify-content:space-between; height:88rpx; padding:0 26rpx; background:var(--field); border-radius:var(--r-m); font-size:30rpx; color:var(--ink); }
.picker-arrow { color:var(--ink-3); font-size:36rpx; }

/* 备注 */
.textarea { width:100%; box-sizing:border-box; height:160rpx; padding:22rpx 26rpx; background:var(--field); border-radius:var(--r-m); font-size:28rpx; color:var(--ink); }

.stock-tip { margin-top:22rpx; padding:18rpx 22rpx; background:#FFFBE6; border-radius:var(--r-s); color:#FA8C16; font-size:23rpx; line-height:1.5; }

/* 底部玻璃栏按钮 */
.btn { border:none; border-radius:var(--pill); font-size:30rpx; font-weight:600; height:92rpx; line-height:92rpx; }
.btn::after { border:none; }
.btn.ghost { flex:1; background:#EEF0F6; color:var(--ink-2); }
.btn.main  { flex:2; background:var(--grad); color:#fff; box-shadow:0 12rpx 30rpx rgba(91,108,247,.36); }
.btn.main[disabled] { opacity:.6; }
