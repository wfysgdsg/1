page {
  background-color: #f7f8fa;
}
.header-banner {
  background: linear-gradient(135deg, #722ed1, #b37feb);
  color: #fff;
  display: -webkit-flex;
  display: flex;
  flex-direction: column;
  padding: 40rpx;
}
.title {
  font-size: 40rpx;
  font-weight: 700;
}
.subtitle {
  font-size: 24rpx;
  margin-top: 10rpx;
  opacity: 0.8;
}
.request-list {
  padding: 30rpx 40rpx;
}
.request-card {
  background-color: #fff;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
  margin-bottom: 30rpx;
  padding: 30rpx;
}
.card-header {
  align-items: flex-start;
  border-bottom: 1rpx solid #f5f5f5;
  justify-content: space-between;
  margin-bottom: 24rpx;
  padding-bottom: 16rpx;
}
.card-header,
.sender-info {
  display: -webkit-flex;
  display: flex;
}
.sender-info {
  flex-direction: column;
}
.sender-name {
  color: #262626;
  font-size: 32rpx;
  font-weight: 700;
}
.request-time {
  color: #bfbfbf;
  font-size: 22rpx;
  margin-top: 6rpx;
}
.status-tag {
  background: #f9f0ff;
  border-radius: 20rpx;
  color: #722ed1;
  font-size: 22rpx;
  padding: 4rpx 16rpx;
}
.customer-info {
  color: #8c8c8c;
  font-size: 26rpx;
  margin-bottom: 20rpx;
}
.goods-list {
  background: #fafafa;
  border-radius: 12rpx;
  margin-bottom: 30rpx;
  padding: 20rpx;
}
.goods-item {
  display: -webkit-flex;
  display: flex;
  justify-content: space-between;
  margin-bottom: 10rpx;
}
.goods-item:last-child {
  margin-bottom: 0;
}
.goods-name {
  color: #595959;
  font-size: 28rpx;
}
.goods-qty {
  color: #722ed1;
  font-size: 28rpx;
  font-weight: 700;
}
.card-footer {
  justify-content: flex-end;
}
.action-btn,
.card-footer {
  display: -webkit-flex;
  display: flex;
}
.action-btn {
  align-items: center;
  border-radius: 32rpx;
  font-size: 26rpx;
  height: 64rpx;
  justify-content: center;
  margin-left: 20rpx;
  padding: 0 30rpx;
}
.reject {
  background: #fff;
  border: 1rpx solid #d9d9d9;
  color: #595959;
}
.accept {
  background: #722ed1;
  color: #fff;
}
.empty {
  align-items: center;
  display: -webkit-flex;
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding-top: 100rpx;
}
.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
  opacity: 0.3;
}
.empty text:last-child {
  color: #bfbfbf;
  font-size: 28rpx;
}
