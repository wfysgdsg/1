<view class="container">
    <view class="tabs">
        <view class="tab-indicator {{tab==='stock'?'right':''}}"></view>
        <view bindtap="switchTab" class="tab {{tab==='detail'?'active':''}} tap-3d" data-tab="detail">{{uiText.detailTab}}</view>
        <view bindtap="switchTab" class="tab {{tab==='stock'?'active':''}} tap-3d" data-tab="stock">{{uiText.stockTab}}</view>
    </view>

    <!-- 搜索栏 -->
    <view class="search-bar">
        <view class="search-box">
            <text class="search-icon">🔍</text>
            <input bindinput="onSearchInput" class="search-input" placeholder="{{tab==='detail'?uiText.searchBorrow:uiText.searchStock}}" value="{{searchKeyword}}"></input>
        </view>
        <picker wx:if="{{tab==='detail'}}" bindchange="onSortChange" mode="selector" range="{{[uiText.sortCount, uiText.sortTime]}}" value="{{sortBy==='count'?0:1}}">
            <view class="sort-btn">{{sortBy==='count'?uiText.sortCount:uiText.sortTime}}</view>
        </picker>
        <picker wx:if="{{tab==='stock'}}" bindchange="onStockSortChange" mode="selector" range="{{[uiText.stockSortTime, uiText.stockSortName, uiText.stockSortQty]}}" value="{{stockSortBy==='time'?0:(stockSortBy==='name'?1:2)}}">
            <view class="sort-btn">{{stockSortBy==='time'?uiText.stockSortTime:(stockSortBy==='name'?uiText.stockSortName:uiText.stockSortQty)}}</view>
        </picker>
    </view>

    <view class="borrow-list" wx:if="{{tab==='detail'}}">
        <!-- 列表最上面的分页 -->
        <view class="pagination" wx:if="{{totalCount > 0}}">
            <button bindtap="prevPage" class="page-btn tap-3d" disabled="{{currentPage === 1}}">上一页</button>
            <text class="page-info">{{currentPage}} / {{totalPages}} 共 {{totalCount}} 条</text>
            <button bindtap="nextPage" class="page-btn tap-3d" disabled="{{currentPage >= totalPages}}">下一页</button>
        </view>

        <view bindtap="goToDetail" class="customer-card {{_anim ? 'anim-spring' : ''}} tap-3d" data-id="{{item.customerId}}" data-name="{{item.customerName}}" wx:for="{{customerGroups}}" wx:key="groupKey" style="animation-delay: {{index * 0.08 < 0.4 ? index * 0.08 : 0.4}}s">
            <view class="card-header">
                <view class="customer-info">
                    <text class="customer-name">{{item.customerName}}</text>
                    <text class="last-date">{{uiText.latestBorrow}}: {{item.lastBorrowDate}}</text>
                </view>
                <view class="badge-count">{{item.totalItems}}</view>
            </view>
            <view class="card-body">
                <view class="goods-summary-row" wx:for="{{item.displayGoods}}" wx:for-item="goods" wx:key="name">
                    <text class="goods-name-dot">{{goods.name}}</text>
                    <text class="goods-qty">x{{goods.qty}}{{goods.unit}}</text>
                </view>
                <view class="more-tip" wx:if="{{item.totalItems>3}}">{{uiText.viewAll}} ({{item.totalItems}})</view>
            </view>
            <view class="card-footer">
                <text class="tap-detail-btn">{{uiText.manageHint}}</text>
            </view>
        </view>
        <view class="empty" wx:if="{{!customerGroups||customerGroups.length===0}}">
            <text class="empty-icon">📭</text>
            <text>{{uiText.noBorrow}}</text>
        </view>
        <!-- 底部固定分页 -->
        <view class="pagination" wx:if="{{totalCount > 0 && tab==='detail'}}">
            <button bindtap="prevPage" class="page-btn tap-3d" disabled="{{currentPage === 1}}">上一页</button>
            <text class="page-info">{{currentPage}} / {{totalPages}} 共 {{totalCount}} 条</text>
            <button bindtap="nextPage" class="page-btn tap-3d" disabled="{{currentPage >= totalPages}}">下一页</button>
        </view>
    </view>
    <view class="stock-list" wx:if="{{tab==='stock'}}">
        <!-- 库存列表最上面的分页 -->
        <view class="pagination" wx:if="{{stockTotalCount > 0}}">
            <button bindtap="prevStockPage" class="page-btn tap-3d" disabled="{{stockPage === 1}}">上一页</button>
            <text class="page-info">{{stockPage}} / {{stockTotalPages}} 共 {{stockTotalCount}} 条</text>
            <button bindtap="nextStockPage" class="page-btn tap-3d" disabled="{{stockPage >= stockTotalPages}}">下一页</button>
        </view>

        <view class="stock-item {{_anim ? 'anim-spring' : ''}}" wx:for="{{stockList}}" wx:key="_id" style="animation-delay: {{index * 0.04}}s">
            <view class="stock-info">
                <text class="goods-name">{{item.goodsName}}</text>
                <text class="stock-num">{{uiText.availableStock}}: {{item.stock}} {{item.unit||''}}</text>
            </view>
            <view class="stock-time">{{uiText.lastChange}}: {{item.lastSaleDate||uiText.noSaleRecord}}</view>
        </view>
        <view class="empty" wx:if="{{!stockList||stockList.length===0}}">
            <text class="empty-icon">📭</text>
            <text>{{uiText.noStock}}</text>
        </view>
        
        <!-- 库存列表最下面的分页 -->
        <view class="pagination" wx:if="{{stockTotalCount > 0}}">
            <button bindtap="prevStockPage" class="page-btn tap-3d" disabled="{{stockPage === 1}}">上一页</button>
            <text class="page-info">{{stockPage}} / {{stockTotalPages}} 共 {{stockTotalCount}} 条</text>
            <button bindtap="nextStockPage" class="page-btn tap-3d" disabled="{{stockPage >= stockTotalPages}}">下一页</button>
        </view>
    </view>
    <view bindtap="goToAdd" class="add-btn tap-3d">
        <text>+</text>
        <text>{{uiText.addBorrow}}</text>
    </view>
</view>
