page {
  background: linear-gradient(180deg, #FFF3E8 0%, #f7f8fa 180rpx, #f5f5f5 100%);
}
.container {
  padding-bottom: 40rpx;
  min-height: 100vh;
}
.tabs {
  background: #f0f2ff;
  border-radius: 20rpx;
  display: -webkit-flex;
  display: flex;
  margin: 16rpx 0 24rpx;
  padding: 6rpx;
  position: relative;
  z-index: 100;
}

.tab-indicator {
  position: absolute;
  top: 6rpx;
  left: 6rpx;
  width: calc(50% - 6rpx);
  height: calc(100% - 12rpx);
  background: #fff;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(79, 110, 247, 0.15);
  transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}
.tab-indicator.right {
  transform: translateX(100%);
}

.tab {
  color: #8c8c8c;
  flex: 1;
  font-size: 28rpx;
  padding: 20rpx 0;
  position: relative;
  text-align: center;
  z-index: 1;
  transition: color 0.25s ease;
}
.tab.active {
  color: #4F6EF7;
  font-weight: 600;
}
.search-bar {
  align-items: center;
  background: #fff;
  display: -webkit-flex;
  display: flex;
  gap: 12rpx;
  padding: 16rpx 30rpx;
}
.search-box {
  align-items: center;
  background: #f5f7fa;
  border-radius: 16rpx;
  display: -webkit-flex;
  display: flex;
  flex: 1;
  min-height: 68rpx;
  padding: 0 20rpx;
}
.search-icon {
  color: #bfbfbf;
  font-size: 24rpx;
  margin-right: 10rpx;
}
.search-input {
  color: #333; flex: 1; font-size: 26rpx;
  background: transparent; border: none; padding: 0; border-radius: 0;
}
.sort-btn {
  align-items: center;
  background: #f5f7fa;
  border-radius: 16rpx;
  color: #4F6EF7;
  display: -webkit-flex;
  display: flex;
  font-size: 24rpx;
  min-height: 68rpx;
  padding: 0 20rpx;
  white-space: nowrap;
}
.borrow-list {
  padding: 30rpx 40rpx;
}
.customer-card {
  background-color: #fff;
  border-radius: 24rpx;
  border-left: 6rpx solid #FF9C6E;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.03), 0 8rpx 32rpx rgba(255, 156, 110, 0.04);
  margin-bottom: 24rpx;
  padding: 30rpx;
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}
.customer-card:active {
  transform: scale(0.985);
  box-shadow: 0 1rpx 8rpx rgba(0, 0, 0, 0.03);
}
.card-header {
  align-items: flex-start;
  border-bottom: 1rpx solid #f5f5f5;
  justify-content: space-between;
  margin-bottom: 24rpx;
  padding-bottom: 16rpx;
}
.card-header,
.customer-info {
  display: -webkit-flex;
  display: flex;
}
.customer-info {
  flex-direction: column;
}
.customer-name {
  color: #262626;
  font-size: 36rpx;
  font-weight: 700;
}
.last-date {
  color: #bfbfbf;
  font-size: 24rpx;
  margin-top: 6rpx;
}
.badge-count {
  background-color: #EEF1FE;
  border-radius: 20rpx;
  color: #4F6EF7;
  font-size: 24rpx;
  font-weight: 500;
  padding: 4rpx 16rpx;
}
.card-body {
  margin-bottom: 24rpx;
}
.goods-summary-row {
  align-items: center;
  display: -webkit-flex;
  display: flex;
  justify-content: space-between;
  margin-bottom: 12rpx;
}
.goods-name-dot {
  color: #595959;
  font-size: 28rpx;
}
.goods-qty {
  color: #4F6EF7;
  font-size: 28rpx;
  font-weight: 500;
}
.more-tip {
  color: #bfbfbf;
  font-size: 22rpx;
  font-style: italic;
  margin-top: 10rpx;
}
.card-footer {
  text-align: right;
}
.tap-detail-btn {
  color: #4F6EF7;
  font-size: 24rpx;
}
.stock-list {
  padding: 30rpx 40rpx;
}
.stock-item {
  background-color: #fff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  padding: 24rpx;
}
.stock-info {
  align-items: center;
  display: -webkit-flex;
  display: flex;
  justify-content: space-between;
}
.goods-name {
  color: #262626;
  font-size: 32rpx;
  font-weight: 700;
}
.stock-num {
  color: #52c41a;
  font-size: 28rpx;
  font-weight: 700;
}
.stock-time {
  color: #bfbfbf;
  font-size: 22rpx;
  margin-top: 10rpx;
  text-align: right;
}
.empty {
  align-items: center;
  display: -webkit-flex;
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding-top: 100rpx;
}
.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
  opacity: 0.3;
}
.empty text:last-child {
  color: #bfbfbf;
  font-size: 28rpx;
}
.add-btn {
  align-items: center;
  animation: bounceIn 0.6s cubic-bezier(0.68, -0.55, 0.27, 1.55) 0.35s both, fabPulse 2.5s ease-in-out 1s infinite;
  background: linear-gradient(135deg, #4F6EF7, #3D56D4);
  border-radius: 50rpx;
  bottom: 180rpx;
  box-shadow: 0 8rpx 30rpx rgba(79, 110, 247, 0.40);
  color: #fff;
  display: -webkit-flex;
  display: flex;
  height: 100rpx;
  justify-content: center;
  padding: 0 40rpx;
  position: fixed;
  right: 40rpx;
  z-index: 1000;
}
.add-btn text:first-child {
  font-size: 44rpx;
  margin-right: 10rpx;
}
.add-btn text:last-child {
  font-size: 30rpx;
  font-weight: 700;
}
