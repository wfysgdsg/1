<wxs module="utils">
function includes(arr, item) {
  if (!arr) return false;
  for (var i = 0; i < arr.length; i++) {
    if (arr[i] === item) return true;
  }
  return false;
}
module.exports = { includes: includes };
</wxs>

<view class="page">
  <!-- 顶部渐变大头 -->
  <view class="x-hero hero anim-enter-3d">
    <view class="x-hero-orb a"></view>
    <view class="x-hero-orb b"></view>
    <view class="hero-row">
      <view class="hero-main">
        <text class="x-hero-title">{{customerName}}</text>
        <text class="x-hero-sub">共 {{rawRecords.length}} 条借货记录</text>
      </view>
      <view bindtap="toggleBatchMode" class="batch-switch x-tap">
        <text>{{isBatchMode?'取消选择':'批量操作'}}</text>
      </view>
    </view>
  </view>

  <!-- 内容区 -->
  <view class="body">
    <view>
      <!-- 子 Tab -->
      <view class="sub-tabs">
        <view bindtap="switchTab" class="sub-tab {{tab==='time'?'active':''}}" data-tab="time">按时间</view>
        <view bindtap="switchTab" class="sub-tab {{tab==='goods'?'active':''}}" data-tab="goods">按商品</view>
      </view>

      <view class="selection-tip" wx:if="{{isBatchMode}}">已选 {{selectedIds.length}} 项</view>

      <!-- 按时间 -->
      <view class="records-list" wx:if="{{tab==='time'}}">
        <view class="time-group" wx:for="{{timeGroups}}" wx:key="date">
          <view class="date-group-card">
            <view class="date-header"><view class="date-dot"></view>{{item.date}}</view>
            <view bindtap="{{isBatchMode?'onItemSelect':''}}" class="record-card {{utils.includes(selectedIds,r._id)?'selected':''}}" data-id="{{r._id}}" wx:for="{{item.items}}" wx:for-item="r" wx:key="_id">
              <view class="record-check" wx:if="{{isBatchMode}}">
                <view class="checkbox {{utils.includes(selectedIds,r._id)?'checked':''}}">
                  <text class="checkmark" wx:if="{{utils.includes(selectedIds,r._id)}}">✓</text>
                </view>
              </view>
              <view class="record-body">
                <view class="record-header">
                  <text class="goods-name">{{r.goodsName}}</text>
                  <text class="goods-qty">x{{r.quantity}}{{r.unit}}</text>
                </view>
                <view class="record-footer">
                  <text class="price-info">成本 ¥{{r.costPrice}} · 售价 ¥{{r.salePrice||0}}</text>
                </view>
                <text class="remark-text" wx:if="{{r.remark}}">备注：{{r.remark}}</text>
              </view>
            </view>
          </view>
        </view>
      </view>

      <!-- 按商品 -->
      <view class="records-list" wx:if="{{tab==='goods'}}">
        <view class="goods-summary-card" wx:for="{{goodsGroups}}" wx:key="goodsId">
          <view class="summary-header">
            <text class="sum-name">{{item.goodsName}}</text>
            <text class="sum-qty">总计 {{item.totalQty}} {{item.unit}}</text>
          </view>
          <view class="detail-items">
            <block wx:for="{{item.items}}" wx:for-item="r" wx:key="_id">
              <view bindtap="{{isBatchMode?'onItemSelect':''}}" class="record-card {{utils.includes(selectedIds,r._id)?'selected':''}}" data-id="{{r._id}}">
                <view class="record-check" wx:if="{{isBatchMode}}">
                  <view class="checkbox {{utils.includes(selectedIds,r._id)?'checked':''}}">
                    <text class="checkmark" wx:if="{{utils.includes(selectedIds,r._id)}}">✓</text>
                  </view>
                </view>
                <view class="record-body">
                  <view class="record-header">
                    <text class="goods-name">{{r.borrowDate}}</text>
                    <text class="goods-qty">×{{r.quantity}}{{r.unit}}</text>
                  </view>
                  <view class="record-footer">
                    <text class="price-info">成本 ¥{{r.costPrice}} · 售价 ¥{{r.salePrice||0}}</text>
                  </view>
                  <text class="remark-text" wx:if="{{r.remark}}">备注：{{r.remark}}</text>
                </view>
              </view>
            </block>
          </view>
        </view>
      </view>

      <!-- 空状态 -->
      <view class="empty-state" wx:if="{{!rawRecords||rawRecords.length===0}}">
        <view class="empty-icon">✓</view>
        <text class="empty-text">该客户所有借货均已结清</text>
      </view>
    </view>
  </view>

  <!-- 批量工具栏（position:fixed，必须在动画容器外） -->
  <view class="batch-toolbar" wx:if="{{isBatchMode}}">
    <view bindtap="selectAll" class="toolbar-info">
      <view class="checkbox {{selectedIds.length===rawRecords.length&&rawRecords.length>0?'checked':''}}">
        <text class="checkmark" wx:if="{{selectedIds.length===rawRecords.length&&rawRecords.length>0}}">✓</text>
      </view>
      <text>全选（已选 {{selectedIds.length}}）</text>
    </view>
    <view class="toolbar-btns">
      <view bindtap="batchReturn" class="tool-btn return-btn x-tap">归还</view>
      <view bindtap="batchTransfer" class="tool-btn move-btn x-tap">移货</view>
      <view bindtap="batchSale" class="tool-btn sale-btn x-tap">去开票</view>
    </view>
  </view>

  <!-- 弹窗（position:fixed，必须在动画容器外） -->
  <view bindtap="closeStaffPicker" class="modal-mask" wx:if="{{showStaffPicker}}"></view>
  <view class="staff-picker-modal" wx:if="{{showStaffPicker}}">
    <view class="modal-title">移货详情</view>
    <view class="modal-body">
      <view class="transfer-goods-list">
        <view class="transfer-goods-row" wx:for="{{transferItems}}" wx:key="_id">
          <view class="transfer-goods-info">
            <text class="transfer-goods-name">{{item.goodsName}}</text>
            <text class="transfer-goods-max">最多 {{item.maxQty}} {{item.unit}}</text>
          </view>
          <view class="transfer-qty-stepper">
            <view bindtap="onTransferQtyMinus" data-index="{{index}}" class="stepper-btn minus">-</view>
            <text class="stepper-val">{{item.transferQty}}</text>
            <view bindtap="onTransferQtyPlus" data-index="{{index}}" class="stepper-btn plus">+</view>
          </view>
        </view>
      </view>
      <view class="transfer-staff-label">接收员工</view>
      <picker-view bindchange="onStaffChange" class="staff-picker-view" indicatorStyle="height: 50px;" style="width:100%;height:200rpx;" value="{{[selectedStaffIndex]}}">
        <picker-view-column>
          <view style="line-height:50px;text-align:center;" wx:for="{{staffList}}" wx:key="_id">{{item.name}}</view>
        </picker-view-column>
      </picker-view>
    </view>
    <view class="modal-footer">
      <view bindtap="closeStaffPicker" class="modal-btn cancel x-tap">取消</view>
      <view bindtap="confirmTransfer" class="modal-btn confirm x-tap">确定发送</view>
    </view>
  </view>
</view>
