<view class="page scene-3d {{_anim ? 'anim-enter-3d' : ''}}">
  <!-- 3D 深空头部 -->
  <view class="hero">
    <view class="hero-bg"></view>
    <view class="hero-orb a"></view>
    <view class="hero-orb b"></view>
    <view class="hero-top">
      <text class="hero-title">商品库</text>
      <text class="hero-sub">共 {{totalCount}} 件商品 · 借货 / 开票快速调用</text>
    </view>

    <!-- 玻璃搜索框 -->
    <view class="search glass">
      <text class="search-ico">🔍</text>
      <input class="search-inp" bindinput="onSearch" placeholder="搜索商品名称" placeholder-class="search-ph"/>
      <view class="search-glow"></view>
    </view>
  </view>

  <!-- 列表内容 -->
  <view class="body">
    <view class="list" wx:if="{{goodsList.length}}">
      <view class="g-card card-3d {{_anim ? 'anim-spring' : ''}}" wx:for="{{goodsList}}" wx:key="_id" style="animation-delay: {{index * 0.06 < 0.36 ? index * 0.06 : 0.36}}s">
        <view class="g-card-glow"></view>
        <view class="g-main">
          <view class="g-header">
            <text class="g-name">{{item.name}}</text>
            <view class="g-stock-pill {{(item.stock||0) > 0 ? 'in-stock' : 'out-stock'}}">
              <view class="stock-dot"></view>
              <text>{{item.stock||0}}{{item.unit||''}}</text>
            </view>
          </view>
          <view class="g-tags">
            <view class="g-tag cost">
              <text class="tag-label">成本</text>
              <text class="tag-val">¥{{item.costPrice}}</text>
            </view>
            <view class="g-tag price">
              <text class="tag-label">售价</text>
              <text class="tag-val">¥{{item.salePrice}}</text>
            </view>
          </view>
        </view>
        <view class="g-acts" wx:if="{{isAdmin}}">
          <text bindtap="editGoods" class="g-btn edit tap-3d" data-id="{{item._id}}">编辑</text>
          <text bindtap="deleteGoods" class="g-btn del tap-3d" data-id="{{item._id}}">删除</text>
        </view>
      </view>
    </view>

    <!-- 空状态 -->
    <view class="empty" wx:else>
      <view class="empty-state">
        <text class="empty-icon">📦</text>
        <text class="empty-text">暂无商品</text>
        <text class="empty-tip">点击下方按钮，新增第一件商品</text>
      </view>
    </view>

    <!-- 分页 -->
    <view class="pager" wx:if="{{totalPages > 1}}">
      <button bindtap="prevPage" class="pg-btn" disabled="{{currentPage === 1}}">上一页</button>
      <text class="pg-info">{{currentPage}} / {{totalPages}}</text>
      <button bindtap="nextPage" class="pg-btn" disabled="{{currentPage === totalPages}}">下一页</button>
    </view>
  </view>

  <!-- 悬浮新增按钮 -->
  <view bindtap="goToAdd" class="fab">
    <view class="fab-glow"></view>
    <text class="fab-text">+ 新增商品</text>
  </view>
</view>
