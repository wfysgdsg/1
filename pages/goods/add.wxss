.container {
  background-color: #f5f5f5;
  min-height: 100vh;
  padding: 30rpx;
}
.form {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
}
.form-item {
  margin-bottom: 30rpx;
}
.label {
  color: #333;
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  margin-bottom: 12rpx;
}
.input {
  height: 80rpx;
  padding: 0 20rpx;
}
.input,
.textarea {
  background: #f7f7f7;
  border-radius: 8rpx;
  font-size: 28rpx;
}
.textarea {
  box-sizing: border-box;
  height: 160rpx;
  padding: 20rpx;
  width: 100%;
}
.btn-group {
  display: -webkit-flex;
  display: flex;
  gap: 20rpx;
  margin-top: 40rpx;
  padding: 0 30rpx;
}
.cancel-btn,
.submit-btn {
  align-items: center;
  border-radius: 44rpx;
  display: -webkit-flex;
  display: flex;
  flex: 1;
  font-size: 30rpx;
  height: 88rpx;
  justify-content: center;
}
.cancel-btn {
  background: #f5f5f5;
  color: #666;
}
.submit-btn {
  background: #1890ff;
  color: #fff;
}
