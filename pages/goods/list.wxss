/* 商品库列表 — 3D + Spring 动画增强版 */
page {
  background: #f5f6fa;
}

/* ========================================
   3D 渐变 Hero
   ======================================== */
.hero {
  background: linear-gradient(160deg, #4F6EF7, #6C5CE7);
  background-size: 200% 200%;
  border-bottom-left-radius: 44rpx;
  border-bottom-right-radius: 44rpx;
  height: 320rpx;
  overflow: hidden;
  position: relative;
  animation: gradientShift 8s ease infinite;
}

/* 3D 浮动光球 */
.hero-orb {
  position: absolute;
  border-radius: 50%;
  filter: blur(35rpx);
}
.hero-orb.a {
  width: 280rpx; height: 280rpx;
  background: rgba(255,255,255,0.1);
  top: -80rpx; right: -60rpx;
  animation: orbFloatA 7s ease-in-out infinite;
}
.hero-orb.b {
  width: 200rpx; height: 200rpx;
  background: rgba(139,124,247,0.2);
  bottom: 20rpx; left: -50rpx;
  animation: orbFloatB 9s ease-in-out infinite;
}
@keyframes orbFloatA {
  0%, 100% { transform: translate3d(0,0,0) scale(1); }
  50% { transform: translate3d(-20rpx,15rpx,20rpx) scale(1.1); }
}
@keyframes orbFloatB {
  0%, 100% { transform: translate3d(0,0,0) scale(1); }
  50% { transform: translate3d(25rpx,-10rpx,15rpx) scale(1.08); }
}

/* 网格纹理 */
.hero-mesh {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background-image:
    linear-gradient(rgba(255,255,255,.04) 1px, transparent 1px),
    linear-gradient(90deg, rgba(255,255,255,.04) 1px, transparent 1px);
  background-size: 80rpx 80rpx;
  opacity: 0.5;
}

.hero-top {
  padding: 48rpx 40rpx 0;
  position: relative;
  z-index: 2;
}
.hero-title {
  color: #fff;
  display: block;
  font-size: 44rpx;
  font-weight: 700;
  text-shadow: 0 2rpx 12rpx rgba(0,0,0,0.1);
}
.hero-sub {
  color: hsla(0,0%,100%,0.8);
  display: block;
  font-size: 24rpx;
  margin-top: 8rpx;
}

/* 搜索框 — 3D 悬浮 */
.search {
  align-items: center;
  background: #fff;
  border-radius: 22rpx;
  bottom: -36rpx;
  box-shadow: 0 12rpx 30rpx rgba(0,0,0,0.08), 0 4rpx 10rpx rgba(0,0,0,0.04);
  display: flex;
  height: 84rpx;
  left: 40rpx;
  padding: 0 24rpx;
  position: absolute;
  right: 40rpx;
  transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1), box-shadow 0.3s ease;
  z-index: 10;
}
.search:focus-within {
  transform: translateY(-4rpx) translateZ(20rpx);
  box-shadow: 0 16rpx 40rpx rgba(79,110,247,0.12), 0 6rpx 14rpx rgba(0,0,0,0.06);
}
.search-ico {
  font-size: 28rpx;
  margin-right: 14rpx;
}
.search-inp {
  color: #262626;
  flex: 1;
  font-size: 28rpx;
}
.search-ph {
  color: #BFBFBF;
}

/* ========================================
   列表内容区
   ======================================== */
.body {
  padding: 60rpx 32rpx 200rpx;
}

/* 商品卡片 — 3D 倾斜 + Spring 入场 */
.g-card {
  background: #fff;
  border-radius: 24rpx;
  box-shadow: 0 10rpx 28rpx rgba(0,0,0,0.045), 0 4rpx 10rpx rgba(0,0,0,0.02);
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
  padding: 28rpx 24rpx;
  transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1), box-shadow 0.3s ease;
  transform-style: preserve-3d;
}
.g-card:active {
  transform: scale(0.97) translateZ(30rpx);
  box-shadow: 0 6rpx 18rpx rgba(0,0,0,0.03), 0 2rpx 6rpx rgba(0,0,0,0.01);
}

.g-main {
  flex: 1;
  padding-right: 20rpx;
}
.g-name {
  color: #1a1a1a;
  display: block;
  font-size: 30rpx;
  font-weight: 600;
}
.g-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 14rpx;
}
.g-tag {
  background: #F3F5FB;
  border-radius: 12rpx;
  color: #8c8c8c;
  font-size: 24rpx;
  padding: 4rpx 14rpx;
}
.g-tag.price {
  background: #EEF1FE;
  color: #4F6EF7;
  font-weight: 600;
}
.g-tag.stock {
  background: #f6ffed;
  color: #52c41a;
}

/* 操作按钮 — 3D 凸起 */
.g-acts {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}
.g-btn {
  border-radius: 14rpx;
  font-size: 24rpx;
  padding: 8rpx 24rpx;
  text-align: center;
  transition: transform 0.2s cubic-bezier(0.34, 1.56, 0.64, 1);
}
.g-btn.edit {
  background: #EEF1FE;
  color: #4F6EF7;
}
.g-btn.del {
  background: #FFF1F0;
  color: #ff4d4f;
}
.g-btn:active {
  transform: scale(0.9) translateZ(20rpx);
}

/* 空状态 */
.empty {
  align-items: center;
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 120rpx 0;
}
.empty-ico {
  font-size: 80rpx;
  margin-bottom: 24rpx;
  animation: emptyBounce 3s ease-in-out infinite;
}
@keyframes emptyBounce {
  0%, 100% { transform: translateY(0) rotate(0deg); }
  50% { transform: translateY(-10rpx) rotate(-5deg); }
}
.empty-txt {
  color: #8c8c8c;
  font-size: 32rpx;
  font-weight: 500;
}
.empty-tip {
  color: #BFBFBF;
  font-size: 24rpx;
  margin-top: 12rpx;
}

/* 分页 */
.pager {
  align-items: center;
  display: flex;
  justify-content: center;
  margin-top: 40rpx;
  gap: 20rpx;
}
.pg-btn {
  background: #fff;
  border-radius: 14rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.04);
  color: #4F6EF7;
  font-size: 24rpx;
  font-weight: 600;
  line-height: 72rpx;
  height: 72rpx;
  min-width: 140rpx;
  padding: 0 24rpx;
  transition: transform 0.2s cubic-bezier(0.34, 1.56, 0.64, 1);
}
.pg-btn:active {
  transform: scale(0.92) translateZ(20rpx);
}
.pg-btn::after { border: none; }
.pg-btn[disabled] { color: #BFBFBF; opacity: .55; }
.pg-info {
  font-size: 24rpx;
  color: #8c8c8c;
  font-weight: 600;
}

/* ========================================
   悬浮新增按钮 — 3D 浮起
   ======================================== */
.fab {
  position: fixed;
  left: 10%;
  width: 80%;
  bottom: calc(env(safe-area-inset-bottom) + 40rpx);
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #4F6EF7, #6C5CE7);
  background-size: 200% 200%;
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 48rpx;
  box-shadow:
    0 12rpx 40rpx rgba(79,110,247,0.35),
    0 4rpx 12rpx rgba(79,110,247,0.2);
  z-index: 50;
  animation: gradientShift 6s ease infinite, fabFloat 4s ease-in-out infinite;
  transition: transform 0.25s cubic-bezier(0.34, 1.56, 0.64, 1), box-shadow 0.25s ease;
}
.fab:active {
  transform: scale(0.95) translateZ(40rpx);
  box-shadow:
    0 8rpx 24rpx rgba(79,110,247,0.3),
    0 2rpx 8rpx rgba(79,110,247,0.15);
}
@keyframes fabFloat {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-4rpx); }
}

/* 动画 */
@keyframes gradientShift {
  0% { background-position: 0% 50%; }
  50% { background-position: 100% 50%; }
  100% { background-position: 0% 50%; }
}
