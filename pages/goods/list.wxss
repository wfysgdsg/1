page { --grad: linear-gradient(135deg,#4F6EF7,#6C5CE7); --accent:#4F6EF7; background: var(--bg); }

.page { min-height: 100vh; padding-bottom: 200rpx; }

/* ===== 顶部渐变大头 ===== */
.hero {
  position: relative;
  overflow: hidden;
  padding: calc(env(safe-area-inset-top) + 36rpx) 36rpx 64rpx;
  background: var(--grad);
  border-bottom-left-radius: 36rpx;
  border-bottom-right-radius: 36rpx;
}
.hero-orb { position: absolute; border-radius: 50%; }
.hero-orb.a { width: 220rpx; height: 220rpx; top: -70rpx; right: -54rpx; background: rgba(255,255,255,.16); }
.hero-orb.b { width: 150rpx; height: 150rpx; bottom: -36rpx; left: -30rpx; background: rgba(255,255,255,.10); }
.hero-top { position: relative; z-index: 2; }
.hero-title { display: block; font-size: 46rpx; font-weight: 800; color: #fff; letter-spacing: .5rpx; }
.hero-sub { display: block; margin-top: 10rpx; font-size: 24rpx; color: rgba(255,255,255,.82); }

/* 搜索框 */
.search {
  position: relative; z-index: 2;
  display: flex; align-items: center;
  margin-top: 28rpx;
  height: 84rpx; padding: 0 28rpx;
  background: rgba(255,255,255,.97);
  border-radius: var(--pill);
  box-shadow: 0 12rpx 30rpx rgba(31,45,120,.20);
}
.search-ico { font-size: 30rpx; margin-right: 14rpx; }
.search-inp { flex: 1; height: 84rpx; font-size: 28rpx; color: var(--ink); background: transparent; border: none; padding: 0; border-radius: 0; }
.search-ph { color: var(--ink-3); }

/* ===== 内容区 ===== */
.body { padding: 28rpx; }

/* 列表卡片 */
.list { display: flex; flex-direction: column; gap: 20rpx; }
.g-card {
  display: flex; align-items: center; justify-content: space-between;
  background: var(--card); border-radius: var(--r-l);
  padding: 28rpx 26rpx; box-shadow: var(--sh-s);
  transition: background .15s ease;
}
.g-card:active { background: #FAFBFF; }
.g-main { flex: 1; min-width: 0; }
.g-name { display: block; font-size: 32rpx; font-weight: 700; color: var(--ink); }
.g-tags { display: flex; flex-wrap: wrap; gap: 12rpx; margin-top: 16rpx; }
.g-tag {
  font-size: 22rpx; color: var(--ink-2);
  background: var(--field); border-radius: var(--pill);
  padding: 8rpx 18rpx;
}
.g-tag.price { color: var(--accent); background: rgba(79,110,247,.10); font-weight: 600; }
.g-tag.stock { color: #52C41A; background: rgba(82,196,26,.12); }

/* 操作按钮 */
.g-acts { display: flex; flex-direction: column; gap: 14rpx; margin-left: 20rpx; flex-shrink: 0; }
.g-btn {
  font-size: 24rpx; text-align: center; font-weight: 600;
  border-radius: var(--pill); padding: 12rpx 26rpx;
}
.g-btn.edit { color: var(--accent); background: rgba(79,110,247,.10); }
.g-btn.del { color: #FF4D4F; background: rgba(255,77,79,.10); }

/* 空状态 */
.empty { padding: 130rpx 50rpx; text-align: center; }
.empty-ico { display: block; font-size: 110rpx; margin-bottom: 24rpx; opacity: .9; }
.empty-txt { display: block; font-size: 30rpx; color: var(--ink-2); font-weight: 600; }
.empty-tip { display: block; margin-top: 12rpx; font-size: 24rpx; color: var(--ink-3); }

/* 分页 */
.pager { display: flex; align-items: center; justify-content: center; gap: 24rpx; margin-top: 32rpx; }
.pg-btn {
  background: var(--card); border: 2rpx solid var(--line);
  border-radius: var(--pill); color: var(--ink-2);
  font-size: 24rpx; line-height: 1.7; padding: 8rpx 32rpx; margin: 0;
}
.pg-btn::after { border: none; }
.pg-btn[disabled] { color: var(--ink-3); opacity: .55; }
.pg-info { font-size: 24rpx; color: var(--ink-2); font-weight: 600; }

/* 悬浮新增按钮 */
.fab {
  position: fixed; left: 10%; width: 80%;
  bottom: calc(env(safe-area-inset-bottom) + 40rpx);
  height: 96rpx;
  display: flex; align-items: center; justify-content: center;
  background: var(--grad); color: #fff;
  font-size: 32rpx; font-weight: 600;
  border-radius: var(--pill);
  box-shadow: 0 12rpx 40rpx rgba(79,110,247,.40);
  z-index: 50;
}
.fab:active { transform: scale(.97); opacity: .94; }
