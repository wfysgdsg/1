page {
  background: #f5f6fa;
}
.container {
  min-height: 100vh;
  padding: 30rpx 30rpx 150rpx;
}
.search-bar {
  align-items: center;
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
  display: -webkit-flex;
  display: flex;
  margin-bottom: 30rpx;
  padding: 20rpx 30rpx;
}
.search-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
}
.search-input {
  flex: 1;
  font-size: 28rpx;
  height: 60rpx;
}
.goods-list {
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
}
.goods-item {
  align-items: center;
  border-bottom: 1rpx solid #f5f5f5;
  display: -webkit-flex;
  display: flex;
  justify-content: space-between;
  padding: 30rpx;
}
.goods-info {
  flex: 1;
}
.goods-name {
  color: #333;
  display: block;
  font-size: 32rpx;
  font-weight: 500;
}
.goods-tags {
  display: -webkit-flex;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 12rpx;
}
.tag {
  background: #f5f5f5;
  border-radius: 20rpx;
  color: #666;
  font-size: 22rpx;
  padding: 6rpx 16rpx;
}
.tag.stock {
  background: #e6f7ff;
  color: #1890ff;
}
.goods-actions {
  display: -webkit-flex;
  display: flex;
  gap: 16rpx;
}
.action-btn {
  border-radius: 30rpx;
  font-size: 26rpx;
  padding: 12rpx 24rpx;
}
.action-btn.edit {
  background: #f0eeff;
  color: #667eea;
}
.action-btn.delete {
  background: #fff0f0;
  color: #ff6b6b;
}
.empty {
  padding: 100rpx 50rpx;
  text-align: center;
}
.empty-icon {
  display: block;
  font-size: 100rpx;
  margin-bottom: 20rpx;
}
.empty text {
  color: #999;
  font-size: 28rpx;
}
.pagination {
  align-items: center;
  display: flex;
  justify-content: center;
  margin: 30rpx 0 120rpx;
  padding: 0 30rpx;
}
.page-btn {
  background: #fff;
  border: 1rpx solid #dcdcdc;
  border-radius: 8rpx;
  color: #333;
  font-size: 24rpx;
  height: 60rpx !important;
  line-height: 60rpx;
  margin: 0;
  width: 160rpx !important;
  padding: 0;
}
.page-btn[disabled] {
  background: #f5f5f5;
  color: #ccc;
}
.page-info {
  color: #666;
  font-size: 26rpx;
  margin: 0 30rpx;
}
.add-btn {
  align-items: center;
  background: linear-gradient(135deg, #667eea, #764ba2);
  border-radius: 48rpx;
  bottom: 40rpx;
  box-shadow: 0 10rpx 40rpx rgba(102, 126, 234, 0.4);
  color: #fff;
  display: -webkit-flex;
  display: flex;
  font-size: 32rpx;
  font-weight: 500;
  height: 96rpx;
  justify-content: center;
  left: 50%;
  position: fixed;
  transform: translateX(-50%);
  width: 80%;
}
