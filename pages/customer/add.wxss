page {
  background: #f5f6fa;
}
.container {
  min-height: 100vh;
  padding: 30rpx;
}
.form-card {
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
  padding: 40rpx;
}
.form-item {
  margin-bottom: 36rpx;
}
.label {
  color: #333;
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  margin-bottom: 16rpx;
}
.input {
  height: 88rpx;
  padding: 0 24rpx;
}
.input,
.textarea {
  background: #f7f8fa;
  border-radius: 12rpx;
  font-size: 30rpx;
}
.textarea {
  box-sizing: border-box;
  height: 180rpx;
  padding: 24rpx;
  width: 100%;
}
.btn-group {
  display: -webkit-flex;
  display: flex;
  gap: 24rpx;
  margin-top: 50rpx;
}
.cancel-btn,
.submit-btn {
  align-items: center;
  border-radius: 48rpx;
  display: -webkit-flex;
  display: flex;
  flex: 1;
  font-size: 32rpx;
  font-weight: 500;
  height: 96rpx;
  justify-content: center;
}
.cancel-btn {
  background: #f7f8fa;
  color: #666;
}
.submit-btn {
  background: linear-gradient(135deg, #667eea, #764ba2);
  box-shadow: 0 10rpx 30rpx rgba(102, 126, 234, 0.3);
  color: #fff;
}
