page {
  background: #f5f6fa;
}
.container {
  min-height: 100vh;
  padding: 30rpx 30rpx 150rpx;
}
.search-bar {
  align-items: center;
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
  display: -webkit-flex;
  display: flex;
  margin-bottom: 30rpx;
  padding: 20rpx 30rpx;
}
.search-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
}
.search-input {
  flex: 1;
  font-size: 28rpx;
  height: 60rpx;
}
.customer-list {
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
}
.customer-item {
  align-items: center;
  border-bottom: 1rpx solid #f5f5f5;
  display: -webkit-flex;
  display: flex;
  justify-content: space-between;
  padding: 30rpx;
}
.customer-info {
  flex: 1;
}
.customer-name {
  color: #333;
  display: block;
  font-size: 32rpx;
  font-weight: 500;
}
.customer-detail {
  display: -webkit-flex;
  display: flex;
  gap: 20rpx;
  margin-top: 12rpx;
}
.customer-detail text {
  color: #999;
  font-size: 24rpx;
}
.customer-actions {
  display: -webkit-flex;
  display: flex;
  gap: 16rpx;
}
.action-btn {
  border-radius: 30rpx;
  font-size: 26rpx;
  padding: 12rpx 24rpx;
}
.action-btn.edit {
  background: #f0eeff;
  color: #667eea;
}
.action-btn.delete {
  background: #fff0f0;
  color: #ff6b6b;
}
.empty {
  padding: 100rpx 50rpx;
  text-align: center;
}
.empty-icon {
  display: block;
  font-size: 100rpx;
  margin-bottom: 20rpx;
}
.empty text {
  color: #999;
  font-size: 28rpx;
}
.add-btn {
  align-items: center;
  background: linear-gradient(135deg, #667eea, #764ba2);
  border-radius: 48rpx;
  bottom: 40rpx;
  box-shadow: 0 10rpx 40rpx rgba(102, 126, 234, 0.4);
  color: #fff;
  display: -webkit-flex;
  display: flex;
  font-size: 32rpx;
  font-weight: 500;
  height: 96rpx;
  justify-content: center;
  left: 50%;
  position: fixed;
  transform: translateX(-50%);
  width: 80%;
}
