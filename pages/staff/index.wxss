.container {
  background-color: #f5f5f5;
  min-height: 100vh;
  padding: 20rpx;
}
.header {
  align-items: center;
  display: -webkit-flex;
  display: flex;
  justify-content: space-between;
  margin-bottom: 20rpx;
}
.title {
  color: #333;
  font-size: 36rpx;
  font-weight: 700;
}
.add-btn {
  background: #1890ff;
  border-radius: 8rpx;
  color: #fff;
  font-size: 28rpx;
  padding: 12rpx 24rpx;
}
.user-list {
  background: #fff;
  border-radius: 12rpx;
}
.user-item {
  align-items: center;
  border-bottom: 1rpx solid #f0f0f0;
  display: -webkit-flex;
  display: flex;
  justify-content: space-between;
  padding: 24rpx;
}
.user-info {
  flex: 1;
}
.user-name {
  color: #333;
  display: block;
  font-size: 30rpx;
  font-weight: 500;
}
.user-role {
  color: #999;
  display: block;
  font-size: 24rpx;
  margin-top: 8rpx;
}
.user-actions {
  display: -webkit-flex;
  display: flex;
  gap: 20rpx;
}
.action-btn {
  background: #e6f7ff;
  border-radius: 6rpx;
  color: #1890ff;
  font-size: 26rpx;
  padding: 8rpx 16rpx;
}
.action-btn.delete {
  background: #fff2f0;
  color: #ff4d4f;
}
.empty {
  color: #999;
  font-size: 28rpx;
  padding: 100rpx;
  text-align: center;
}
