/* ============================================================
   个人中心 — NEXUS-3D
   ============================================================ */

page {
  background: var(--void);
}

.container {
  min-height: 100vh;
  padding: 30rpx;
  overflow: hidden;
}

/* ===== 背景光晕 ===== */
.bg-orb-a {
  background: linear-gradient(135deg, #7B61FF, #FF4FA3);
  width: 400rpx; height: 400rpx;
  right: -150rpx; top: -100rpx;
  opacity: 0.15;
  animation: nexus-float 12s ease-in-out infinite;
}
.bg-orb-b {
  background: linear-gradient(135deg, #00D4FF, #7B61FF);
  width: 300rpx; height: 300rpx;
  left: -120rpx; bottom: 200rpx;
  opacity: 0.1;
  animation: nexus-float 10s ease-in-out infinite;
  animation-delay: -4s;
}

/* ===== 3D 头像卡片 ===== */
.header-card {
  position: relative;
  overflow: hidden;
  border-radius: var(--r-xl);
  padding: 50rpx 36rpx;
  background: linear-gradient(135deg, rgba(123,97,255,0.12) 0%, rgba(0,212,255,0.06) 100%);
  backdrop-filter: blur(30rpx);
  border: 1rpx solid rgba(255,255,255,0.08);
  box-shadow: 0 20rpx 50rpx rgba(0,0,0,0.3);
  margin-bottom: 24rpx;
  transform-style: preserve-3d;
}
.header-bg-glow {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background:
    radial-gradient(circle at 80% 30%, rgba(123,97,255,0.15), transparent 50%),
    radial-gradient(circle at 20% 70%, rgba(0,212,255,0.08), transparent 40%);
  pointer-events: none;
}
.avatar-section {
  position: relative;
  display: flex;
  align-items: center;
}
.avatar-wrap {
  position: relative;
  width: 130rpx; height: 130rpx;
  margin-right: 28rpx;
  flex-shrink: 0;
}
.avatar, .avatar-img {
  width: 130rpx; height: 130rpx;
  border-radius: 50%;
}
.avatar {
  background: rgba(255,255,255,0.08);
  color: var(--text-primary);
  font-size: 50rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid rgba(255,255,255,0.1);
}
.avatar-img {
  border: 3rpx solid rgba(255,255,255,0.15);
}
.avatar-ring {
  position: absolute;
  top: -6rpx; left: -6rpx; right: -6rpx; bottom: -6rpx;
  border: 2rpx solid transparent;
  border-top-color: var(--neon-violet);
  border-right-color: var(--neon-blue);
  border-radius: 50%;
  animation: nexus-spin 4s linear infinite;
  opacity: 0.5;
}
.avatar-ring-2 {
  position: absolute;
  top: -12rpx; left: -12rpx; right: -12rpx; bottom: -12rpx;
  border: 1rpx solid transparent;
  border-bottom-color: var(--neon-pink);
  border-radius: 50%;
  animation: nexus-spin 6s linear infinite reverse;
  opacity: 0.3;
}
.user-detail {
  flex: 1;
  display: flex;
  flex-direction: column;
}
.username {
  color: var(--text-primary);
  font-size: 38rpx;
  font-weight: 800;
  letter-spacing: 1rpx;
}
.user-bio {
  color: rgba(255,255,255,0.4);
  font-size: 24rpx;
  margin-top: 6rpx;
}
.role-tag {
  display: flex;
  align-items: center;
  gap: 8rpx;
  align-self: flex-start;
  padding: 6rpx 18rpx;
  border-radius: var(--pill);
  margin-top: 14rpx;
  font-size: 20rpx;
}
.role-tag.admin {
  background: rgba(123,97,255,0.12);
  color: var(--neon-violet);
  border: 1rpx solid rgba(123,97,255,0.2);
}
.role-tag.staff {
  background: rgba(0,212,255,0.1);
  color: var(--neon-blue);
  border: 1rpx solid rgba(0,212,255,0.15);
}
.role-dot {
  width: 8rpx; height: 8rpx;
  border-radius: 50%;
  background: currentColor;
  box-shadow: 0 0 6rpx currentColor;
}
.edit-hint-wrap {
  display: flex;
  align-items: center;
}
.edit-hint {
  color: rgba(255,255,255,0.35);
  font-size: 24rpx;
}
.edit-arrow {
  color: rgba(255,255,255,0.2);
  font-size: 32rpx;
  margin-left: 4rpx;
}

/* ===== 菜单卡片 ===== */
.menu-card {
  padding: 8rpx 0;
  margin-bottom: 24rpx;
}
.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 28rpx;
  border-bottom: 1rpx solid rgba(255,255,255,0.04);
}
.menu-item:last-child {
  border-bottom: none;
}
.menu-left {
  display: flex;
  align-items: center;
}
.menu-icon-wrapper {
  position: relative;
  width: 72rpx; height: 72rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 22rpx;
  overflow: hidden;
  border: 1rpx solid rgba(255,255,255,0.04);
}
.menu-icon-glow {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  opacity: 0.15;
}
.menu-icon-glow.violet { background: radial-gradient(circle, var(--neon-violet), transparent); }
.menu-icon-glow.amber  { background: radial-gradient(circle, var(--neon-amber), transparent); }
.menu-icon-glow.mint   { background: radial-gradient(circle, var(--neon-mint), transparent); }
.menu-icon-glow.blue   { background: radial-gradient(circle, var(--neon-blue), transparent); }
.menu-icon-glow.coral  { background: radial-gradient(circle, var(--neon-coral), transparent); }
.violet-bg { background: rgba(123,97,255,0.08); }
.amber-bg  { background: rgba(255,184,0,0.08); }
.mint-bg   { background: rgba(0,245,160,0.08); }
.blue-bg   { background: rgba(0,212,255,0.08); }
.coral-bg  { background: rgba(255,107,107,0.08); }
.neutral-bg{ background: rgba(255,255,255,0.05); }
.menu-icon {
  position: relative;
  z-index: 1;
  font-size: 30rpx;
}
.menu-text {
  color: var(--text-primary);
  font-size: 28rpx;
  font-weight: 500;
}
.arrow {
  color: rgba(255,255,255,0.2);
  font-size: 36rpx;
}

/* ===== 退出按钮 ===== */
.logout-section {
  padding: 0 20rpx;
}
.logout-btn {
  width: 100%;
  background: rgba(255,107,107,0.08);
  border: 1rpx solid rgba(255,107,107,0.15);
  border-radius: var(--r-lg);
  color: var(--neon-coral);
  font-size: 30rpx;
  font-weight: 600;
  padding: 28rpx 0;
  letter-spacing: 2rpx;
}
.logout-btn::after {
  border: none;
}
