<view class="container">
    <view class="header-card tap-3d" class="tap-3d" bindtap="editProfile">
        <view class="avatar-section">
            <image wx:if="{{userInfo.avatarUrl}}" class="avatar-img" src="{{userInfo.avatarUrl}}" mode="aspectFill"></image>
            <view wx:else class="avatar">{{displayName[0]||'?'}}</view>
            <view class="user-detail">
                <text class="username">{{displayName}}</text>
                <text class="user-bio" wx:if="{{userInfo.bio}}">{{userInfo.bio}}</text>
                <text class="role-tag">{{userInfo.role==='root'?uiText.admin:uiText.staff}}</text>
            </view>
            <text class="edit-hint">编辑</text>
        </view>
    </view>
    <view class="menu-card">
        <view bindtap="changePassword" class="menu-item tap-3d">
            <view class="menu-left">
                <view class="menu-icon-wrapper" style="background:#EEF1FE;">
                    <text class="menu-icon">🔑</text>
                </view>
                <text class="menu-text">{{uiText.changePassword}}</text>
            </view>
            <text class="arrow">›</text>
        </view>
        <view bindtap="exportData" class="menu-item tap-3d">
            <view class="menu-left">
                <view class="menu-icon-wrapper" style="background:#FFF7E6;">
                    <text class="menu-icon">📥</text>
                </view>
                <text class="menu-text">{{uiText.exportData}}</text>
            </view>
            <text class="arrow">›</text>
        </view>
        <view bindtap="viewReport" class="menu-item tap-3d">
            <view class="menu-left">
                <view class="menu-icon-wrapper" style="background:#F6FFED;">
                    <text class="menu-icon">📊</text>
                </view>
                <text class="menu-text">{{uiText.report}}</text>
            </view>
            <text class="arrow">›</text>
        </view>
        <view bindtap="viewDeliveryList" class="menu-item tap-3d">
            <view class="menu-left">
                <view class="menu-icon-wrapper" style="background:#F9F0FF;">
                    <text class="menu-icon">📋</text>
                </view>
                <text class="menu-text">送货单记录</text>
            </view>
            <text class="arrow">›</text>
        </view>
        <view bindtap="manageStaff" class="menu-item tap-3d" wx:if="{{isAdmin}}">
            <view class="menu-left">
                <view class="menu-icon-wrapper" style="background:#FFF1F0;">
                    <text class="menu-icon">👥</text>
                </view>
                <text class="menu-text">{{uiText.manageStaff}}</text>
            </view>
            <text class="arrow">›</text>
        </view>
        <view bindtap="about" class="menu-item tap-3d">
            <view class="menu-left">
                <view class="menu-icon-wrapper" style="background:#F5F6FA;">
                    <text class="menu-icon">ℹ️</text>
                </view>
                <text class="menu-text">{{uiText.about}}</text>
            </view>
            <text class="arrow">›</text>
        </view>
    </view>
    <button bindtap="logout" class="logout-btn tap-3d" wx:if="{{isLogged}}">{{uiText.logout}}</button>
</view>
