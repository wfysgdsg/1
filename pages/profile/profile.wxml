<view class="container scene-3d">

  <!-- 背景光晕 -->
  <view class="bg-orb bg-orb-a"></view>
  <view class="bg-orb bg-orb-b"></view>

  <!-- 3D 头像卡片 -->
  <view class="header-card {{_anim ? 'anim-enter-3d' : ''}}" bindtap="editProfile">
    <view class="header-bg-glow"></view>
    <view class="avatar-section">
      <view class="avatar-wrap">
        <image wx:if="{{userInfo.avatarUrl}}" class="avatar-img" src="{{userInfo.avatarUrl}}" mode="aspectFill"></image>
        <view wx:else class="avatar">{{displayName[0]||'?'}}</view>
        <view class="avatar-ring"></view>
        <view class="avatar-ring-2"></view>
      </view>
      <view class="user-detail">
        <text class="username">{{displayName}}</text>
        <text class="user-bio" wx:if="{{userInfo.bio}}">{{userInfo.bio}}</text>
        <view class="role-tag {{userInfo.role==='root'?'admin':'staff'}}">
          <view class="role-dot"></view>
          <text>{{userInfo.role==='root'?uiText.admin:uiText.staff}}</text>
        </view>
      </view>
      <view class="edit-hint-wrap">
        <text class="edit-hint">编辑</text>
        <text class="edit-arrow">›</text>
      </view>
    </view>
  </view>

  <!-- 菜单卡片 -->
  <view class="menu-card glass {{_anim ? 'anim-spring' : ''}}" style="animation-delay: 0.12s">
    <view bindtap="changePassword" class="menu-item tap-3d">
      <view class="menu-left">
        <view class="menu-icon-wrapper violet-bg">
          <view class="menu-icon-glow violet"></view>
          <text class="menu-icon">🔑</text>
        </view>
        <text class="menu-text">{{uiText.changePassword}}</text>
      </view>
      <text class="arrow">›</text>
    </view>
    <view bindtap="exportData" class="menu-item tap-3d">
      <view class="menu-left">
        <view class="menu-icon-wrapper amber-bg">
          <view class="menu-icon-glow amber"></view>
          <text class="menu-icon">📥</text>
        </view>
        <text class="menu-text">{{uiText.exportData}}</text>
      </view>
      <text class="arrow">›</text>
    </view>
    <view bindtap="viewReport" class="menu-item tap-3d">
      <view class="menu-left">
        <view class="menu-icon-wrapper mint-bg">
          <view class="menu-icon-glow mint"></view>
          <text class="menu-icon">📊</text>
        </view>
        <text class="menu-text">{{uiText.report}}</text>
      </view>
      <text class="arrow">›</text>
    </view>
    <view bindtap="viewDeliveryList" class="menu-item tap-3d">
      <view class="menu-left">
        <view class="menu-icon-wrapper blue-bg">
          <view class="menu-icon-glow blue"></view>
          <text class="menu-icon">📋</text>
        </view>
        <text class="menu-text">送货单记录</text>
      </view>
      <text class="arrow">›</text>
    </view>
    <view bindtap="manageStaff" class="menu-item tap-3d" wx:if="{{isAdmin}}">
      <view class="menu-left">
        <view class="menu-icon-wrapper coral-bg">
          <view class="menu-icon-glow coral"></view>
          <text class="menu-icon">👥</text>
        </view>
        <text class="menu-text">{{uiText.manageStaff}}</text>
      </view>
      <text class="arrow">›</text>
    </view>
    <view bindtap="about" class="menu-item tap-3d">
      <view class="menu-left">
        <view class="menu-icon-wrapper neutral-bg">
          <text class="menu-icon">ℹ️</text>
        </view>
        <text class="menu-text">{{uiText.about}}</text>
      </view>
      <text class="arrow">›</text>
    </view>
  </view>

  <!-- 退出按钮 -->
  <view class="logout-section {{_anim ? 'anim-spring' : ''}}" style="animation-delay: 0.22s">
    <button bindtap="logout" class="logout-btn" wx:if="{{isLogged}}">{{uiText.logout}}</button>
  </view>
</view>
