<view class="container">
    <!-- 快捷状态标签 -->
    <view class="status-tabs">
        <view class="status-tab {{statusFilter=== tap-3d'unpaid'?'active':''}} tap-3d" class="tap-3d" bindtap="onStatusFilter" data-status="unpaid">
            <text class="status-count">{{statusCounts.unpaid}}</text>
            <text class="status-label">{{uiText.unpaid}}</text>
        </view>
        <view class="status-tab {{statusFilter=== tap-3d'paid'?'active':''}} tap-3d" class="tap-3d" bindtap="onStatusFilter" data-status="paid">
            <text class="status-count">{{statusCounts.paid}}</text>
            <text class="status-label">{{uiText.paid}}</text>
        </view>
        <view class="status-tab {{statusFilter=== tap-3d'voided'?'active':''}} tap-3d" class="tap-3d" bindtap="onStatusFilter" data-status="voided">
            <text class="status-count">{{statusCounts.voided}}</text>
            <text class="status-label">{{uiText.voided}}</text>
        </view>
        <view class="status-tab {{statusFilter=== tap-3d'all'?'active':''}} tap-3d" class="tap-3d" bindtap="onStatusFilter" data-status="all">
            <text class="status-count">{{statusCounts.all}}</text>
            <text class="status-label">{{uiText.all}}</text>
        </view>
    </view>

    <!-- 搜索 + 月份 + 排序 -->
    <view class="filter-bar">
        <view class="search-box">
            <text class="search-icon">🔍</text>
            <input bindinput="onSearchInput" class="search-input" placeholder="{{uiText.search}}" value="{{searchKeyword}}"></input>
        </view>
        <view class="filter-right">
            <picker bindchange="onMonthChange" fields="month" mode="date" value="{{filterMonth}}">
                <view class="picker-btn">{{filterMonth||uiText.month}}</view>
            </picker>
            <picker bindchange="onSortChange" mode="selector" range="{{sortOptions}}" rangeKey="name">
                <view class="sort-btn">{{selectedSort?selectedSort.name:uiText.sort}}</view>
            </picker>
        </view>
    </view>
    <view class="summary">
        <view class="summary-item">
            <text class="label">{{uiText.totalInvoiceAmount}}</text>
            <text class="value invoice">{{totalInvoiceAmount}}</text>
        </view>
        <view class="summary-item">
            <text class="label">{{uiText.totalAmount}}</text>
            <text class="value">{{totalAmount}}</text>
        </view>
        <view class="summary-item">
            <text class="label">{{uiText.totalCost}}</text>
            <text class="value">{{totalCost}}</text>
        </view>
        <view class="summary-item">
            <text class="label">{{uiText.totalProfit}}</text>
            <text class="value profit">{{totalProfit}}</text>
        </view>
    </view>
    <view class="toolbar" wx:if="{{isRoot}}">
        <button bindtap="recalculateProfit" class="recalc-btn tap-3d" disabled="{{recalculating}}">{{recalculating ? '重算中...' : '重算利润'}}</button>
    </view>
    <view class="sale-list" wx:if="{{saleList.length}}">
        <view class="sale-item {{_anim ? 'anim-spring' : ''}}" wx:for="{{saleList}}" wx:key="_id" style="animation-delay: {{index * 0.08 < 0.4 ? index * 0.08 : 0.4}}s">
            <view class="sale-header">
                <text class="customer-name">{{item.customerName}}</text>
                <view class="status-tags">
                    <text class="status-tag voided" wx:if="{{item.voidStatus==='voided'}}">{{uiText.voided}}</text>
                    <text class="status-tag {{item.payStatus}}">{{item.hasPartial ? item.payStatusStr : (item.payStatus==='paid'?uiText.paid:uiText.unpaid)}}</text>
                    <text class="sale-date">{{item.saleDate}}</text>
                </view>
            </view>
            <view class="goods-detail">
                <view class="goods-row header">
                    <text>{{uiText.goods}}</text>
                    <text>{{uiText.quantity}}</text>
                    <text>{{uiText.unitPrice}}</text>
                    <text>{{uiText.profit}}</text>
                </view>
                <view class="goods-row" wx:for="{{item.goodsDetail}}" wx:for-item="goods" wx:key="goodsId">
                    <text>{{goods.goodsName}}</text>
                    <text>{{goods.quantity}}{{goods.unit}}</text>
                    <text>{{goods.salePrice}}</text>
                    <text class="profit">{{goods.profit}}</text>
                </view>
            </view>
            <view class="sale-footer">
                <view class="amount-info">
                    <text class="invoice-text">开票: ¥{{item.totalInvoiceAmountStr}}</text>
                    <text class="paid-text" wx:if="{{item.hasPartial}}">已付: ¥{{item.totalPaidStr}} / 待付: ¥{{item.remaining}}</text>
                    <text>{{uiText.total}}: {{item.totalAmountStr}}</text>
                    <text class="profit-text">{{uiText.profit}}: {{item.totalProfitStr}}</text>
                </view>
                <view class="action-btns" wx:if="{{item.payStatus==='unpaid' && item.voidStatus!=='voided'}}">
                    <button bindtap="goToDelivery" class="delivery-btn tap-3d" data-id="{{item._id}}">📋 送货单</button>
                    <button bindtap="voidSale" class="void-btn tap-3d" data-id="{{item._id}}" data-wxid="{{item._id}}">{{uiText.voidSale}}</button>
                    <button bindtap="confirmPayment" class="pay-btn tap-3d" data-id="{{item._id}}" data-remaining="{{item.remaining}}">{{item.hasPartial ? '收余款 ¥' + item.remaining : '确认收款'}}</button>
                </view>
                <view class="action-btns" wx:elif="{{item.voidStatus==='voided'}}">
                    <text class="voided-hint">该单已红冲，库存已恢复</text>
                </view>
                <view class="action-btns" wx:else>
                    <button bindtap="goToDelivery" class="delivery-btn tap-3d" data-id="{{item._id}}">📋 送货单</button>
                </view>
            </view>
        </view>
    </view>
    <view class="empty" wx:if="{{!saleList.length}}">
        <text>{{uiText.noSales}}</text>
    </view>
    
    <!-- 分页 -->
    <view class="pagination" wx:if="{{totalCount > 0}}">
        <button bindtap="prevPage" class="page-btn tap-3d" disabled="{{currentPage === 1}}">上一页</button>
        <text class="page-info">{{currentPage}} / {{totalPages}} 共 {{totalCount}} 条</text>
        <button bindtap="nextPage" class="page-btn tap-3d" disabled="{{currentPage >= totalPages}}">下一页</button>
    </view>
    
    <view bindtap="goToAdd" class="add-btn tap-3d">{{uiText.addSale}}</view>

    <!-- 收款弹窗 -->
    <view class="pay-modal-mask tap-3d" wx:if="{{showPayModal}}" class="tap-3d" bindtap="cancelPayment"></view>
    <view class="pay-modal" wx:if="{{showPayModal}}">
        <view class="pay-modal-title">确认收款</view>
        <view class="pay-modal-body">
            <text class="pay-modal-label">剩余待付：¥{{payingRemaining}}</text>
            <view class="pay-input-box">
                <text class="pay-input-prefix">¥</text>
                <input type="digit" class="pay-input" value="{{payingAmount}}" bindinput="onPayAmountInput" focus="{{true}}" placeholder="请输入收款金额"></input>
            </view>
        </view>
        <view class="pay-modal-footer">
            <button bindtap="cancelPayment" class="pay-cancel-btn tap-3d">取消</button>
            <button bindtap="submitPayment" class="pay-confirm-btn tap-3d">确认收款</button>
        </view>
    </view>
</view>
