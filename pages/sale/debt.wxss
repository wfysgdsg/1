.container {
  background-color: #f5f5f5;
  min-height: 100vh;
  padding: 30rpx;
}
.header-card {
  background: linear-gradient(135deg, #ff4d4f, #ff7875);
  border-radius: 20rpx;
  box-shadow: 0 10rpx 30rpx rgba(255, 77, 79, 0.3);
  color: #fff;
  margin-bottom: 30rpx;
  padding: 40rpx;
  text-align: center;
}
.total-label {
  font-size: 28rpx;
  opacity: 0.9;
}
.total-amount {
  display: block;
  font-size: 64rpx;
  font-weight: 700;
  margin: 20rpx 0;
}
.total-stats {
  display: -webkit-flex;
  display: flex;
  font-size: 24rpx;
  gap: 30rpx;
  justify-content: center;
  opacity: 0.82;
}
.customer-debt-item {
  background: #fff;
  border-radius: 18rpx;
  box-shadow: 0 8rpx 24rpx rgba(15, 35, 95, 0.05);
  margin-bottom: 20rpx;
  overflow: hidden;
}
.customer-header {
  align-items: center;
  display: -webkit-flex;
  display: flex;
  justify-content: space-between;
  padding: 28rpx 30rpx;
}
.customer-info {
  flex: 1;
  padding-right: 16rpx;
}
.customer-name {
  color: #333;
  display: block;
  font-size: 32rpx;
  font-weight: 700;
}
.order-count {
  color: #999;
  font-size: 22rpx;
  margin-top: 8rpx;
}
.customer-amount-info {
  align-items: center;
  gap: 15rpx;
  text-align: right;
}
.customer-amount-info,
.debt-sums {
  display: -webkit-flex;
  display: flex;
}
.debt-sums {
  align-items: flex-end;
  flex-direction: column;
}
.debt-amount {
  color: #ff4d4f;
  font-size: 34rpx;
  font-weight: 700;
}
.debt-profit {
  color: #52c41a;
  font-size: 20rpx;
  margin-top: 4rpx;
}
.arrow {
  color: #ccc;
  font-size: 20rpx;
  transition: -webkit-transform 0.3s;
  transition: transform 0.3s;
  transition:
    transform 0.3s,
    -webkit-transform 0.3s;
}
.arrow.up {
  transform: rotate(180deg);
}
.order-details {
  background: #fafafa;
  border-top: 1rpx solid #eee;
  padding: 10rpx 0 4rpx;
}
.order-item {
  background: #fff;
  border-radius: 18rpx;
  box-shadow: inset 0 0 0 1rpx #f2f2f2;
  margin: 14rpx 18rpx;
  padding: 22rpx;
}
.order-main {
  align-items: flex-start;
  gap: 20rpx;
  justify-content: space-between;
  margin-bottom: 18rpx;
}
.order-date-box,
.order-main {
  display: -webkit-flex;
  display: flex;
}
.order-date-box {
  flex-direction: column;
  gap: 8rpx;
}
.order-date {
  color: #444;
  display: block;
  font-size: 28rpx;
  font-weight: 700;
}
.debt-tag {
  background: #fff7e6;
  border-radius: 999rpx;
  color: #fa8c16;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  width: -webkit-fit-content;
  width: fit-content;
}
.debt-tag.urgent {
  background: #fff1f0;
  color: #ff4d4f;
  font-weight: 700;
}
.order-money-info {
  align-items: flex-end;
  display: -webkit-flex;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}
.order-amount {
  color: #333;
  font-size: 25rpx;
  font-weight: 600;
}
.order-profit {
  color: #52c41a;
  font-size: 22rpx;
}
.goods-table {
  background: #fafcff;
  border: 1rpx solid #eef3ff;
  border-radius: 14rpx;
  padding: 16rpx 18rpx 6rpx;
}
.goods-table-head,
.goods-table-row {
  align-items: center;
  column-gap: 10rpx;
  display: grid;
  grid-template-columns: minmax(0, 2.2fr) 1fr 1.15fr 1.15fr 1.2fr;
}
.goods-table-head {
  border-bottom: 1rpx dashed #dbe7ff;
  padding-bottom: 12rpx;
}
.goods-table-head text {
  color: #8c8c8c;
  font-size: 20rpx;
  font-weight: 600;
}
.goods-table-row {
  border-bottom: 1rpx dashed #edf2fb;
  padding: 14rpx 0;
}
.goods-table-row:last-child {
  border-bottom: none;
}
.goods-table-row text {
  color: #262626;
  font-size: 22rpx;
}
.goods-name {
  line-height: 1.45;
  word-break: break-all;
}
.profit-text {
  color: #52c41a !important;
  font-weight: 600;
}
.col-name {
  text-align: left;
}
.col-price,
.col-profit,
.col-qty,
.col-total {
  text-align: right;
}
.pay-btn-sm {
  background: #1890ff;
  border-radius: 29rpx;
  color: #fff;
  font-size: 22rpx;
  height: 58rpx;
  line-height: 58rpx;
  margin: 18rpx 0 0 auto;
  width: 172rpx !important;
}
.empty {
  color: #bfbfbf;
  padding-top: 200rpx;
  text-align: center;
}
.empty text {
  display: block;
  font-size: 28rpx;
  margin-top: 30rpx;
}
