page { --grad: linear-gradient(135deg,#5B6CF7,#7C5CFF); --accent:#5B6CF7; --danger:#FF4D4F; --success:#52C41A; }

.page { min-height: 100vh; padding-bottom: 60rpx; background: var(--bg); }
.hero { background: var(--grad); transition: background .3s; }
.hero.paid { background: linear-gradient(135deg,#36C172,#19A85C); }
.body { padding: 0 28rpx 28rpx; margin-top: -56rpx; position: relative; z-index: 2; }

/* ---------- Tab 分段控件 ---------- */
.tab-bar {
  display: flex;
  background: var(--card);
  border-radius: var(--pill);
  padding: 8rpx;
  box-shadow: var(--sh-m);
  margin-bottom: 22rpx;
}
.tab-item {
  flex: 1;
  text-align: center;
  height: 72rpx;
  line-height: 72rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--ink-2);
  border-radius: var(--pill);
  transition: all .2s;
}
.tab-item.active {
  background: var(--grad);
  color: #fff;
  box-shadow: 0 8rpx 20rpx rgba(91,108,247,.3);
}

/* ---------- 汇总头卡 ---------- */
.header-card {
  border-radius: var(--r-l);
  padding: 34rpx 32rpx;
  margin-bottom: 24rpx;
  color: #fff;
  box-shadow: var(--sh-m);
}
.header-card.unpaid { background: linear-gradient(135deg,#FF7875,#FF4D4F); }
.header-card.paid { background: linear-gradient(135deg,#5DDC8A,#34B86A); }
.total-label { display: block; font-size: 26rpx; opacity: .9; }
.total-amount { display: block; font-size: 64rpx; font-weight: 800; margin: 10rpx 0 18rpx; }
.total-stats { display: flex; gap: 16rpx; }
.stat-chip {
  font-size: 24rpx;
  background: rgba(255,255,255,.22);
  padding: 8rpx 20rpx;
  border-radius: var(--pill);
}

/* ---------- 客户卡 ---------- */
.customer-list { display: flex; flex-direction: column; gap: 18rpx; }
.customer-debt-item {
  background: var(--card);
  border-radius: var(--r-l);
  box-shadow: var(--sh-s);
  overflow: hidden;
}
.customer-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 26rpx 28rpx;
}
.customer-info { display: flex; align-items: center; flex: 1; min-width: 0; }
.avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  margin-right: 18rpx;
  flex-shrink: 0;
}
.avatar.unpaid { background: #FFF1F0; }
.avatar.paid { background: #F6FFED; }
.customer-meta { display: flex; flex-direction: column; min-width: 0; }
.customer-name { font-size: 30rpx; font-weight: 700; color: var(--ink); }
.order-count { font-size: 22rpx; color: var(--ink-3); margin-top: 6rpx; }

.customer-amount-info { display: flex; align-items: center; gap: 12rpx; flex-shrink: 0; }
.debt-sums { display: flex; flex-direction: column; align-items: flex-end; }
.debt-amount { font-size: 32rpx; font-weight: 800; color: var(--danger); }
.debt-amount.paid-amount { color: var(--success); }
.debt-profit { font-size: 22rpx; color: var(--ink-3); margin-top: 6rpx; }
.arrow {
  font-size: 22rpx;
  color: var(--ink-3);
  transition: transform .25s;
}
.arrow.up { transform: rotate(180deg); }

/* ---------- 订单明细 ---------- */
.order-details {
  padding: 0 28rpx 20rpx;
  border-top: 2rpx solid var(--line);
}
.order-item {
  background: var(--field);
  border-radius: var(--r-m);
  padding: 22rpx;
  margin-top: 18rpx;
}
.order-item.partial-paid { border-left: 6rpx solid var(--warning, #FA8C16); }
.order-main {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: 16rpx;
}
.order-date-box { display: flex; flex-direction: column; gap: 8rpx; }
.order-date { font-size: 26rpx; font-weight: 600; color: var(--ink); }
.debt-tag {
  align-self: flex-start;
  font-size: 20rpx;
  color: #FA8C16;
  background: #FFF7E6;
  padding: 4rpx 14rpx;
  border-radius: var(--pill);
}
.debt-tag.urgent { color: var(--danger); background: #FFF1F0; }
.paid-tag {
  align-self: flex-start;
  font-size: 20rpx;
  color: var(--success);
  background: #F6FFED;
  padding: 4rpx 14rpx;
  border-radius: var(--pill);
}
.order-money-info { display: flex; flex-direction: column; align-items: flex-end; gap: 6rpx; }
.order-amount { font-size: 28rpx; font-weight: 700; color: var(--ink); }
.partial-paid-text { font-size: 22rpx; color: #FA8C16; }
.order-profit { font-size: 22rpx; color: var(--ink-3); }

/* ---------- 商品明细表 ---------- */
.goods-table {
  background: #fff;
  border-radius: var(--r-s);
  padding: 14rpx 16rpx;
  margin-bottom: 16rpx;
}
.goods-table-head,
.goods-table-row {
  display: flex;
  align-items: center;
  font-size: 22rpx;
  padding: 10rpx 0;
}
.goods-table-head {
  color: var(--ink-3);
  border-bottom: 2rpx solid var(--line);
}
.goods-table-row { color: var(--ink-2); border-bottom: 2rpx solid var(--line); }
.goods-table-row:last-child { border-bottom: none; }
.col-name { flex: 2; }
.col-qty, .col-price, .col-profit, .col-total { flex: 1; text-align: right; }
.goods-name { color: var(--ink); font-weight: 600; }
.profit-text { color: var(--success); }

/* ---------- 收款按钮 ---------- */
.pay-btn-sm {
  width: 100%;
  height: 76rpx;
  line-height: 76rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: #fff;
  background: var(--grad);
  border-radius: var(--pill);
  border: none;
  box-shadow: 0 8rpx 20rpx rgba(91,108,247,.3);
}
.pay-btn-sm::after { border: none; }

/* ---------- 空状态 ---------- */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0;
}
.empty-icon { font-size: 80rpx; margin-bottom: 20rpx; }
.empty-text { font-size: 28rpx; color: var(--ink-3); }

/* ---------- 收款弹窗 ---------- */
.pay-modal-mask {
  position: fixed;
  inset: 0;
  background: rgba(20,21,42,.45);
  z-index: 100;
}
.pay-modal {
  position: fixed;
  left: 50%;
  top: 50%;
  transform: translate(-50%,-50%);
  width: 600rpx;
  background: var(--card);
  border-radius: var(--r-l);
  z-index: 101;
  overflow: hidden;
  box-shadow: 0 30rpx 80rpx rgba(0,0,0,.25);
}
.pay-modal-title {
  text-align: center;
  font-size: 32rpx;
  font-weight: 700;
  color: var(--ink);
  padding: 36rpx 0 8rpx;
}
.pay-modal-body { padding: 24rpx 40rpx 8rpx; }
.pay-modal-label { display: block; font-size: 26rpx; color: var(--ink-2); margin-bottom: 18rpx; }
.pay-input-box {
  display: flex;
  align-items: center;
  background: var(--field);
  border-radius: var(--r-m);
  padding: 0 24rpx;
  height: 96rpx;
}
.pay-input-prefix { font-size: 36rpx; font-weight: 700; color: var(--accent); margin-right: 12rpx; }
.pay-input { flex: 1; height: 96rpx; font-size: 40rpx; font-weight: 700; color: var(--ink); background: transparent; border: none; padding: 0; border-radius: 0; }
.pay-modal-footer {
  display: flex;
  gap: 20rpx;
  padding: 28rpx 40rpx 36rpx;
}
.pay-cancel-btn,
.pay-confirm-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: var(--pill);
  border: none;
}
.pay-cancel-btn::after,
.pay-confirm-btn::after { border: none; }
.pay-cancel-btn { background: #EEF0F6; color: var(--ink-2); }
.pay-confirm-btn {
  background: var(--grad);
  color: #fff;
  box-shadow: 0 12rpx 30rpx rgba(91,108,247,.36);
}
