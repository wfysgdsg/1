<view class="page anim-enter-3d">

  <!-- 1) 顶部渐变大头 -->
  <view class="x-hero hero anim-enter-3d">
    <view class="x-hero-orb a"></view>
    <view class="x-hero-orb b"></view>
    <text class="x-hero-title">销售开票</text>
    <text class="x-hero-sub">先选商品，再选客户，最后确认金额和收款状态</text>
  </view>

  <!-- 2) 内容卡片区 -->
  <view class="body">

    <!-- 选择商品 -->
    <view class="card">
      <view class="card-h"><view class="dot"></view>选择商品</view>
      <view class="card-tip">支持搜索，也可以从借货明细批量导入</view>

      <view class="goods-select">
        <view class="search-box">
          <text class="search-ico">🔍</text>
          <input bindinput="onSearchInput" class="search-inp" confirmType="search" placeholder="输入商品名称搜索" value="{{searchKeyword}}"></input>
          <view bindtap="clearSearch" class="clear-search x-tap" wx:if="{{searchKeyword}}">×</view>
        </view>

        <view class="search-result" wx:if="{{showSearchResults&&searchResults.length>0}}">
          <view class="result-item" wx:for="{{searchResults}}" wx:key="_id">
            <view bindtap="toggleCheck" class="check-box {{checkedIds[item._id] ? 'checked' : ''}}" data-id="{{item._id}}">
              <text class="check-mark" wx:if="{{checkedIds[item._id]}}">✓</text>
            </view>
            <view bindtap="selectGoods" class="result-info" data-id="{{item._id}}">
              <text class="result-name">{{item.name}}</text>
              <text class="result-price">¥{{item.salePrice}}</text>
            </view>
          </view>
          <view class="batch-bar" wx:if="{{checkedCount > 0}}">
            <text class="batch-count">已选 {{checkedCount}} 项</text>
            <button bindtap="batchAddGoods" class="batch-add-btn x-tap">批量添加</button>
          </view>
        </view>

        <view class="search-result empty-result" wx:if="{{showSearchResults&&searchResults.length===0&&searchKeyword}}">
          <text>未找到商品</text>
        </view>
      </view>

      <view class="selected-goods" wx:if="{{selectedGoods.length>0}}">
        <view class="selected-summary">
          <text>已选 {{selectedGoods.length}} 种商品</text>
          <text class="summary-profit" wx:if="{{hasAllQuantities}}">预计毛利 ¥{{totalProfit}}</text>
        </view>

        <view class="goods-item" wx:for="{{selectedGoods}}" wx:key="index">
          <view class="goods-header">
            <view class="goods-name-group">
              <text class="goods-name">{{item.name}}</text>
              <text class="goods-unit">单位：{{item.unit||'未填'}}</text>
            </view>
            <text bindtap="removeGoods" class="remove-btn x-tap" data-index="{{index}}">×</text>
          </view>
          <view class="goods-body">
            <view class="price-row">
              <text class="price-label">售价</text>
              <input bindinput="onSalePriceInput" class="price-input" data-index="{{index}}" type="digit" value="{{item.salePrice}}"></input>
            </view>
            <view class="price-row">
              <text class="price-label">成本</text>
              <input bindinput="onCostPriceInput" class="price-input" data-index="{{index}}" type="digit" value="{{item.costPrice}}"></input>
            </view>
            <view class="price-row">
              <text class="price-label">数量</text>
              <input bindinput="onQuantityInput" class="quantity-input" data-index="{{index}}" placeholder="0" type="digit" value="{{item.quantity}}"></input>
            </view>
          </view>
          <view class="goods-footer">
            <text class="goods-stock">库存 {{item.userStock}}</text>
            <text class="goods-profit-text" wx:if="{{item.quantity}}">毛利 ¥{{item.profit}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 客户信息 -->
    <view class="card">
      <view class="card-h"><view class="dot"></view>客户信息<text class="req">*</text></view>
      <view class="card-tip">建议先搜索已有客户，没有再新增</view>

      <view class="location-search">
        <view class="search-box">
          <text class="search-ico">🔍</text>
          <input bindfocus="onContactFocus" bindinput="onContactKeywordInput" class="search-inp" placeholder="输入关键字搜索客户" value="{{contactKeyword}}"></input>
        </view>
        <view class="contact-results" wx:if="{{showContactResults&&contactResults.length>0}}">
          <view bindtap="selectContact" class="contact-item" data-item="{{item}}" wx:for="{{contactResults}}" wx:key="_id">
            <text class="contact-name">{{item.name}}</text>
            <text class="result-detail" wx:if="{{item.contact}}">{{item.contact}}</text>
          </view>
        </view>
        <view class="contact-results empty-result" wx:if="{{showContactResults&&contactResults.length===0&&contactKeyword}}">
          <text>未找到匹配客户</text>
        </view>
      </view>

      <view class="selected-location" wx:if="{{selectedContact}}">
        <text class="selected-text">已选：{{selectedContact.name}}</text>
        <text bindtap="clearContact" class="clear-btn x-tap">×</text>
      </view>

      <view bindtap="goToAddContact" class="add-link x-tap">＋ 新增客户</view>
    </view>

    <!-- 本单预览 -->
    <view class="card preview-card anim-spring" style="animation-delay:0.18s" wx:if="{{selectedGoods.length>0&&hasAllQuantities}}">
      <view class="card-h light"><view class="dot light"></view>本单预览</view>
      <view class="profit-row highlight">
        <text>开票金额</text>
        <text class="val-strong">¥{{totalInvoiceAmount}}</text>
      </view>
      <view class="profit-row">
        <text>销售金额</text>
        <text>¥{{totalAmount}}</text>
      </view>
      <view class="profit-row">
        <text>成本</text>
        <text>¥{{totalCost}}</text>
      </view>
      <view class="profit-row highlight">
        <text>预估毛利</text>
        <text class="val-profit">¥{{totalProfit}}</text>
      </view>
      <view class="profit-row">
        <text>毛利率</text>
        <text>{{profitRate}}%</text>
      </view>
    </view>

    <!-- 订单信息 -->
    <view class="card">
      <view class="card-h"><view class="dot"></view>订单信息</view>

      <view class="field">
        <text class="lab">销售日期<text class="req">*</text></text>
        <picker bindchange="onDateChange" mode="date" value="{{saleDate}}">
          <view class="picker">
            <text class="picker-txt {{saleDate ? '' : 'ph'}}">{{saleDate||'请选择日期'}}</text>
            <text class="picker-arrow">›</text>
          </view>
        </picker>
      </view>

      <view class="field">
        <text class="lab">付款状态</text>
        <radio-group bindchange="onPayStatusChange" class="radio-group">
          <label class="radio-label {{payStatus==='unpaid' ? 'on-unpaid' : ''}}">
            <radio checked="{{payStatus==='unpaid'}}" color="#FF4D4F" value="unpaid"></radio>
            <text>未付款</text>
          </label>
          <label class="radio-label {{payStatus==='paid' ? 'on-paid' : ''}}">
            <radio checked="{{payStatus==='paid'}}" color="#52C41A" value="paid"></radio>
            <text>已结清</text>
          </label>
        </radio-group>
      </view>

      <view class="field last">
        <text class="lab">备注</text>
        <textarea bindinput="onRemarkInput" class="textarea" placeholder="可选填写" value="{{remark}}"></textarea>
      </view>
    </view>

  </view>

  <!-- 3) 底部玻璃操作栏 -->
  <view class="x-glass-bar">
    <button bindtap="goBack" class="btn ghost x-tap">返回</button>
    <button bindtap="submit" class="btn main x-tap" disabled="{{submitting}}">{{submitting ? '提交中...' : '确认开票'}}</button>
  </view>

</view>
