page { --grad: linear-gradient(135deg,#5B6CF7,#7C5CFF); --accent:#5B6CF7; }

.page { min-height: 100vh; padding-bottom: 200rpx; background: var(--bg); }
.hero { background: var(--grad); }
.body { padding: 28rpx; margin-top: -32rpx; position: relative; z-index: 2; }

/* ---------- 通用卡片 ---------- */
.card {
  background: var(--card);
  border-radius: var(--r-l);
  padding: 28rpx;
  margin-bottom: 22rpx;
  box-shadow: var(--sh-s);
}
.card-h {
  display: flex;
  align-items: center;
  font-size: 28rpx;
  font-weight: 700;
  color: var(--ink);
  margin-bottom: 8rpx;
}
.dot {
  width: 8rpx;
  height: 30rpx;
  border-radius: 4rpx;
  background: var(--grad);
  margin-right: 14rpx;
}
.card-tip {
  font-size: 22rpx;
  color: var(--ink-3);
  line-height: 1.5;
  margin: 0 0 20rpx 22rpx;
}
.req { color: var(--accent); margin-left: 6rpx; font-weight: 700; }

/* ---------- 字段 ---------- */
.field { padding-bottom: 26rpx; }
.field.last { padding-bottom: 4rpx; }
.lab {
  display: block;
  font-size: 26rpx;
  color: var(--ink-2);
  font-weight: 600;
  margin-bottom: 14rpx;
}

/* ---------- 搜索框 ---------- */
.search-box {
  display: flex;
  align-items: center;
  background: var(--field);
  border: 2rpx solid transparent;
  border-radius: var(--r-m);
  padding: 0 20rpx;
  height: 88rpx;
}
.search-ico { font-size: 30rpx; opacity: .55; margin-right: 12rpx; }
.search-inp {
  flex: 1; height: 88rpx; font-size: 30rpx; color: var(--ink);
  background: transparent; border: none; padding: 0; border-radius: 0;
}
.clear-search {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: #C8CBDA;
  color: #fff;
  font-size: 28rpx;
  line-height: 40rpx;
  text-align: center;
  margin-left: 8rpx;
}

/* ---------- 搜索结果 ---------- */
.search-result {
  margin-top: 14rpx;
  background: #fff;
  border: 2rpx solid var(--line);
  border-radius: var(--r-m);
  overflow: hidden;
}
.result-item {
  display: flex;
  align-items: center;
  padding: 22rpx 20rpx;
  border-bottom: 2rpx solid var(--line);
}
.result-item:last-child { border-bottom: none; }
.check-box {
  width: 40rpx;
  height: 40rpx;
  border: 2rpx solid #C8CBDA;
  border-radius: 10rpx;
  margin-right: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.check-box.checked { background: var(--grad); border-color: transparent; }
.check-mark { color: #fff; font-size: 26rpx; font-weight: 700; }
.result-info {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.result-name { font-size: 28rpx; color: var(--ink); }
.result-price { font-size: 28rpx; color: var(--accent); font-weight: 700; }

.batch-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 18rpx 20rpx;
  background: #F3F5FB;
}
.batch-count { font-size: 24rpx; color: var(--ink-2); }
.batch-add-btn {
  height: 60rpx;
  line-height: 60rpx;
  padding: 0 28rpx;
  font-size: 24rpx;
  color: #fff;
  background: var(--grad);
  border-radius: var(--pill);
  border: none;
}
.batch-add-btn::after { border: none; }

.empty-result {
  margin-top: 14rpx;
  padding: 30rpx;
  text-align: center;
  font-size: 26rpx;
  color: var(--ink-3);
  background: var(--field);
  border-radius: var(--r-m);
}

/* ---------- 已选商品 ---------- */
.selected-goods { margin-top: 22rpx; }
.selected-summary {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #EEF1FE;
  border-radius: var(--r-s);
  padding: 16rpx 20rpx;
  font-size: 24rpx;
  color: var(--ink-2);
  margin-bottom: 16rpx;
}
.summary-profit { color: var(--accent); font-weight: 700; }

.goods-item {
  background: var(--field);
  border-radius: var(--r-m);
  padding: 22rpx;
  margin-bottom: 16rpx;
}
.goods-item:last-child { margin-bottom: 0; }
.goods-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: 18rpx;
}
.goods-name-group { display: flex; flex-direction: column; }
.goods-name { font-size: 30rpx; font-weight: 700; color: var(--ink); }
.goods-unit { font-size: 22rpx; color: var(--ink-3); margin-top: 6rpx; }
.remove-btn {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: #fff;
  color: #FF4D4F;
  font-size: 32rpx;
  line-height: 44rpx;
  text-align: center;
  flex-shrink: 0;
}

.goods-body {
  display: flex;
  gap: 14rpx;
  margin-bottom: 16rpx;
}
.price-row {
  flex: 1;
  background: #fff;
  border-radius: var(--r-s);
  padding: 12rpx 16rpx;
}
.price-label { display: block; font-size: 22rpx; color: var(--ink-3); margin-bottom: 6rpx; }
.price-input,
.quantity-input {
  width: 100%; height: 48rpx; font-size: 30rpx; font-weight: 700; color: var(--ink);
  background: transparent; border: none; padding: 0; border-radius: 0;
}
.quantity-input { color: var(--accent); }

.goods-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.goods-stock { font-size: 22rpx; color: var(--ink-3); }
.goods-profit-text { font-size: 22rpx; color: #52C41A; font-weight: 600; }

/* ---------- 客户结果 ---------- */
.contact-results {
  margin-top: 14rpx;
  background: #fff;
  border: 2rpx solid var(--line);
  border-radius: var(--r-m);
  overflow: hidden;
}
.contact-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 22rpx 20rpx;
  border-bottom: 2rpx solid var(--line);
}
.contact-item:last-child { border-bottom: none; }
.contact-name { font-size: 28rpx; color: var(--ink); }
.result-detail { font-size: 24rpx; color: var(--ink-3); }

.selected-location {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 16rpx;
  padding: 18rpx 22rpx;
  background: #EEF1FE;
  border-radius: var(--r-m);
}
.selected-text { font-size: 28rpx; color: var(--ink); font-weight: 600; }
.clear-btn {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: #C8CBDA;
  color: #fff;
  font-size: 28rpx;
  line-height: 40rpx;
  text-align: center;
}
.add-link {
  margin-top: 18rpx;
  text-align: center;
  font-size: 26rpx;
  color: var(--accent);
  font-weight: 600;
  padding: 16rpx;
  border: 2rpx dashed #C3CCF9;
  border-radius: var(--r-m);
}

/* ---------- 本单预览 ---------- */
.preview-card { background: var(--grad); }
.card-h.light { color: #fff; }
.dot.light { background: rgba(255,255,255,.85); }
.profit-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 14rpx 0;
  font-size: 26rpx;
  color: rgba(255,255,255,.82);
}
.profit-row.highlight { color: #fff; font-weight: 700; font-size: 28rpx; }
.val-strong { font-size: 38rpx; }
.val-profit { font-size: 34rpx; color: #FFE58F; }

/* ---------- 选择器 ---------- */
.picker {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 88rpx;
  padding: 0 26rpx;
  background: var(--field);
  border: 2rpx solid transparent;
  border-radius: var(--r-m);
}
.picker-txt { font-size: 30rpx; color: var(--ink); }
.picker-txt.ph { color: var(--ink-3); }
.picker-arrow { color: var(--ink-3); font-size: 36rpx; transform: rotate(90deg); }

/* ---------- 付款状态 ---------- */
.radio-group { display: flex; gap: 18rpx; }
.radio-label {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  height: 88rpx;
  background: var(--field);
  border: 2rpx solid transparent;
  border-radius: var(--r-m);
  font-size: 28rpx;
  color: var(--ink-2);
}
.radio-label.on-unpaid { border-color: #FF4D4F; color: #FF4D4F; background: #FFF1F0; }
.radio-label.on-paid { border-color: #52C41A; color: #52C41A; background: #F6FFED; }

/* ---------- 备注 ---------- */
.textarea {
  width: 100%;
  box-sizing: border-box;
  min-height: 140rpx;
  padding: 22rpx 26rpx;
  background: var(--field);
  border: 2rpx solid transparent;
  border-radius: var(--r-m);
  font-size: 28rpx;
  color: var(--ink);
}

/* ---------- 底部按钮 ---------- */
.btn {
  border: none;
  border-radius: var(--pill);
  font-size: 30rpx;
  font-weight: 600;
  height: 92rpx;
  line-height: 92rpx;
}
.btn::after { border: none; }
.btn.ghost { flex: 1; background: #EEF0F6; color: var(--ink-2); }
.btn.main {
  flex: 2;
  background: var(--grad);
  color: #fff;
  box-shadow: 0 12rpx 30rpx rgba(91,108,247,.36);
}
.btn.main[disabled] { opacity: .6; }
