<view class="page {{_anim ? 'anim-spring' : ''}}">

  <!-- 顶部渐变大头 -->
  <view class="x-hero hero {{tab==='paid' ? 'paid' : 'unpaid'}}">
    <view class="x-hero-orb a"></view>
    <view class="x-hero-orb b"></view>
    <text class="x-hero-title">账款管理</text>
    <text class="x-hero-sub">{{tab==='unpaid' ? '跟进未结清订单，及时确认收款' : '查看已结清的收款记录'}}</text>
  </view>

  <view class="body">

    <!-- Tab 切换（分段控件） -->
    <view class="tab-bar">
      <view class="tab-item {{tab=== tap-3d'unpaid'?'active':''}} tap-3d" class="tap-3d" bindtap="switchTab" data-tab="unpaid">
        <text>{{uiText.unpaidTab}}</text>
      </view>
      <view class="tab-item {{tab=== tap-3d'paid'?'active':''}} tap-3d" class="tap-3d" bindtap="switchTab" data-tab="paid">
        <text>{{uiText.paidTab}}</text>
      </view>
    </view>

    <!-- ========== 应收账款（未结清） ========== -->
    <view wx:if="{{tab==='unpaid'}}">
      <view class="header-card unpaid">
        <text class="total-label">{{uiText.totalDebt}}</text>
        <text class="total-amount">¥{{totalDebt}}</text>
        <view class="total-stats">
          <text class="stat-chip">{{debtCount}} {{uiText.unpaidOrders}}</text>
          <text class="stat-chip">{{customerCount}} {{uiText.customers}}</text>
        </view>
      </view>

      <view class="customer-list">
        <view class="customer-debt-item {{_anim ? 'anim-spring' : ''}}" wx:for="{{debtList}}" wx:key="contactId" style="animation-delay: {{index * 0.08 < 0.4 ? index * 0.08 : 0.4}}s">
          <view bindtap="toggleCustomer" class="customer-header x-tap tap-3d" data-id="{{item.contactId}}">
            <view class="customer-info">
              <view class="avatar unpaid">👤</view>
              <view class="customer-meta">
                <text class="customer-name">{{item.contactName}}</text>
                <text class="order-count">{{item.orders.length}} {{uiText.orderCount}}</text>
              </view>
            </view>
            <view class="customer-amount-info">
              <view class="debt-sums">
                <text class="debt-amount">¥{{item.displayOriginal}}</text>
                <text class="debt-profit">{{uiText.profit}}: ¥{{item.displayProfit}}</text>
              </view>
              <text class="arrow {{expandedId===item.contactId?'up':'down'}}">▼</text>
            </view>
          </view>

          <view class="order-details" wx:if="{{expandedId===item.contactId}}">
            <view class="order-item {{order.hasPartial ? 'partial-paid' : ''}}" wx:for="{{item.orders}}" wx:for-item="order" wx:key="_id">
              <view class="order-main">
                <view class="order-date-box">
                  <text class="order-date">{{order.saleDate}}</text>
                  <text class="debt-tag {{order.debtDays>30?'urgent':''}}">{{uiText.overdue}}{{order.debtDays}}{{uiText.days}}</text>
                </view>
                <view class="order-money-info">
                  <text class="order-amount">待付 ¥{{order.orderOriginal}}</text>
                  <text class="partial-paid-text" wx:if="{{order.hasPartial}}">已付 ¥{{order.totalPaidStr}}</text>
                  <text class="order-profit">{{uiText.grossProfit}}: ¥{{order.orderProfit}}</text>
                </view>
              </view>
              <view class="goods-table" wx:if="{{order.goodsRows.length}}">
                <view class="goods-table-head">
                  <text class="col-name">{{uiText.goodsName}}</text>
                  <text class="col-qty">{{uiText.quantity}}</text>
                  <text class="col-price">{{uiText.unitPrice}}</text>
                  <text class="col-profit">{{uiText.grossProfit}}</text>
                  <text class="col-total">{{uiText.totalPrice}}</text>
                </view>
                <view class="goods-table-row" wx:for="{{order.goodsRows}}" wx:for-item="row" wx:key="index">
                  <text class="col-name goods-name">{{row.goodsName}}</text>
                  <text class="col-qty">{{row.quantity}}{{row.unit}}</text>
                  <text class="col-price">{{row.salePrice}}</text>
                  <text class="col-profit profit-text">{{row.profit}}</text>
                  <text class="col-total">{{row.lineTotal}}</text>
                </view>
              </view>
              <button bindtap="confirmPayment" class="pay-btn-sm x-tap tap-3d" data-id="{{order._id}}" data-remaining="{{order.remaining}}">{{order.hasPartial ? uiText.payRemaining + ' ¥' + order.remaining : uiText.confirmPayment}}</button>
            </view>
          </view>
        </view>
      </view>

      <view class="empty-state" wx:if="{{debtList.length===0}}">
        <view class="empty-icon">✅</view>
        <text class="empty-text">{{uiText.noDebt}}</text>
      </view>
    </view>

    <!-- ========== 已收款项（已结清） ========== -->
    <view wx:if="{{tab==='paid'}}">
      <view class="header-card paid">
        <text class="total-label">{{uiText.totalPaid}}</text>
        <text class="total-amount">¥{{totalPaid}}</text>
        <view class="total-stats">
          <text class="stat-chip">{{paidCount}} {{uiText.paidOrders}}</text>
          <text class="stat-chip">{{paidCustomerCount}} {{uiText.paidCustomers}}</text>
        </view>
      </view>

      <view class="customer-list">
        <view class="customer-debt-item {{_anim ? 'anim-spring' : ''}}" wx:for="{{paidList}}" wx:key="contactId" style="animation-delay: {{index * 0.08 < 0.4 ? index * 0.08 : 0.4}}s">
          <view bindtap="togglePaidCustomer" class="customer-header x-tap tap-3d" data-id="{{item.contactId}}">
            <view class="customer-info">
              <view class="avatar paid">👤</view>
              <view class="customer-meta">
                <text class="customer-name">{{item.contactName}}</text>
                <text class="order-count">{{item.orders.length}} {{uiText.orderCount}}</text>
              </view>
            </view>
            <view class="customer-amount-info">
              <view class="debt-sums">
                <text class="debt-amount paid-amount">¥{{item.displayOriginal}}</text>
                <text class="debt-profit">{{uiText.profit}}: ¥{{item.displayProfit}}</text>
              </view>
              <text class="arrow {{paidExpandedId===item.contactId?'up':'down'}}">▼</text>
            </view>
          </view>

          <view class="order-details" wx:if="{{paidExpandedId===item.contactId}}">
            <view class="order-item" wx:for="{{item.orders}}" wx:for-item="order" wx:key="_id">
              <view class="order-main">
                <view class="order-date-box">
                  <text class="order-date">{{order.saleDate}}</text>
                  <text class="paid-tag">{{uiText.payTime}}: {{order.payTimeStr}}</text>
                </view>
                <view class="order-money-info">
                  <text class="order-amount">实收 ¥{{order.orderOriginal}}</text>
                  <text class="order-profit">{{uiText.grossProfit}}: ¥{{order.orderProfit}}</text>
                </view>
              </view>
              <view class="goods-table" wx:if="{{order.goodsRows.length}}">
                <view class="goods-table-head">
                  <text class="col-name">{{uiText.goodsName}}</text>
                  <text class="col-qty">{{uiText.quantity}}</text>
                  <text class="col-price">{{uiText.unitPrice}}</text>
                  <text class="col-profit">{{uiText.grossProfit}}</text>
                  <text class="col-total">{{uiText.totalPrice}}</text>
                </view>
                <view class="goods-table-row" wx:for="{{order.goodsRows}}" wx:for-item="row" wx:key="index">
                  <text class="col-name goods-name">{{row.goodsName}}</text>
                  <text class="col-qty">{{row.quantity}}{{row.unit}}</text>
                  <text class="col-price">{{row.salePrice}}</text>
                  <text class="col-profit profit-text">{{row.profit}}</text>
                  <text class="col-total">{{row.lineTotal}}</text>
                </view>
              </view>
            </view>
          </view>
        </view>
      </view>

      <view class="empty-state" wx:if="{{paidList.length===0}}">
        <view class="empty-icon">📭</view>
        <text class="empty-text">{{uiText.noPaid}}</text>
      </view>
    </view>

  </view>

  <!-- 收款弹窗 -->
  <view class="pay-modal-mask tap-3d" wx:if="{{showPayModal}}" class="tap-3d" bindtap="cancelPayment"></view>
  <view class="pay-modal" wx:if="{{showPayModal}}">
    <view class="pay-modal-title">确认收款</view>
    <view class="pay-modal-body">
      <text class="pay-modal-label">剩余待付：¥{{payingRemaining}}</text>
      <view class="pay-input-box">
        <text class="pay-input-prefix">¥</text>
        <input type="digit" class="pay-input" value="{{payingAmount}}" bindinput="onPayAmountInput" focus="{{true}}" placeholder="请输入收款金额"></input>
      </view>
    </view>
    <view class="pay-modal-footer">
      <button bindtap="cancelPayment" class="pay-cancel-btn x-tap tap-3d">取消</button>
      <button bindtap="submitPayment" class="pay-confirm-btn x-tap tap-3d">确认收款</button>
    </view>
  </view>

</view>
