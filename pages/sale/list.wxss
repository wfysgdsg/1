.container {
  background: linear-gradient(180deg, #eef6ff, #f7f8fa 220rpx, #f5f5f5 0);
  min-height: 100vh;
  padding: 24rpx 24rpx 160rpx;
}
.filter-bar {
  margin-bottom: 20rpx;
}
.filter-row {
  display: -webkit-flex;
  display: flex;
  gap: 16rpx;
}
.filter-btn,
.picker-btn,
.sort-btn {
  align-items: center;
  background: #fff;
  border-radius: 18rpx;
  box-shadow: 0 8rpx 22rpx rgba(16, 69, 125, 0.06);
  color: #1677d9;
  display: -webkit-inline-flex;
  display: inline-flex;
  font-size: 26rpx;
  min-height: 76rpx;
  padding: 0 24rpx;
}
.summary {
  background: #fff;
  border-radius: 24rpx;
  box-shadow: 0 14rpx 28rpx rgba(0, 0, 0, 0.05);
  display: -webkit-flex;
  display: flex;
  margin-bottom: 20rpx;
  padding: 26rpx 20rpx;
}
.summary-item {
  flex: 1;
  text-align: center;
}
.summary-item .label {
  color: #999;
  display: block;
  font-size: 24rpx;
}
.summary-item .value {
  color: #333;
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  margin-top: 8rpx;
}
.summary-item .value.profit {
  color: #52c41a;
}
.sale-list {
  background: transparent;
  border-radius: 0;
}
.sale-item {
  background: #fff;
  border-bottom: none;
  border-radius: 24rpx;
  box-shadow: 0 12rpx 28rpx rgba(0, 0, 0, 0.045);
  margin-bottom: 18rpx;
  padding: 24rpx 24rpx 20rpx;
}
.sale-header {
  align-items: flex-start;
  display: -webkit-flex;
  display: flex;
  gap: 16rpx;
  justify-content: space-between;
  margin-bottom: 18rpx;
}
.customer-name {
  color: #333;
  flex: 1;
  font-size: 32rpx;
  font-weight: 700;
  line-height: 1.3;
}
.sale-date {
  color: #999;
  font-size: 24rpx;
}
.status-tags {
  align-items: flex-end;
  display: -webkit-flex;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}
.status-tag {
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 600;
  padding: 6rpx 14rpx;
}
.status-tag.unpaid {
  background: #fff2e8;
  color: #ff6b6b;
}
.status-tag.paid {
  background: #f6ffed;
  color: #52c41a;
}
.goods-detail {
  background: #fafafa;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
  padding: 16rpx;
}
.goods-row {
  align-items: center;
  display: -webkit-flex;
  display: flex;
  justify-content: space-between;
  padding: 8rpx 0;
}
.goods-row.header {
  border-bottom: 1rpx dashed #e8e8e8;
  margin-bottom: 8rpx;
  padding-bottom: 12rpx;
}
.goods-row.header text {
  color: #999;
  font-size: 22rpx;
}
.goods-row text {
  color: #333;
  font-size: 24rpx;
}
.goods-row .profit {
  color: #52c41a;
}
.sale-footer {
  align-items: center;
  display: -webkit-flex;
  display: flex;
  justify-content: space-between;
}
.amount-info {
  display: -webkit-flex;
  display: flex;
  flex-direction: column;
}
.amount-info text:first-child {
  color: #333;
  font-size: 28rpx;
  font-weight: 600;
}
.profit-text {
  color: #52c41a;
  font-size: 22rpx;
  margin-top: 4rpx;
}
.action-btns {
  display: -webkit-flex;
  display: flex;
}
.pay-btn {
  background: #1677d9;
  border: none;
  border-radius: 30rpx;
  color: #fff;
  font-size: 24rpx;
  padding: 12rpx 32rpx;
}
.empty {
  padding: 100rpx 50rpx;
  text-align: center;
}
.empty text {
  color: #999;
  font-size: 28rpx;
}
.add-btn {
  align-items: center;
  background: linear-gradient(135deg, #1677d9, #0958d9);
  border-radius: 50rpx;
  bottom: 40rpx;
  box-shadow: 0 10rpx 40rpx rgba(22, 119, 217, 0.4);
  color: #fff;
  display: -webkit-flex;
  display: flex;
  font-size: 32rpx;
  font-weight: 500;
  height: 96rpx;
  justify-content: center;
  left: 50%;
  position: fixed;
  transform: translateX(-50%);
  width: 80%;
}
.add-btn[disabled] {
  opacity: 0.5;
}
/* 分页样式 */
.pagination {
  align-items: center;
  background: #fff;
  display: flex;
  justify-content: center;
  margin: 20rpx 0;
  padding: 20rpx;
  position: fixed;
  bottom: 120rpx;
  left: 0;
  right: 0;
}
.page-btn {
  background: #f5f5f5;
  border: 1rpx solid #ddd;
  border-radius: 8rpx;
  color: #1677d9;
  font-size: 24rpx;
  padding: 10rpx 24rpx;
}
.page-btn[disabled] {
  color: #ccc;
}
.page-info {
  color: #666;
  font-size: 24rpx;
  margin: 0 20rpx;
}