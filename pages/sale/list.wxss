/* ============================================================
   销售列表 — NEXUS-3D
   ============================================================ */

page {
  background: var(--void);
}

.container {
  min-height: 100vh;
  padding-bottom: 200rpx;
}

/* ===== 3D 头部 ===== */
.header-3d {
  position: relative;
  overflow: hidden;
  padding: calc(env(safe-area-inset-top) + 36rpx) 36rpx 36rpx;
  background: linear-gradient(160deg, #1A1244 0%, #0D1024 100%);
  border-bottom-left-radius: 40rpx;
  border-bottom-right-radius: 40rpx;
  transform-style: preserve-3d;
}
.header-bg {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background:
    radial-gradient(circle at 80% 20%, rgba(123,97,255,0.2), transparent 50%),
    radial-gradient(circle at 20% 80%, rgba(255,79,163,0.1), transparent 40%);
  pointer-events: none;
}
.hero-orb {
  position: absolute;
  border-radius: 50%;
  pointer-events: none;
}
.hero-orb.a {
  width: 260rpx; height: 260rpx;
  top: -80rpx; right: -60rpx;
  background: radial-gradient(circle, rgba(123,97,255,0.2), transparent 70%);
  animation: nexus-breathe 4s ease-in-out infinite;
}
.hero-orb.b {
  width: 160rpx; height: 160rpx;
  bottom: -40rpx; left: -30rpx;
  background: radial-gradient(circle, rgba(255,79,163,0.12), transparent 70%);
  animation: nexus-breathe 5s ease-in-out infinite;
  animation-delay: -2s;
}
.header-top {
  position: relative;
  z-index: 2;
  margin-bottom: 24rpx;
}
.page-title {
  display: block;
  font-size: 44rpx;
  font-weight: 800;
  color: var(--text-primary);
  letter-spacing: 1rpx;
}
.page-sub {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: rgba(255,255,255,0.35);
}

/* ===== 3D 状态标签 ===== */
.status-tabs-3d {
  position: relative;
  z-index: 2;
  display: flex;
  gap: 12rpx;
}
.status-tab {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 0;
  border-radius: var(--r-md);
  background: rgba(255,255,255,0.04);
  border: 1rpx solid rgba(255,255,255,0.06);
  position: relative;
  overflow: hidden;
  transition: all 0.3s var(--ease-spring);
}
.status-tab.active {
  transform: translateY(-4rpx);
}
.status-tab.active.unpaid {
  background: rgba(255,107,107,0.1);
  border-color: rgba(255,107,107,0.2);
  box-shadow: 0 8rpx 24rpx rgba(255,107,107,0.15);
}
.status-tab.active.paid {
  background: rgba(0,245,160,0.1);
  border-color: rgba(0,245,160,0.2);
  box-shadow: 0 8rpx 24rpx rgba(0,245,160,0.15);
}
.status-tab.active.voided {
  background: rgba(255,255,255,0.08);
  border-color: rgba(255,255,255,0.12);
}
.tab-glow {
  position: absolute;
  top: 50%; left: 50%;
  transform: translate(-50%, -50%);
  width: 100rpx; height: 100rpx;
  border-radius: 50%;
  filter: blur(20rpx);
  opacity: 0.2;
}
.tab-glow.coral { background: var(--neon-coral); }
.tab-glow.mint { background: var(--neon-mint); }
.tab-glow.neutral { background: rgba(255,255,255,0.5); }
.status-count {
  position: relative;
  z-index: 1;
  font-size: 40rpx;
  font-weight: 800;
  color: var(--text-primary);
}
.active.unpaid .status-count { color: var(--neon-coral); }
.active.paid .status-count { color: var(--neon-mint); }
.status-label {
  position: relative;
  z-index: 1;
  font-size: 22rpx;
  color: rgba(255,255,255,0.4);
  margin-top: 4rpx;
}

/* ===== 搜索栏 ===== */
.search-section {
  padding: 24rpx 28rpx 0;
}
.search {
  display: flex;
  align-items: center;
  height: 80rpx;
  padding: 0 24rpx;
  border-radius: var(--pill);
  background: rgba(255,255,255,0.04);
  border: 1rpx solid rgba(255,255,255,0.06);
  backdrop-filter: blur(20rpx);
}
.search-ico {
  font-size: 28rpx;
  margin-right: 12rpx;
}
.search-inp {
  flex: 1;
  height: 80rpx;
  font-size: 26rpx;
  color: var(--text-primary);
  background: transparent;
  border: none;
  padding: 0;
  border-radius: 0;
}
.search-ph {
  color: rgba(255,255,255,0.2);
}

/* ===== 销售卡片 ===== */
.sale-list {
  padding: 20rpx 28rpx;
}
.sale-card {
  position: relative;
  background: rgba(255,255,255,0.035);
  backdrop-filter: blur(20rpx);
  border: 1rpx solid rgba(255,255,255,0.06);
  border-radius: var(--r-lg);
  padding: 28rpx;
  margin-bottom: 16rpx;
  overflow: hidden;
  transform-style: preserve-3d;
}
.sale-card-glow {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background: linear-gradient(135deg, rgba(123,97,255,0.03), transparent 50%);
  pointer-events: none;
}

/* 卡片头部 */
.sale-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
  position: relative;
  z-index: 1;
}
.sale-customer {
  display: flex;
  align-items: center;
}
.customer-avatar {
  width: 64rpx; height: 64rpx;
  border-radius: 18rpx;
  background: linear-gradient(135deg, rgba(123,97,255,0.2), rgba(0,212,255,0.1));
  border: 1rpx solid rgba(255,255,255,0.08);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-primary);
}
.sale-customer-info {
  display: flex;
  flex-direction: column;
}
.customer-name {
  color: var(--text-primary);
  font-size: 30rpx;
  font-weight: 600;
}
.sale-date {
  color: rgba(255,255,255,0.3);
  font-size: 22rpx;
  margin-top: 4rpx;
}

/* 状态徽章 */
.status-badge {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 18rpx;
  border-radius: var(--pill);
  font-size: 22rpx;
  font-weight: 600;
}
.status-badge.unpaid {
  background: rgba(255,107,107,0.1);
  color: var(--neon-coral);
  border: 1rpx solid rgba(255,107,107,0.15);
}
.status-badge.paid {
  background: rgba(0,245,160,0.1);
  color: var(--neon-mint);
  border: 1rpx solid rgba(0,245,160,0.15);
}
.status-badge.voided {
  background: rgba(255,255,255,0.06);
  color: rgba(255,255,255,0.4);
  border: 1rpx solid rgba(255,255,255,0.08);
}
.badge-dot {
  width: 10rpx; height: 10rpx;
  border-radius: 50%;
  background: currentColor;
  box-shadow: 0 0 6rpx currentColor;
}

/* 卡片内容 */
.sale-body {
  position: relative;
  z-index: 1;
}
.goods-summary {
  display: flex;
  flex-direction: column;
  margin-bottom: 16rpx;
}
.goods-count {
  color: rgba(255,255,255,0.4);
  font-size: 22rpx;
}
.goods-preview {
  color: rgba(255,255,255,0.6);
  font-size: 24rpx;
  margin-top: 6rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 1;
}
.amount-row {
  display: flex;
  gap: 32rpx;
  padding: 20rpx 0;
  border-top: 1rpx solid rgba(255,255,255,0.04);
}
.amount-block {
  display: flex;
  flex-direction: column;
}
.amount-label {
  color: rgba(255,255,255,0.3);
  font-size: 20rpx;
  letter-spacing: 1rpx;
}
.amount-val {
  font-size: 30rpx;
  font-weight: 700;
  margin-top: 4rpx;
}
.amount-val.total { color: var(--text-primary); }
.amount-val.paid { color: var(--neon-mint); }
.amount-val.unpaid {
  color: var(--neon-coral);
  text-shadow: 0 0 8rpx rgba(255,107,107,0.2);
}

/* 卡片操作 */
.sale-actions {
  display: flex;
  gap: 12rpx;
  margin-top: 16rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid rgba(255,255,255,0.04);
  position: relative;
  z-index: 1;
}
.act-btn {
  flex: 1;
  font-size: 24rpx;
  padding: 16rpx 0;
  border-radius: var(--pill);
  border: 1rpx solid rgba(255,255,255,0.06);
  line-height: 1.2;
  margin: 0;
}
.act-btn::after {
  border: none;
}
.act-btn.pay {
  background: rgba(0,245,160,0.1);
  color: var(--neon-mint);
  border-color: rgba(0,245,160,0.15);
}
.act-btn.view {
  background: rgba(0,212,255,0.08);
  color: var(--neon-blue);
  border-color: rgba(0,212,255,0.12);
}
.act-btn.delivery {
  background: rgba(123,97,255,0.08);
  color: var(--neon-violet);
  border-color: rgba(123,97,255,0.12);
}

/* ===== 空状态 ===== */
.empty {
  padding: 60rpx 0;
}

/* ===== 分页 ===== */
.pagination {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  padding: 16rpx 28rpx;
  margin-top: 10rpx;
}
.page-btn {
  background: rgba(255,255,255,0.05);
  border: 1rpx solid rgba(255,255,255,0.08);
  border-radius: var(--pill);
  color: var(--text-primary);
  font-size: 24rpx;
  padding: 14rpx 32rpx;
  line-height: 1.2;
}
.page-btn[disabled] {
  opacity: 0.3;
}
.page-info {
  color: rgba(255,255,255,0.35);
  font-size: 24rpx;
}

/* ===== 悬浮按钮 ===== */
.fab {
  position: fixed;
  bottom: calc(40rpx + env(safe-area-inset-bottom));
  left: 10%;
  width: 80%;
  height: 96rpx;
  background: linear-gradient(135deg, #7B61FF, #00D4FF);
  border-radius: 48rpx;
  box-shadow: 0 12rpx 40rpx rgba(123,97,255,0.35);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  animation: nexus-pulse-glow 2.5s ease-in-out infinite;
}
.fab-glow {
  position: absolute;
  top: 0; left: -50%;
  width: 50%; height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.2), transparent);
  animation: nexus-shine 3s ease-in-out infinite;
}
.fab-text {
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  position: relative;
  z-index: 1;
}
.fab:active {
  transform: scale(0.96);
  transition: transform 0.15s var(--ease-spring);
}

/* ===== 收款弹窗 ===== */
.pay-modal-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(6,8,24,0.7);
  backdrop-filter: blur(8rpx);
  z-index: 100;
  animation: nexus-fade-in 0.3s ease-out;
}
.pay-modal {
  position: fixed;
  bottom: 0;
  left: 0; right: 0;
  background: rgba(18,21,48,0.95);
  backdrop-filter: blur(40rpx);
  border: 1rpx solid rgba(255,255,255,0.1);
  border-bottom: none;
  border-top-left-radius: 48rpx;
  border-top-right-radius: 48rpx;
  padding: 40rpx 36rpx calc(40rpx + env(safe-area-inset-bottom));
  z-index: 101;
  animation: nexus-slide-up 0.4s var(--ease-spring);
  overflow: hidden;
}
.pay-modal-glow {
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 200rpx;
  background: radial-gradient(ellipse at center top, rgba(0,245,160,0.1), transparent 70%);
  pointer-events: none;
}
.pay-modal-title {
  text-align: center;
  color: var(--text-primary);
  font-size: 32rpx;
  font-weight: 700;
  position: relative;
  z-index: 1;
}
.pay-amount-display {
  display: flex;
  align-items: baseline;
  justify-content: center;
  margin: 32rpx 0;
  position: relative;
  z-index: 1;
}
.pay-currency {
  color: var(--neon-mint);
  font-size: 36rpx;
  font-weight: 700;
}
.pay-amount {
  color: var(--neon-mint);
  font-size: 64rpx;
  font-weight: 800;
  text-shadow: 0 0 24rpx rgba(0,245,160,0.3);
}
.pay-input-wrapper {
  margin-bottom: 32rpx;
  position: relative;
  z-index: 1;
}
.pay-input {
  background: rgba(255,255,255,0.05);
  border: 1rpx solid rgba(255,255,255,0.1);
  border-radius: var(--r-md);
  padding: 24rpx 28rpx;
  font-size: 32rpx;
  color: var(--text-primary);
  text-align: center;
}
.pay-ph {
  color: rgba(255,255,255,0.2);
}
.pay-modal-actions {
  display: flex;
  gap: 16rpx;
  position: relative;
  z-index: 1;
}
.pay-btn {
  flex: 1;
  font-size: 30rpx;
  padding: 24rpx 0;
  border-radius: var(--r-md);
  line-height: 1.2;
}
.pay-btn::after {
  border: none;
}
.pay-btn.cancel {
  background: rgba(255,255,255,0.05);
  color: rgba(255,255,255,0.5);
  border: 1rpx solid rgba(255,255,255,0.08);
}
.pay-btn.confirm {
  background: linear-gradient(135deg, #00F5A0, #00D4FF);
  color: #060818;
  font-weight: 700;
  box-shadow: 0 8rpx 24rpx rgba(0,245,160,0.3);
}
