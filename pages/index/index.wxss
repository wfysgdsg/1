/* ============================================================
   首页 — NEXUS-3D 前卫设计
   ============================================================ */

page {
  background: var(--void);
}

.container {
  padding-bottom: 60rpx;
  overflow: hidden;
}

/* ===== 背景光晕 ===== */
.bg-orb-a {
  background: linear-gradient(135deg, #7B61FF, #00D4FF);
  width: 500rpx; height: 500rpx;
  right: -200rpx; top: -200rpx;
  opacity: 0.25;
  animation: nexus-float 12s ease-in-out infinite;
}
.bg-orb-b {
  background: linear-gradient(135deg, #FF4FA3, #7B61FF);
  width: 360rpx; height: 360rpx;
  left: -150rpx; top: 600rpx;
  opacity: 0.15;
  animation: nexus-float 10s ease-in-out infinite;
  animation-delay: -5s;
}

/* ===== 3D 头部 ===== */
.header-3d {
  position: relative;
  overflow: hidden;
  padding: calc(env(safe-area-inset-top) + 40rpx) 40rpx 100rpx;
  background: linear-gradient(160deg, #1A1244 0%, #0D1024 100%);
  border-bottom-left-radius: 48rpx;
  border-bottom-right-radius: 48rpx;
  transform-style: preserve-3d;
}
.header-bg {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background:
    radial-gradient(circle at 80% 20%, rgba(123,97,255,0.25), transparent 50%),
    radial-gradient(circle at 20% 80%, rgba(0,212,255,0.12), transparent 40%);
  pointer-events: none;
}
.header-orb-1 {
  position: absolute;
  width: 300rpx; height: 300rpx;
  top: -100rpx; right: -80rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(123,97,255,0.2), transparent 70%);
  animation: nexus-breathe 4s ease-in-out infinite;
}
.header-orb-2 {
  position: absolute;
  width: 180rpx; height: 180rpx;
  bottom: 20rpx; left: -40rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(0,212,255,0.15), transparent 70%);
  animation: nexus-breathe 5s ease-in-out infinite;
  animation-delay: -2s;
}
.user-info {
  position: relative;
  z-index: 2;
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.welcome-box {
  display: flex;
  flex-direction: column;
}
.greeting {
  color: var(--text-primary);
  font-size: 42rpx;
  font-weight: 800;
  letter-spacing: 1rpx;
}
.date {
  color: rgba(255,255,255,0.45);
  font-size: 24rpx;
  margin-top: 10rpx;
}
.profile-entry {
  position: relative;
  width: 80rpx; height: 80rpx;
  border-radius: 50%;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255,255,255,0.08);
  border: 2rpx solid rgba(255,255,255,0.12);
  backdrop-filter: blur(20rpx);
}
.profile-avatar {
  width: 100%; height: 100%;
}
.profile-icon {
  color: #fff;
  font-size: 28rpx;
  font-weight: 700;
}
.profile-ring {
  position: absolute;
  top: -4rpx; left: -4rpx; right: -4rpx; bottom: -4rpx;
  border: 2rpx solid transparent;
  border-top-color: var(--neon-violet);
  border-radius: 50%;
  animation: nexus-spin 3s linear infinite;
  opacity: 0.6;
}

/* ===== 3D 统计卡片 ===== */
.stats-3d {
  position: relative;
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, rgba(26,30,79,0.9), rgba(18,21,48,0.9));
  backdrop-filter: blur(30rpx);
  border: 1rpx solid rgba(255,255,255,0.08);
  border-radius: var(--r-xl);
  margin: -70rpx 32rpx 0;
  padding: 36rpx 32rpx;
  box-shadow: 0 20rpx 50rpx rgba(0,0,0,0.4);
  transform-style: preserve-3d;
}
.stats-glow {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  border-radius: var(--r-xl);
  background: linear-gradient(135deg, rgba(123,97,255,0.06), transparent 50%);
  pointer-events: none;
}
.stat-main {
  flex: 1.2;
  display: flex;
  flex-direction: column;
}
.stat-val {
  color: var(--neon-blue);
  font-size: 48rpx;
  font-weight: 800;
  line-height: 1;
  text-shadow: 0 0 20rpx rgba(0,212,255,0.3);
}
.stat-lab {
  color: rgba(255,255,255,0.45);
  font-size: 22rpx;
  margin-top: 12rpx;
  letter-spacing: 1rpx;
}
.stat-divider {
  background: rgba(255,255,255,0.08);
  height: 80rpx;
  width: 1rpx;
  margin: 0 24rpx;
}
.stat-side {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  height: 90rpx;
}
.stat-mini {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.mini-val {
  color: var(--text-primary);
  font-size: 30rpx;
  font-weight: 700;
}
.mini-val.danger {
  color: var(--neon-coral);
  text-shadow: 0 0 12rpx rgba(255,107,107,0.4);
}
.mini-val.mint {
  color: var(--neon-mint);
  text-shadow: 0 0 12rpx rgba(0,245,160,0.3);
}
.mini-lab {
  color: rgba(255,255,255,0.35);
  font-size: 22rpx;
}

/* ===== 网格统计 ===== */
.grid-stats {
  display: flex;
  background: rgba(255,255,255,0.03);
  backdrop-filter: blur(20rpx);
  border: 1rpx solid rgba(255,255,255,0.06);
  border-radius: var(--r-lg);
  margin: 20rpx 32rpx;
  padding: 28rpx 0;
}
.grid-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  border-right: 1rpx solid rgba(255,255,255,0.04);
  position: relative;
}
.grid-item:last-child {
  border-right: none;
}
.grid-icon-wrap {
  width: 56rpx; height: 56rpx;
  margin-bottom: 12rpx;
  position: relative;
}
.grid-icon-orb {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  border-radius: 50%;
  opacity: 0.2;
}
.grid-icon-orb.violet {
  background: radial-gradient(circle, var(--neon-violet), transparent);
  box-shadow: 0 0 16rpx rgba(123,97,255,0.3);
}
.grid-icon-orb.amber {
  background: radial-gradient(circle, var(--neon-amber), transparent);
  box-shadow: 0 0 16rpx rgba(255,184,0,0.3);
}
.grid-icon-orb.blue {
  background: radial-gradient(circle, var(--neon-blue), transparent);
  box-shadow: 0 0 16rpx rgba(0,212,255,0.3);
}
.grid-num {
  color: var(--text-primary);
  font-size: 40rpx;
  font-weight: 800;
}
.grid-label {
  color: rgba(255,255,255,0.35);
  font-size: 22rpx;
  margin-top: 4rpx;
}

/* ===== 提醒条 ===== */
.alert-bar {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 0 32rpx 12rpx;
  padding: 22rpx 26rpx;
  background: rgba(255,107,107,0.08);
  border: 1rpx solid rgba(255,107,107,0.15);
  border-radius: var(--r-md);
  overflow: hidden;
}
.alert-bar.amber-bar {
  background: rgba(255,184,0,0.08);
  border-color: rgba(255,184,0,0.15);
}
.alert-glow {
  position: absolute;
  top: 50%; left: 0;
  transform: translateY(-50%);
  width: 80rpx; height: 80rpx;
  border-radius: 50%;
  filter: blur(20rpx);
  opacity: 0.3;
}
.alert-glow.coral {
  background: var(--neon-coral);
}
.alert-glow.amber {
  background: var(--neon-amber);
}
.alert-content {
  flex: 1;
  padding-left: 20rpx;
}
.alert-text {
  color: var(--neon-coral);
  font-size: 24rpx;
}
.amber-bar .alert-text {
  color: var(--neon-amber);
}
.alert-btn {
  color: var(--neon-coral);
  font-size: 24rpx;
  font-weight: 600;
}
.amber-bar .alert-btn {
  color: var(--neon-amber);
}

/* ===== 区块标题 ===== */
.section-title {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin: 38rpx 32rpx 18rpx;
}
.section-title text:first-child {
  color: var(--text-primary);
  font-size: 32rpx;
  font-weight: 800;
}
.title-tip {
  color: rgba(255,255,255,0.35);
  font-size: 22rpx;
}

/* ===== 操作卡片 ===== */
.action-grid {
  padding: 0 32rpx;
}
.action-card {
  position: relative;
  display: flex;
  align-items: center;
  padding: 36rpx 32rpx;
  border-radius: var(--r-xl);
  margin-bottom: 16rpx;
  overflow: hidden;
  border: 1rpx solid rgba(255,255,255,0.08);
}
.card-glow {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  pointer-events: none;
}
.action-violet {
  background: linear-gradient(135deg, rgba(123,97,255,0.15) 0%, rgba(123,97,255,0.05) 100%);
}
.action-violet .card-glow {
  background: radial-gradient(circle at 80% 50%, rgba(123,97,255,0.15), transparent 60%);
}
.action-coral {
  background: linear-gradient(135deg, rgba(255,107,107,0.15) 0%, rgba(255,79,163,0.05) 100%);
}
.action-coral .card-glow {
  background: radial-gradient(circle at 80% 50%, rgba(255,107,107,0.15), transparent 60%);
}
.card-content {
  flex: 1;
  display: flex;
  flex-direction: column;
}
.action-title {
  color: var(--text-primary);
  font-size: 34rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
}
.action-desc {
  color: rgba(255,255,255,0.4);
  font-size: 24rpx;
}
.card-arrow {
  color: rgba(255,255,255,0.3);
  font-size: 36rpx;
  margin-left: 16rpx;
}

/* ===== 迷你操作行 ===== */
.mini-action-row {
  display: flex;
  justify-content: space-between;
  margin-top: 20rpx;
  padding: 8rpx 0;
}
.mini-action {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}
.mini-icon {
  position: relative;
  width: 88rpx; height: 88rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 10rpx;
  overflow: hidden;
  border: 1rpx solid rgba(255,255,255,0.06);
}
.mini-icon-glow {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  opacity: 0.15;
  border-radius: 24rpx;
}
.mini-icon-glow.coral {
  background: radial-gradient(circle, var(--neon-coral), transparent);
}
.mini-icon-glow.mint {
  background: radial-gradient(circle, var(--neon-mint), transparent);
}
.mini-icon-glow.violet {
  background: radial-gradient(circle, var(--neon-violet), transparent);
}
.mini-icon-glow.blue {
  background: radial-gradient(circle, var(--neon-blue), transparent);
}
.coral-bg { background: rgba(255,107,107,0.08); }
.mint-bg { background: rgba(0,245,160,0.08); }
.violet-bg { background: rgba(123,97,255,0.08); }
.blue-bg { background: rgba(0,212,255,0.08); }
.mini-icon text {
  position: relative;
  z-index: 1;
  color: var(--text-primary);
  font-size: 30rpx;
  font-weight: 700;
}
.mini-text {
  color: rgba(255,255,255,0.5);
  font-size: 22rpx;
}
.mini-badge {
  position: absolute;
  top: -4rpx; right: 50%;
  transform: translateX(40rpx);
  background: var(--neon-coral);
  color: #fff;
  font-size: 18rpx;
  min-width: 30rpx;
  height: 30rpx;
  line-height: 30rpx;
  text-align: center;
  border-radius: var(--pill);
  padding: 0 8rpx;
  box-shadow: 0 0 12rpx rgba(255,107,107,0.4);
}

/* ===== 应收账款卡片 ===== */
.receivable-panel {
  padding: 0 32rpx;
}
.receivable-card {
  position: relative;
  background: rgba(255,255,255,0.03);
  backdrop-filter: blur(20rpx);
  border: 1rpx solid rgba(255,255,255,0.06);
  border-radius: var(--r-lg);
  margin-bottom: 16rpx;
  overflow: hidden;
}
.receivable-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 28rpx;
}
.receivable-left {
  display: flex;
  flex-direction: column;
}
.receivable-name {
  color: var(--text-primary);
  font-size: 30rpx;
  font-weight: 600;
}
.receivable-meta {
  color: rgba(255,255,255,0.35);
  font-size: 22rpx;
  margin-top: 6rpx;
}
.receivable-right {
  display: flex;
  align-items: center;
}
.receivable-amount {
  color: var(--neon-coral);
  font-size: 34rpx;
  font-weight: 700;
  text-shadow: 0 0 12rpx rgba(255,107,107,0.2);
}
.receivable-arrow {
  color: rgba(255,255,255,0.3);
  font-size: 24rpx;
  margin-left: 16rpx;
}
.receivable-body {
  max-height: 0;
  overflow: hidden;
  transition: max-height 0.5s var(--ease-expo);
}
.receivable-body.expanded {
  max-height: 3000rpx;
}
.receivable-order {
  padding: 20rpx 28rpx;
  border-top: 1rpx solid rgba(255,255,255,0.04);
}
.order-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}
.order-date {
  color: rgba(255,255,255,0.5);
  font-size: 24rpx;
}
.order-total {
  color: var(--neon-amber);
  font-size: 26rpx;
  font-weight: 600;
}
.order-total.partial {
  color: var(--neon-coral);
}
.goods-table {
  width: 100%;
}
.goods-table-head {
  display: flex;
  padding: 12rpx 0;
  border-bottom: 1rpx solid rgba(255,255,255,0.06);
}
.goods-table-head text {
  flex: 1;
  color: rgba(255,255,255,0.3);
  font-size: 20rpx;
  text-align: center;
}
.goods-table-row {
  display: flex;
  padding: 12rpx 0;
}
.goods-table-row text {
  flex: 1;
  color: rgba(255,255,255,0.6);
  font-size: 22rpx;
  text-align: center;
}
.profit-cell {
  color: var(--neon-mint) !important;
}
.receivable-empty {
  padding: 0 32rpx;
}
