/* 首页 — 3D + Spring 动画增强版 */
page {
  background-color: #f7f8fa;
}
.container {
  padding-bottom: 60rpx;
}

/* ========================================
   3D 视差头部
   ======================================== */
.header-banner {
  position: relative;
  background: radial-gradient(
      circle at top right,
      hsla(0, 0%, 100%, 0.22),
      transparent 28%
    ),
    linear-gradient(180deg, #4F6EF7, #6C5CE7);
  background-size: 200% 200%;
  border-bottom-left-radius: 64rpx;
  border-bottom-right-radius: 64rpx;
  min-height: 300rpx;
  padding: 42rpx 40rpx 96rpx;
  overflow: hidden;
  animation: gradientShift 8s ease infinite;
}

/* 3D 背景层 — 深度光球 */
.header-bg-3d {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  transform-style: preserve-3d;
  pointer-events: none;
}
.header-orb {
  position: absolute;
  border-radius: 50%;
  filter: blur(40rpx);
}
.header-orb-1 {
  width: 300rpx; height: 300rpx;
  top: -80rpx; right: -60rpx;
  background: radial-gradient(circle, rgba(255,255,255,0.2), transparent 70%);
  animation: headerOrbFloat1 7s ease-in-out infinite;
}
.header-orb-2 {
  width: 200rpx; height: 200rpx;
  bottom: -40rpx; left: 40rpx;
  background: radial-gradient(circle, rgba(108,92,231,0.25), transparent 70%);
  animation: headerOrbFloat2 9s ease-in-out infinite;
}
@keyframes headerOrbFloat1 {
  0%, 100% { transform: translate3d(0, 0, 0) scale(1); }
  50% { transform: translate3d(-20rpx, 15rpx, 30rpx) scale(1.1); }
}
@keyframes headerOrbFloat2 {
  0%, 100% { transform: translate3d(0, 0, 0) scale(1); }
  50% { transform: translate3d(25rpx, -10rpx, 20rpx) scale(1.08); }
}

/* 网格纹理 */
.header-mesh {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background-image:
    linear-gradient(rgba(255,255,255,.04) 1px, transparent 1px),
    linear-gradient(90deg, rgba(255,255,255,.04) 1px, transparent 1px);
  background-size: 80rpx 80rpx;
  opacity: 0.6;
}

.user-info {
  align-items: center;
  justify-content: space-between;
  position: relative;
  z-index: 2;
}
.user-info,
.welcome-box {
  display: flex;
}
.welcome-box {
  flex-direction: column;
}
.greeting {
  color: #fff;
  font-size: 40rpx;
  font-weight: 700;
  text-shadow: 0 2rpx 12rpx rgba(0,0,0,0.1);
}
.date {
  color: hsla(0, 0%, 100%, 0.82);
  font-size: 24rpx;
  margin-top: 10rpx;
}

/* 头像入口 — 3D 浮起 */
.profile-entry {
  align-items: center;
  background: hsla(0, 0%, 100%, 0.22);
  backdrop-filter: blur(10rpx);
  border: 2rpx solid hsla(0, 0%, 100%, 0.3);
  border-radius: 50%;
  display: flex;
  height: 80rpx;
  justify-content: center;
  overflow: hidden;
  width: 80rpx;
  transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1), box-shadow 0.3s ease;
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.1);
}
.profile-entry:active {
  transform: scale(0.92) translateZ(20rpx);
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.15);
}
.profile-avatar {
  width: 100%;
  height: 100%;
}
.profile-icon {
  color: #fff;
  font-size: 28rpx;
  font-weight: 700;
}

/* ========================================
   3D 统计主卡 — 浮在头部上方
   ======================================== */
.scene-3d-near {
  perspective: 800rpx;
  perspective-origin: center top;
}

.stats-card {
  align-items: center;
  background: #fff;
  border-radius: 32rpx;
  box-shadow:
    0 18rpx 44rpx rgba(21, 93, 165, 0.1),
    0 4rpx 12rpx rgba(21, 93, 165, 0.06),
    inset 0 2rpx 8rpx rgba(255,255,255,0.5);
  margin: -88rpx 32rpx 0;
  padding: 34rpx 32rpx;
  position: relative;
  overflow: hidden;
  transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1), box-shadow 0.3s ease;
  transform-style: preserve-3d;
}
.stats-card:active {
  transform: scale(0.97) translateZ(20rpx);
  box-shadow:
    0 12rpx 30rpx rgba(21, 93, 165, 0.08),
    0 2rpx 8rpx rgba(21, 93, 165, 0.04);
}

/* 卡片顶部光泽 */
.stats-card-glow {
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 4rpx;
  background: linear-gradient(90deg, transparent, #4F6EF7, #6C5CE7, #4F6EF7, transparent);
  background-size: 200% 100%;
  animation: gradientShift 4s linear infinite;
}

.stat-main,
.stats-card {
  display: flex;
}
.stat-main {
  flex: 1.2;
  flex-direction: column;
}
.stat-val {
  color: #4F6EF7;
  font-size: 54rpx;
  font-weight: 700;
  line-height: 1;
  text-shadow: 0 2rpx 8rpx rgba(79,110,247,0.15);
}
.stat-lab {
  color: #8c8c8c;
  font-size: 24rpx;
  margin-top: 14rpx;
  letter-spacing: 1rpx;
}
.stat-divider {
  background: linear-gradient(180deg, transparent, #f0f0f0, transparent);
  height: 92rpx;
  margin: 0 24rpx;
  width: 1rpx;
}
.stat-side {
  flex: 1;
  flex-direction: column;
  height: 100rpx;
}
.stat-mini,
.stat-side {
  display: flex;
  justify-content: space-between;
}
.stat-mini {
  align-items: center;
}
.mini-val {
  color: #262626;
  font-size: 30rpx;
  font-weight: 600;
}
.mini-lab {
  color: #8c8c8c;
  font-size: 22rpx;
  margin-top: 4rpx;
}

/* ========================================
   网格统计 — 3D 翻转入场
   ======================================== */
.grid-stats {
  background: #fff;
  border-radius: 24rpx;
  box-shadow: 0 10rpx 28rpx rgba(0, 0, 0, 0.04), 0 2rpx 8rpx rgba(0,0,0,0.02);
  margin: 24rpx 32rpx;
  padding: 28rpx 0;
}
.grid-item,
.grid-stats {
  display: flex;
}
.grid-item {
  align-items: center;
  border-right: 1rpx solid #f5f5f5;
  flex: 1;
  flex-direction: column;
  transition: transform 0.25s cubic-bezier(0.34, 1.56, 0.64, 1);
}
.grid-item:active {
  transform: scale(0.9) translateZ(30rpx);
}
.grid-item:last-child {
  border-right: none;
}
.grid-num {
  color: #262626;
  font-size: 40rpx;
  font-weight: 700;
}
.grid-label {
  color: #8c8c8c;
  font-size: 22rpx;
  margin-top: 6rpx;
}

/* ========================================
   提醒条 — Spring 深度滑入
   ======================================== */
.alert-bar {
  align-items: center;
  background: #fff1f0;
  border: none;
  border-left: 8rpx solid #ff4d4f;
  border-radius: 0 18rpx 18rpx 0;
  box-shadow: 0 4rpx 16rpx rgba(255, 77, 79, 0.08);
  display: flex;
  justify-content: space-between;
  margin: 0 32rpx 12rpx;
  padding: 20rpx 24rpx;
  transition: transform 0.2s cubic-bezier(0.34, 1.56, 0.64, 1);
}
.alert-bar:active {
  transform: scale(0.97) translateX(8rpx);
}
.alert-bar.overdue-alert {
  background: #fff7e6;
  border-left-color: #fa8c16;
  box-shadow: 0 4rpx 16rpx rgba(250, 140, 22, 0.08);
}
.alert-bar.overdue-alert .alert-text,
.alert-bar.overdue-alert .alert-btn {
  color: #fa8c16;
}
.alert-btn,
.alert-text {
  color: #f5222d;
  font-size: 24rpx;
}

/* ========================================
   区块标题
   ======================================== */
.section-title {
  align-items: baseline;
  display: flex;
  justify-content: space-between;
  margin: 38rpx 32rpx 18rpx;
}
.section-title text:first-child {
  color: #262626;
  font-size: 32rpx;
  font-weight: 700;
}
.title-tip {
  color: #8c8c8c;
  font-size: 22rpx;
}

/* ========================================
   操作卡片 — 3D 透视倾斜
   ======================================== */
.action-grid {
  padding: 0 32rpx;
}

.scene-3d {
  perspective: 1000rpx;
  margin-bottom: 18rpx;
}

.action-card {
  border-radius: 28rpx;
  box-shadow:
    0 14rpx 30rpx rgba(0, 0, 0, 0.08),
    0 4rpx 10rpx rgba(0,0,0,0.04);
  box-sizing: border-box;
  display: flex;
  align-items: center;
  min-height: 158rpx;
  overflow: hidden;
  padding: 30rpx 32rpx;
  position: relative;
  width: 100%;
  transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1), box-shadow 0.3s ease;
  transform-style: preserve-3d;
}
.action-card:active {
  transform: scale(0.96) translateZ(40rpx) rotateX(-3deg);
  box-shadow:
    0 8rpx 20rpx rgba(0, 0, 0, 0.06),
    0 2rpx 6rpx rgba(0,0,0,0.03);
}

.action-card-blue {
  background: linear-gradient(135deg, #4F6EF7 0%, #3D56D4 100%);
  background-size: 200% 200%;
}
.action-card-orange {
  background: linear-gradient(135deg, #FF9C6E 0%, #FF7A45 100%);
  background-size: 200% 200%;
}

/* 背景装饰圆 — 3D 深度 */
.action-card-bg {
  position: absolute;
  right: -30rpx; bottom: -30rpx;
  width: 180rpx; height: 180rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.08);
  pointer-events: none;
  transform: translateZ(-10rpx);
}
.action-card-bg::after {
  content: '';
  position: absolute;
  right: 60rpx; bottom: -60rpx;
  width: 240rpx; height: 240rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.05);
}

.action-card-content {
  flex: 1;
  position: relative;
  z-index: 2;
  display: flex;
  flex-direction: column;
}
.action-title {
  color: #fff;
  font-size: 32rpx;
  font-weight: 700;
  text-shadow: 0 2rpx 6rpx rgba(0,0,0,0.1);
}
.action-desc {
  color: hsla(0, 0%, 100%, 0.84);
  font-size: 22rpx;
  margin-top: 8rpx;
}

/* 箭头 — 3D 悬浮 */
.action-card-arrow {
  color: hsla(0, 0%, 100%, 0.6);
  font-size: 40rpx;
  font-weight: 200;
  position: relative;
  z-index: 2;
  transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
}
.action-card:active .action-card-arrow {
  transform: translateX(10rpx) translateZ(30rpx);
}

/* ========================================
   迷你操作行 — 3D 浮起
   ======================================== */
.mini-action-row {
  display: grid;
  gap: 16rpx;
  grid-template-columns: repeat(4, 1fr);
  margin-top: 8rpx;
}
.mini-action {
  background: #fff;
  border-radius: 22rpx;
  box-shadow: 0 8rpx 20rpx rgba(0, 0, 0, 0.035), 0 2rpx 6rpx rgba(0,0,0,0.02);
  flex-direction: column;
  padding: 24rpx 10rpx 18rpx;
  position: relative;
  transition: transform 0.25s cubic-bezier(0.34, 1.56, 0.64, 1), box-shadow 0.25s ease;
  transform-style: preserve-3d;
}
.mini-action:active {
  transform: scale(0.93) translateZ(30rpx);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.03);
}
.mini-action,
.mini-icon {
  align-items: center;
  display: flex;
}
.mini-icon {
  border-radius: 26rpx;
  color: #262626;
  font-size: 28rpx;
  font-weight: 700;
  height: 90rpx;
  justify-content: center;
  margin-bottom: 12rpx;
  width: 90rpx;
  transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
}
.mini-action:active .mini-icon {
  transform: scale(1.1) translateZ(20rpx);
}
.mini-action text {
  color: #595959;
  font-size: 24rpx;
  line-height: 1.3;
  text-align: center;
}
.mini-badge {
  background: #ff4d4f;
  border: 2rpx solid #fff;
  border-radius: 20rpx;
  color: #fff;
  font-size: 20rpx;
  padding: 2rpx 10rpx;
  position: absolute;
  right: 10rpx;
  top: -6rpx;
  box-shadow: 0 4rpx 10rpx rgba(255,77,79,0.3);
  animation: badgePulse 2s ease-in-out infinite;
}
@keyframes badgePulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.08); }
}

/* ========================================
   应收款面板
   ======================================== */
.receivable-title {
  margin-top: 42rpx;
}
.receivable-panel {
  padding: 0 32rpx;
}
.receivable-card {
  background: #fff;
  border-radius: 24rpx;
  box-shadow: 0 12rpx 30rpx rgba(0, 0, 0, 0.045), 0 4rpx 10rpx rgba(0,0,0,0.02);
  margin-bottom: 16rpx;
  overflow: hidden;
  transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1), box-shadow 0.3s ease;
}
.receivable-card:active {
  transform: scale(0.97) translateZ(20rpx);
  box-shadow: 0 8rpx 20rpx rgba(0, 0, 0, 0.03);
}
.receivable-header {
  align-items: center;
  display: flex;
  justify-content: space-between;
  padding: 24rpx;
}
.receivable-left {
  flex: 1;
  padding-right: 20rpx;
}
.receivable-name {
  color: #262626;
  display: block;
  font-size: 28rpx;
  font-weight: 700;
}
.receivable-meta {
  color: #8c8c8c;
  display: block;
  font-size: 22rpx;
  margin-top: 8rpx;
}
.receivable-right {
  align-items: flex-end;
  display: flex;
  flex-direction: column;
}
.receivable-amount {
  color: #ff4d4f;
  font-size: 28rpx;
  font-weight: 700;
}
.receivable-arrow {
  color: #8c8c8c;
  font-size: 22rpx;
  margin-top: 6rpx;
  transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
}
.receivable-arrow.expanded {
  transform: rotate(180deg);
}
.receivable-body {
  border-top: 1rpx solid #f5f5f5;
  padding: 0 20rpx 20rpx;
  overflow: hidden;
  max-height: 0;
  padding-top: 0;
  padding-bottom: 0;
  transition: max-height 0.45s cubic-bezier(0.34, 1.56, 0.64, 1), padding 0.45s cubic-bezier(0.34, 1.56, 0.64, 1);
}
.receivable-body.expanded {
  max-height: 2000rpx;
  padding: 0 20rpx 20rpx;
}
.receivable-order {
  background: linear-gradient(180deg, #FBFCFE, #f5faff);
  border: 1rpx solid #edf4fb;
  border-radius: 18rpx;
  margin-top: 16rpx;
  padding: 18rpx 18rpx 14rpx;
}
.receivable-order.partial-paid {
  background: linear-gradient(180deg, #FFF8ED, #fff7e6);
  border: 1rpx solid #ffd591;
}
.order-total.partial {
  color: #fa8c16;
}
.order-top {
  align-items: center;
  display: flex;
  gap: 20rpx;
  justify-content: space-between;
  margin-bottom: 14rpx;
}
.order-date {
  color: #595959;
  font-size: 22rpx;
}
.order-total {
  color: #8c8c8c;
  font-size: 22rpx;
  text-align: right;
}
.goods-table-head,
.goods-table-row {
  align-items: center;
  column-gap: 10rpx;
  display: grid;
  grid-template-columns: 2.2fr 1.2fr 1.2fr 1.3fr 1.2fr;
}
.goods-table-head {
  border-bottom: 1rpx dashed #e8e8e8;
  color: #8c8c8c;
  font-size: 21rpx;
  padding-bottom: 10rpx;
}
.goods-table-row {
  border-bottom: 1rpx dashed #f3f3f3;
  color: #262626;
  font-size: 22rpx;
  padding: 12rpx 0;
}
.goods-table-head text,
.goods-table-row text {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.goods-table-head text:first-child,
.goods-table-row text:first-child {
  line-height: 1.35;
  white-space: normal;
}
.goods-table-row:last-child {
  border-bottom: none;
}
.profit-cell {
  color: #4F6EF7;
}
.receivable-empty {
  background: #fff;
  border-radius: 24rpx;
  box-shadow: 0 10rpx 28rpx rgba(0, 0, 0, 0.04);
  color: #8c8c8c;
  margin: 0 32rpx;
  padding: 56rpx 24rpx;
  text-align: center;
}

/* 渐变流动 */
@keyframes gradientShift {
  0% { background-position: 0% 50%; }
  50% { background-position: 100% 50%; }
  100% { background-position: 0% 50%; }
}
