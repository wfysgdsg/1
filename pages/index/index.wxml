<view class="container scene-3d">

  <!-- 3D 深空背景 -->
  <view class="bg-orb bg-orb-a"></view>
  <view class="bg-orb bg-orb-b"></view>

  <!-- 3D 透视头部 -->
  <view class="header-3d {{_anim ? 'anim-enter-3d' : ''}}" style="animation-delay: 0s">
    <view class="header-bg"></view>
    <view class="header-orb-1"></view>
    <view class="header-orb-2"></view>

    <view class="user-info">
      <view class="welcome-box">
        <text class="greeting">{{uiText.greeting}}{{userName}}</text>
        <text class="date">{{currentDate}}</text>
      </view>
      <view bindtap="goToProfile" class="profile-entry tap-3d">
        <image wx:if="{{avatarUrl}}" class="profile-avatar" src="{{avatarUrl}}" mode="aspectFill"></image>
        <text wx:else class="profile-icon">{{uiText.profileIcon}}</text>
        <view class="profile-ring"></view>
      </view>
    </view>
  </view>

  <!-- 3D 统计卡片（悬浮在头部下方） -->
  <view class="stats-3d {{_anim ? 'anim-spring' : ''}}" style="animation-delay: 0.1s">
    <view class="stats-glow"></view>
    <view class="stat-main">
      <text class="stat-val">¥{{todaySales}}</text>
      <text class="stat-lab">{{uiText.todaySales}}</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-side">
      <view class="stat-mini">
        <text class="mini-val">{{stockTotal}}</text>
        <text class="mini-lab">{{uiText.stockTotal}}</text>
      </view>
      <view class="stat-mini">
        <text class="mini-val {{unpaidCount>0?'danger':'mint'}}">{{unpaidCount}}</text>
        <text class="mini-lab">{{uiText.unpaidCount}}</text>
      </view>
    </view>
  </view>

  <!-- 3D 网格统计 -->
  <view class="grid-stats {{_anim ? 'anim-depth' : ''}}" style="animation-delay: 0.18s">
    <view bindtap="goToGoods" class="grid-item tap-3d">
      <view class="grid-icon-wrap"><view class="grid-icon-orb violet"></view></view>
      <text class="grid-num">{{goodsCount}}</text>
      <text class="grid-label">{{uiText.goodsCount}}</text>
    </view>
    <view bindtap="goToBorrow" class="grid-item tap-3d">
      <view class="grid-icon-wrap"><view class="grid-icon-orb amber"></view></view>
      <text class="grid-num">{{borrowCount}}</text>
      <text class="grid-label">{{uiText.borrowCount}}</text>
    </view>
    <view bindtap="goToSale" class="grid-item tap-3d">
      <view class="grid-icon-wrap"><view class="grid-icon-orb blue"></view></view>
      <text class="grid-num">{{saleCount}}</text>
      <text class="grid-label">{{uiText.saleCount}}</text>
    </view>
  </view>

  <!-- 提醒条 -->
  <view bindtap="goToTransfer" class="alert-bar {{_anim ? 'anim-slide-left' : ''}}" wx:if="{{transferCount>0}}" style="animation-delay: 0.22s">
    <view class="alert-glow coral"></view>
    <view class="alert-content">
      <text class="alert-text">{{transferTipText}}</text>
    </view>
    <text class="alert-btn">去处理 →</text>
  </view>
  <view bindtap="goToBorrow" class="alert-bar amber-bar {{_anim ? 'anim-slide-left' : ''}}" wx:if="{{overdueBorrows.length>0}}" style="animation-delay: 0.26s">
    <view class="alert-glow amber"></view>
    <view class="alert-content">
      <text class="alert-text">{{overdueTipText}}</text>
    </view>
    <text class="alert-btn">去处理 →</text>
  </view>

  <!-- 快捷操作区 -->
  <view class="section-title {{_anim ? 'anim-spring' : ''}}" style="animation-delay: 0.3s">
    <text>{{uiText.quickActions}}</text>
    <text class="title-tip">{{uiText.quickTip}}</text>
  </view>

  <view class="action-grid {{_anim ? 'anim-enter-3d' : ''}}" style="animation-delay: 0.35s">
    <view bindtap="goToAddSale" class="action-card card-3d action-violet">
      <view class="card-glow"></view>
      <view class="card-content">
        <text class="action-title">{{uiText.addSale}}</text>
        <text class="action-desc">{{uiText.addSaleDesc}}</text>
      </view>
      <view class="card-arrow">→</view>
    </view>
    <view bindtap="goToAddBorrow" class="action-card card-3d action-coral">
      <view class="card-glow"></view>
      <view class="card-content">
        <text class="action-title">{{uiText.addBorrow}}</text>
        <text class="action-desc">{{uiText.addBorrowDesc}}</text>
      </view>
      <view class="card-arrow">→</view>
    </view>

    <!-- 迷你操作行 -->
    <view class="mini-action-row">
      <view bindtap="goToDebt" class="mini-action tap-3d">
        <view class="mini-icon coral-bg">
          <view class="mini-icon-glow coral"></view>
          <text>{{uiText.debtIcon}}</text>
        </view>
        <text class="mini-text">{{uiText.debt}}</text>
        <view class="mini-badge" wx:if="{{unpaidCount>0}}">{{unpaidCount}}</view>
      </view>
      <view bindtap="goToContact" class="mini-action tap-3d">
        <view class="mini-icon mint-bg">
          <view class="mini-icon-glow mint"></view>
          <text>{{uiText.contactIcon}}</text>
        </view>
        <text class="mini-text">{{uiText.contact}}</text>
      </view>
      <view bindtap="goToReport" class="mini-action tap-3d">
        <view class="mini-icon violet-bg">
          <view class="mini-icon-glow violet"></view>
          <text>{{uiText.reportIcon}}</text>
        </view>
        <text class="mini-text">{{uiText.report}}</text>
      </view>
      <view bindtap="goToTransfer" class="mini-action tap-3d">
        <view class="mini-icon blue-bg">
          <view class="mini-icon-glow blue"></view>
          <text>{{uiText.transferIcon}}</text>
        </view>
        <text class="mini-text">{{uiText.transfer}}</text>
        <view class="mini-badge" wx:if="{{transferCount>0}}">{{transferCount}}</view>
      </view>
    </view>
  </view>

  <!-- 应收账款 -->
  <view class="section-title receivable-title {{_anim ? 'anim-spring' : ''}}" style="animation-delay: 0.4s">
    <text>{{uiText.receivableTitle}}</text>
    <text bindtap="goToDebt" class="title-tip">{{uiText.viewAll}} →</text>
  </view>

  <view class="receivable-panel" wx:if="{{receivableList.length>0}}">
    <view class="receivable-card card-3d {{_anim ? 'anim-slide-right' : ''}}" wx:for="{{receivableList}}" wx:key="customerId" style="animation-delay: {{index * 0.08 < 0.4 ? index * 0.08 : 0.4}}s">
      <view bindtap="toggleReceivable" class="receivable-header" data-id="{{item.customerId}}">
        <view class="receivable-left">
          <text class="receivable-name">{{item.customerName}}</text>
          <text class="receivable-meta">{{buildOrderMeta(item.orderCount)}}</text>
        </view>
        <view class="receivable-right">
          <text class="receivable-amount">¥{{item.totalAmount}}</text>
          <text class="receivable-arrow">{{receivableExpandedId===item.customerId?uiText.collapse:uiText.expand}}</text>
        </view>
      </view>
      <view class="receivable-body {{receivableExpandedId===item.customerId ? 'expanded' : ''}}">
        <view class="receivable-order {{order.hasPartial ? 'partial-paid' : ''}}" wx:for="{{item.orders}}" wx:for-item="order" wx:key="_id">
          <view class="order-top">
            <text class="order-date">{{order.saleDate}}</text>
            <text class="order-total {{order.hasPartial ? 'partial' : ''}}">{{buildOrderTotal(order)}}</text>
          </view>
          <view class="goods-table">
            <view class="goods-table-head">
              <text>{{uiText.goods}}</text>
              <text>{{uiText.quantity}}</text>
              <text>{{uiText.price}}</text>
              <text>{{uiText.total}}</text>
              <text>{{uiText.profit}}</text>
            </view>
            <view class="goods-table-row" wx:for="{{order.goodsRows}}" wx:for-item="row" wx:key="goodsName">
              <text>{{row.goodsName}}</text>
              <text>{{row.quantity}}{{row.unit}}</text>
              <text>{{row.salePrice}}</text>
              <text>{{row.lineTotal}}</text>
              <text class="profit-cell">{{row.profit}}</text>
            </view>
          </view>
        </view>
      </view>
    </view>
  </view>
  <view class="receivable-empty" wx:else>
    <view class="empty-state">
      <text class="empty-icon">✨</text>
      <text class="empty-text">{{uiText.noReceivables}}</text>
    </view>
  </view>
</view>
