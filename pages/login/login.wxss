/* ============================================================
   登录页 — NEXUS-3D 前卫设计
   ============================================================ */

page {
  background: radial-gradient(ellipse at 30% 0%, #1A1244 0%, transparent 50%),
              radial-gradient(ellipse at 70% 100%, #0A1A3A 0%, transparent 50%),
              var(--void);
  overflow: hidden;
}

.container {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 48rpx;
  position: relative;
}

/* ===== 背景网格 ===== */
.bg-grid {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background-image:
    linear-gradient(rgba(123,97,255,0.03) 1rpx, transparent 1rpx),
    linear-gradient(90deg, rgba(123,97,255,0.03) 1rpx, transparent 1rpx);
  background-size: 60rpx 60rpx;
  z-index: 0;
  mask-image: linear-gradient(180deg, transparent 0%, rgba(0,0,0,0.5) 30%, transparent 80%);
  -webkit-mask-image: linear-gradient(180deg, transparent 0%, rgba(0,0,0,0.5) 30%, transparent 80%);
}

/* ===== 背景光晕（多深度） ===== */
.bg-orb {
  animation: nexus-float 10s ease-in-out infinite;
  opacity: 0.5;
  z-index: 0;
}
.bg-orb-1 {
  background: linear-gradient(135deg, #7B61FF, #00D4FF);
  width: 440rpx; height: 440rpx;
  right: -120rpx; top: -120rpx;
  animation-delay: 0s;
}
.bg-orb-2 {
  background: linear-gradient(135deg, #FF4FA3, #7B61FF);
  width: 320rpx; height: 320rpx;
  left: -100rpx; top: 300rpx;
  animation-delay: -4s;
  opacity: 0.35;
}
.bg-orb-3 {
  background: linear-gradient(135deg, #00F5A0, #00D4FF);
  width: 280rpx; height: 280rpx;
  right: 30rpx; bottom: 50rpx;
  animation-delay: -7s;
  opacity: 0.3;
}

/* ===== 3D 舞台 ===== */
.login-stage {
  width: 100%;
  position: relative;
  z-index: 10;
  transform-style: preserve-3d;
}

/* ===== Logo 3D ===== */
.logo-section {
  text-align: center;
  margin-bottom: 64rpx;
  margin-top: 20rpx;
}
.logo-3d-wrap {
  position: relative;
  width: 180rpx;
  height: 180rpx;
  margin: 0 auto 28rpx;
  transform-style: preserve-3d;
  animation: nexus-float 6s ease-in-out infinite;
}
.logo-circle {
  position: absolute;
  top: 0; left: 0;
  width: 100%; height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, rgba(123,97,255,0.15), rgba(0,212,255,0.1));
  backdrop-filter: blur(20rpx);
  border: 2rpx solid rgba(255,255,255,0.15);
  border-radius: 50%;
  box-shadow: 0 30rpx 60rpx rgba(0,0,0,0.4),
              inset 0 2rpx 20rpx rgba(255,255,255,0.05);
  transform: translateZ(20rpx);
}
.logo-icon {
  font-size: 80rpx;
  filter: drop-shadow(0 4rpx 8rpx rgba(0,0,0,0.3));
}
/* 旋转环 1 */
.logo-ring-1 {
  position: absolute;
  top: -12rpx; left: -12rpx; right: -12rpx; bottom: -12rpx;
  border: 3rpx solid transparent;
  border-top-color: var(--neon-violet);
  border-right-color: rgba(0,212,255,0.4);
  border-radius: 50%;
  animation: nexus-spin 4s linear infinite;
}
/* 旋转环 2（反向） */
.logo-ring-2 {
  position: absolute;
  top: -24rpx; left: -24rpx; right: -24rpx; bottom: -24rpx;
  border: 2rpx solid transparent;
  border-bottom-color: rgba(0,245,160,0.3);
  border-left-color: rgba(255,79,163,0.2);
  border-radius: 50%;
  animation: nexus-spin 6s linear infinite reverse;
}
/* 辉光 */
.logo-glow {
  position: absolute;
  top: 50%; left: 50%;
  width: 200%; height: 200%;
  transform: translate(-50%, -50%);
  background: radial-gradient(circle, rgba(123,97,255,0.15) 0%, transparent 50%);
  border-radius: 50%;
  pointer-events: none;
}
.logo-title {
  display: block;
  font-size: 48rpx;
  font-weight: 800;
  letter-spacing: 4rpx;
  background: linear-gradient(135deg, #fff 0%, #B8C4FF 50%, #7B61FF 100%);
  -webkit-background-clip: text;
  background-clip: text;
  -webkit-text-fill-color: transparent;
}
.logo-subtitle {
  display: block;
  font-size: 22rpx;
  letter-spacing: 6rpx;
  margin-top: 12rpx;
  text-transform: uppercase;
  color: rgba(255,255,255,0.35);
}

/* ===== 表单卡片 ===== */
.form-card {
  padding: 56rpx 44rpx;
  width: 100%;
  box-sizing: border-box;
  box-shadow: 0 40rpx 80rpx rgba(0,0,0,0.35),
              inset 0 1rpx 0 rgba(255,255,255,0.05);
}

/* ===== 字段 ===== */
.field-wrapper {
  margin-bottom: 36rpx;
  position: relative;
}
.field-label {
  color: rgba(255,255,255,0.5);
  font-size: 24rpx;
  font-weight: 500;
  margin-bottom: 14rpx;
  padding-left: 8rpx;
  letter-spacing: 3rpx;
  text-transform: uppercase;
}
.input-wrapper {
  position: relative;
  display: flex;
  align-items: center;
  background: rgba(255,255,255,0.04);
  border: 1rpx solid rgba(255,255,255,0.08);
  border-radius: 24rpx;
  padding: 0 28rpx;
  height: 100rpx;
  transition: all 0.35s var(--ease-expo);
  overflow: hidden;
}
.input-wrapper.focused {
  border-color: var(--neon-violet);
  background: rgba(123,97,255,0.06);
  box-shadow: 0 0 0 4rpx rgba(123,97,255,0.08),
              0 8rpx 32rpx rgba(123,97,255,0.15);
}
.field-icon {
  position: relative;
  width: 56rpx; height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
}
.icon-orb {
  position: absolute;
  width: 100%; height: 100%;
  border-radius: 50%;
  opacity: 0.15;
  transition: opacity 0.3s ease;
}
.user-orb {
  background: radial-gradient(circle, var(--neon-blue), transparent);
}
.lock-orb {
  background: radial-gradient(circle, var(--neon-violet), transparent);
}
.input-wrapper.focused .icon-orb {
  opacity: 0.35;
}
.icon-emoji {
  position: relative;
  font-size: 28rpx;
  z-index: 1;
}
.field-input {
  flex: 1;
  height: 100%;
  color: var(--text-primary);
  font-size: 30rpx;
  background: transparent;
  border: none;
  padding: 0;
  border-radius: 0;
}
.placeholder {
  color: rgba(255,255,255,0.25);
}
/* 底部高亮线 */
.input-line {
  position: absolute;
  bottom: 0; left: 50%;
  width: 0; height: 2rpx;
  background: linear-gradient(90deg, var(--neon-violet), var(--neon-blue));
  border-radius: 1rpx;
  transition: width 0.4s var(--ease-expo), left 0.4s var(--ease-expo);
}
.input-line.active {
  width: 100%;
  left: 0;
}
.eye-btn {
  font-size: 32rpx;
  padding: 10rpx;
  opacity: 0.5;
  transition: opacity 0.2s ease, transform 0.2s var(--ease-spring);
}
.eye-btn.showing {
  opacity: 1;
}
.eye-btn:active {
  transform: scale(0.85);
}

/* ===== 选项行 ===== */
.option-row {
  display: flex;
  justify-content: space-between;
  margin-bottom: 44rpx;
  padding: 0 8rpx;
}
.option-item {
  display: flex;
  align-items: center;
}
.radio-3d {
  width: 36rpx; height: 36rpx;
  border: 2rpx solid rgba(255,255,255,0.2);
  border-radius: 50%;
  margin-right: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s var(--ease-spring);
  background: rgba(255,255,255,0.03);
}
.radio-3d.checked {
  border-color: var(--neon-violet);
  background: var(--grad-primary);
  box-shadow: 0 0 16rpx rgba(123,97,255,0.4);
  transform: scale(1.05);
}
.radio-dot {
  width: 14rpx; height: 14rpx;
  background: #fff;
  border-radius: 50%;
  animation: nexus-pop 0.3s var(--ease-spring);
}
.option-text {
  color: rgba(255,255,255,0.55);
  font-size: 26rpx;
}

/* ===== 登录按钮 ===== */
.btn-wrapper {
  position: relative;
}
.login-btn {
  width: 100%;
  border-radius: 28rpx;
  padding: 28rpx 0;
  font-size: 32rpx;
  font-weight: 700;
  letter-spacing: 4rpx;
  background: linear-gradient(135deg, #7B61FF 0%, #00D4FF 100%);
  box-shadow: 0 12rpx 40rpx rgba(123,97,255,0.4),
              inset 0 1rpx 0 rgba(255,255,255,0.2);
}
.btn-text {
  position: relative;
  z-index: 2;
}

/* ===== 底部链接 ===== */
.extra-links {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
  margin-top: 40rpx;
}
.link {
  color: rgba(255,255,255,0.45);
  font-size: 24rpx;
  transition: color 0.2s ease;
}
.link:active {
  color: var(--neon-blue);
}
.divider {
  color: rgba(255,255,255,0.2);
  font-size: 24rpx;
}
.footer {
  margin-top: 24rpx;
  text-align: center;
}
.footer text {
  color: rgba(255,255,255,0.2);
  font-size: 22rpx;
}
